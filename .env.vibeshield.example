# ============================================================================
# Vibeshield Environment Variables
# ============================================================================
# Copy this file to .env.vibeshield and fill in your values:
#   cp .env.vibeshield.example .env.vibeshield
#
# NEVER commit .env.vibeshield — it is gitignored.
#
# For 1Password integration, use op:// references instead of plain values.
# This requires OP_VIBESHIELD_SERVICE_ACCOUNT_TOKEN to be set.
# ============================================================================

# ---------------------------------------------------------------------------
# Required: Anthropic API Key
# ---------------------------------------------------------------------------
# Your Anthropic API key for Claude Code
# Plain:    ANTHROPIC_API_KEY=sk-ant-...
# 1Password: ANTHROPIC_API_KEY=op://vault/item/field
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Optional: GitHub Token
# ---------------------------------------------------------------------------
# Recommended: Fine-grained Personal Access Token (PAT)
# - Scope to specific repositories only
# - Grant minimal permissions (Contents: read, Pull Requests: write)
# - In lockdown mode, consider not setting this at all
#
# Plain:    GITHUB_TOKEN=ghp_...
# 1Password: GITHUB_TOKEN=op://vault/item/field
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# Optional: 1Password Service Account Token
# ---------------------------------------------------------------------------
# If set, the 1Password CLI will be installed in the container
# and op:// references in other variables will be resolved automatically.
# Get a service account token: https://developer.1password.com/docs/service-accounts
OP_VIBESHIELD_SERVICE_ACCOUNT_TOKEN=

# ---------------------------------------------------------------------------
# Network Mode
# ---------------------------------------------------------------------------
# Controls the firewall mode on container start:
#   lockdown  — Claude API + GitHub only (most restrictive)
#   standard  — Common development domains (recommended default)
#   open      — No network restrictions (least secure)
NETWORK_MODE=standard

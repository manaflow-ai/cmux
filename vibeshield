# --- claw-wrap container-side setup ---
# Configure the container to use claw-wrap for CLI and HTTP proxy credential
# injection. Installs the linux binary, creates symlinks, locks down real
# binaries, starts daemon inside container, installs MITM CA, and creates
# the git-askpass helper. Daemon runs INSIDE the container — no socat relay.
# Called after container is running, between config sync and firewall setup.
# Requires: VS_CRED_* env vars set by claw_wrap_resolve_credentials().
claw_wrap_container_setup() {
  echo "Configuring claw-wrap proxy in container..."

  # 0. Detect stale bind mount from pre-upgrade container
  if docker exec "${CONTAINER_ID}" mountpoint -q /run/openclaw 2>/dev/null; then
    echo "  ERROR: /run/openclaw is a stale bind mount from a previous container version."
    echo "  The container must be rebuilt after this devcontainer.json change."
    echo "  Run: docker rm -f \$(docker ps -q --filter label=devcontainer.local_folder=${WORKSPACE_FOLDER})"
    echo "  Then re-run ./vibeshield"
    return 1
  fi

  # 1. Download and install claw-wrap linux binary into container
  local container_arch
  container_arch=$(docker exec "${CONTAINER_ID}" dpkg --print-architecture 2>/dev/null || echo "amd64")
  local linux_tarball="claw-wrap_${CLAW_WRAP_VERSION}_linux_${container_arch}.tar.gz"
  local linux_url="https://github.com/dedene/claw-wrap/releases/download/v${CLAW_WRAP_VERSION}/${linux_tarball}"
  local tmp_binary
  tmp_binary=$(mktemp)

  # Download linux binary and verify checksum (same rigor as host install)
  if curl -fsSL "${linux_url}" -o "${tmp_binary}.tar.gz" 2>/dev/null; then
    # Verify checksum if available
    if [[ -f "${CLAW_WRAP_CHECKSUMS}" ]]; then
      local expected_hash
      expected_hash=$(grep "${linux_tarball}" "${CLAW_WRAP_CHECKSUMS}" | awk '{print $1}')
      if [[ -n "${expected_hash}" && "${expected_hash}" != PLACEHOLDER* ]]; then
        local actual_hash
        actual_hash=$(shasum -a 256 "${tmp_binary}.tar.gz" | awk '{print $1}')
        if [[ "${actual_hash}" != "${expected_hash}" ]]; then
          echo "  WARNING: Checksum mismatch for linux binary — skipping container install"
          rm -f "${tmp_binary}.tar.gz"
          rm -f "${tmp_binary}"
          return 1
        fi
      fi
    fi
    tar -xzf "${tmp_binary}.tar.gz" -C "$(dirname "${tmp_binary}")" claw-wrap 2>/dev/null
    if [[ -f "$(dirname "${tmp_binary}")/claw-wrap" ]]; then
      mv "$(dirname "${tmp_binary}")/claw-wrap" "${tmp_binary}"
    fi
    rm -f "${tmp_binary}.tar.gz"
  fi

  if [[ -s "${tmp_binary}" ]]; then
    docker cp "${tmp_binary}" "${CONTAINER_ID}:/usr/local/bin/claw-wrap"
    docker exec "${CONTAINER_ID}" chmod 755 /usr/local/bin/claw-wrap
    echo "  Installed claw-wrap linux binary"
  else
    echo "  WARNING: Could not obtain claw-wrap linux binary — CLI wrapping disabled"
    rm -f "${tmp_binary}"
    return 1
  fi
  rm -f "${tmp_binary}"

  # 2. Create symlinks and git wrapper
  # gh: symlink to claw-wrap (API-only tool, no volume writes)
  docker exec "${CONTAINER_ID}" ln -sf /usr/local/bin/claw-wrap /usr/local/bin/gh
  # get-github-token: symlink to claw-wrap (askpass token retrieval via daemon socket)
  docker exec "${CONTAINER_ID}" ln -sf /usr/local/bin/claw-wrap /usr/local/bin/get-github-token
  # git: wrapper script (runs as vscode UID 1000 for Docker volume writes).
  # Filters blocked args (credential ops, config manipulation) before exec'ing /usr/bin/git.
  # Auth via GIT_ASKPASS → get-github-token → daemon socket → credential injection.
  # Note: setgid doesn't work on Linux shell scripts — /usr/bin/git is 0755 instead,
  # with deny rule Bash(/usr/bin/git*) blocking direct absolute-path invocation.
  docker exec "${CONTAINER_ID}" bash -c 'cat > /usr/local/bin/git << "GITWRAP"
#!/bin/sh
# vibeshield git wrapper — argument filtering + credential isolation
# Runs as vscode (UID 1000) for Docker volume writes.
# Auth: GIT_ASKPASS calls get-github-token via claw-wrap daemon socket.
if [ "$1" = "-c" ]; then
  case "$2" in
    credential.*|core.askPass*|core.pager*|core.gitProxy*|core.fsmonitor*|core.editor*|http.proxy*|http.sslVerify*|url.*|alias.*|diff.external*|filter.*)
      echo "Error: git -c $2 is blocked by vibeshield" >&2; exit 1 ;;
  esac
fi
case "$*" in
  *credential*) echo "Error: git credential operations are blocked by vibeshield" >&2; exit 1 ;;
  *config*core.askPass*) echo "Error: git askPass configuration is blocked by vibeshield" >&2; exit 1 ;;
  *config*core.sshCommand*) echo "Error: git sshCommand configuration is blocked by vibeshield" >&2; exit 1 ;;
  *config*core.pager*) echo "Error: git pager configuration is blocked by vibeshield" >&2; exit 1 ;;
  *config*core.gitProxy*) echo "Error: git gitProxy configuration is blocked by vibeshield" >&2; exit 1 ;;
  *config*core.fsmonitor*) echo "Error: git fsmonitor configuration is blocked by vibeshield" >&2; exit 1 ;;
  *config*http.proxy*) echo "Error: git proxy configuration is blocked by vibeshield" >&2; exit 1 ;;
  *config*http.sslVerify*) echo "Error: git sslVerify configuration is blocked by vibeshield" >&2; exit 1 ;;
  *config*url.*) echo "Error: git URL rewriting is blocked by vibeshield" >&2; exit 1 ;;
  *config*alias.*) echo "Error: git alias creation is blocked by vibeshield" >&2; exit 1 ;;
  *config*diff.external*) echo "Error: git diff.external is blocked by vibeshield" >&2; exit 1 ;;
  *config*filter.*) echo "Error: git filter configuration is blocked by vibeshield" >&2; exit 1 ;;
esac
exec /usr/bin/git "$@"
GITWRAP
chmod 755 /usr/local/bin/git'
  echo "  Created: gh symlink, get-github-token symlink, git wrapper"

  # 3. Lock down real binaries — daemon (claw-wrap group) can execute, agent (vscode) cannot.
  # 0750 root:claw-wrap: owner=root(rwx), group=claw-wrap(r-x), other=none.
  # This must run AFTER step 4 (user creation) to reference the claw-wrap group.
  # Deferred to after user creation below.

  # 4. Ensure claw-wrap system user exists (SA15 — least-privilege daemon).
  # Also created in devcontainer.json onCreateCommand for structural test coverage.
  # This is the authoritative creation point; devcontainer.json is the eager fallback.
  # User creation is idempotent (|| true). Group membership is always refreshed
  # so it works even when the user already existed from a prior run.
  # Two groups with distinct purposes (security review: single group is a bypass):
  #   claw-wrap      — daemon primary group. Owns socket, config, auth, logs.
  #                    vscode added for socket IPC access.
  #   claw-wrap-exec — binary execution. Daemon only, NOT vscode.
  #                    Gates /usr/bin/gh and /usr/bin/git access.
  docker exec -u root "${CONTAINER_ID}" bash -c \
    'groupadd claw-wrap 2>/dev/null || true
     groupadd claw-wrap-exec 2>/dev/null || true
     useradd -r -g claw-wrap -s /usr/sbin/nologin -M claw-wrap 2>/dev/null || true
     usermod -a -G claw-wrap-exec claw-wrap 2>/dev/null || true
     usermod -a -G claw-wrap vscode 2>/dev/null || true'

  # Determine daemon user — fall back to root if user creation failed
  local DAEMON_USER="claw-wrap"
  if ! docker exec "${CONTAINER_ID}" id claw-wrap &>/dev/null; then
    echo "  ERROR: Failed to create claw-wrap user — proxy mode requires least-privilege daemon"
    echo "  Falling back to env-direct mode (credentials in container environment)"
    return 1
  else
    echo "  Daemon user: claw-wrap (uid=$(docker exec "${CONTAINER_ID}" id -u claw-wrap 2>/dev/null))"
  fi

  # 5. Lock down real binaries.
  # /usr/bin/gh: 0750 root:claw-wrap-exec (agent must use claw-wrap symlink)
  # /usr/bin/git: 0755 (world-executable — setgid doesn't work on Linux shell scripts,
  #   so the wrapper can't use group access. Binary lockdown replaced by:
  #   deny rule Bash(/usr/bin/git*) blocks absolute-path invocation,
  #   wrapper at /usr/local/bin/git provides argument filtering,
  #   firewall + sandbox are the hard boundaries)
  # vscode is in claw-wrap group (socket IPC) but NOT in claw-wrap-exec (binary execution).
  docker exec -u root "${CONTAINER_ID}" bash -c \
    "chgrp claw-wrap-exec /usr/bin/gh 2>/dev/null; chmod 750 /usr/bin/gh 2>/dev/null; chmod 755 /usr/bin/git 2>/dev/null" || true
  echo "  Locked /usr/bin/gh (root:claw-wrap-exec 750); /usr/bin/git 755 (wrapper + deny rules)"

  # 6. Create /run/openclaw directory (0751 — world-traversable, not listable)
  # Socket permissions follow standard service socket pattern (like MySQL/PostgreSQL)
  docker exec -u root "${CONTAINER_ID}" bash -c \
    "mkdir -p /run/openclaw && chown ${DAEMON_USER}:${DAEMON_USER} /run/openclaw && chmod 0751 /run/openclaw"
  # Pre-create /etc/openclaw for MITM CA storage — daemon needs to write CA cert here
  # but can't create /etc/ subdirectories as non-root
  # /etc/openclaw stays root-owned; only ca/ subdirectory is daemon-writable (CA-012)
  docker exec -u root "${CONTAINER_ID}" bash -c \
    "mkdir -p /etc/openclaw/ca && chown root:root /etc/openclaw && chown ${DAEMON_USER}:${DAEMON_USER} /etc/openclaw/ca"

  # 7. Generate config inside container, then transfer ownership to daemon user.
  # Config is written as root (claw_wrap_config_generate_in_container uses docker exec -u root),
  # then immediately chowned so the daemon can read it at startup.
  claw_wrap_config_generate_in_container
  docker exec -u root "${CONTAINER_ID}" bash -c \
    "chown ${DAEMON_USER}:${DAEMON_USER} /run/openclaw/config.yaml 2>/dev/null || true
     if [[ -f /run/openclaw/auth ]]; then chown ${DAEMON_USER}:${DAEMON_USER} /run/openclaw/auth; fi"

  # 8. Verify credentials exist before proceeding
  if ! compgen -v VS_CRED_ > /dev/null 2>&1; then
    echo "  ERROR: No VS_CRED_* vars resolved — cannot start daemon"
    return 1
  fi

  # 9. Write credential env file for claw-wrap daemon.
  # claw-wrap's env: source reads from /run/openclaw/env (systemd-style credential file),
  # NOT from process environment variables. Write VS_CRED_* as key=value pairs.
  # Newlines in values would break the key=value format — reject them (CA-001).
  local env_content=""
  for varname in $(compgen -v VS_CRED_); do
    local val="${!varname}"
    if [[ "${val}" == *$'\n'* ]]; then
      echo "  WARNING: ${varname} contains newlines — skipping (would break env file format)"
      continue
    fi
    env_content+="${varname}=${val}"$'\n'
  done
  printf '%s' "${env_content}" | docker exec -i -u root "${CONTAINER_ID}" \
    bash -c "umask 0077 && cat > /run/openclaw/env && chown ${DAEMON_USER}:${DAEMON_USER} /run/openclaw/env && chmod 0600 /run/openclaw/env"

  # 10. Create log directory, home dir, and start daemon as least-privilege user.
  # docker exec -d detaches the session. exec replaces bash with the daemon
  # so there is no orphaned shell parent. No nohup or & needed.
  # Log directory: 0700 daemon-user-only (SA8 — agent must not read/tamper daemon logs)
  # Home dir: needed for git config. safe.directory=* allows git to operate on any workspace.
  # PATH: /usr/bin first so daemon's forked children (gh→git) resolve to real binaries,
  # not claw-wrap symlinks — prevents recursive proxy calls (Option C from security review).
  docker exec -u root "${CONTAINER_ID}" bash -c \
    "mkdir -p /var/log/vibeshield && chown ${DAEMON_USER}:${DAEMON_USER} /var/log/vibeshield && chmod 0700 /var/log/vibeshield
     mkdir -p /home/${DAEMON_USER} && chown ${DAEMON_USER}:${DAEMON_USER} /home/${DAEMON_USER}
     /usr/bin/git config --system --add safe.directory '*'"
  docker exec -u "${DAEMON_USER}" -d \
    "${CONTAINER_ID}" \
    bash -c 'umask 0077 && export PATH=/usr/bin:/usr/sbin:/usr/local/bin && exec claw-wrap daemon --config /run/openclaw/config.yaml --socket /run/openclaw/secrets.sock --uid 1000 >/var/log/vibeshield/claw-wrap.log 2>&1'

  # 11. Wait for daemon readiness — TWO checks (socket + HTTP proxy)
  echo "  Waiting for daemon readiness..."

  # Check 1: CLI socket (with daemon liveness check — CA-009)
  local wait_count=0
  while [[ ${wait_count} -lt 50 ]]; do
    if docker exec "${CONTAINER_ID}" test -S /run/openclaw/secrets.sock 2>/dev/null; then
      break
    fi
    # Fail fast if daemon already exited
    if ! docker exec "${CONTAINER_ID}" pgrep -x claw-wrap &>/dev/null; then
      echo "  ERROR: claw-wrap daemon exited during startup"
      echo "  Check logs: docker exec ${CONTAINER_ID} cat /var/log/vibeshield/claw-wrap.log"
      return 1
    fi
    sleep 0.1
    wait_count=$((wait_count + 1))
  done
  if docker exec "${CONTAINER_ID}" test -S /run/openclaw/secrets.sock 2>/dev/null; then
    echo "  CLI socket: /run/openclaw/secrets.sock OK"
    # Fix socket + directory permissions for cross-user access (daemon umask may be restrictive)
    # Directory: 0751 (world-traversable, not listable). Socket: 0660 (group read/write for vscode).
    docker exec -u root "${CONTAINER_ID}" bash -c \
      "chmod 0751 /run/openclaw && chmod 0660 /run/openclaw/secrets.sock"
  else
    echo "  WARNING: secrets.sock not detected after 5s"
    echo "  Check logs: docker exec ${CONTAINER_ID} cat /var/log/vibeshield/claw-wrap.log"
  fi

  # Check 2: HTTP proxy
  wait_count=0
  while [[ ${wait_count} -lt 50 ]]; do
    if docker exec "${CONTAINER_ID}" curl -s --max-time 1 http://127.0.0.1:18080 &>/dev/null; then
      break
    fi
    sleep 0.1
    wait_count=$((wait_count + 1))
  done
  if docker exec "${CONTAINER_ID}" curl -s --max-time 1 http://127.0.0.1:18080 &>/dev/null; then
    echo "  HTTP proxy: 127.0.0.1:18080 OK"
  else
    echo "  WARNING: HTTP proxy not responding after 5s"
    echo "  Check logs: docker exec ${CONTAINER_ID} cat /var/log/vibeshield/claw-wrap.log"
  fi

  # 12. Lock permissions and make proxy-auth-token group-readable.
  # - auth: 0640 (daemon + CLI client via group read for HMAC signing)
  # - proxy-auth-token: 0640 (needed to construct HTTPS_PROXY URL with auth)
  # - config: 0600 (daemon-only, no client access needed)
  docker exec -u root "${CONTAINER_ID}" bash -c \
    "if [[ -f /run/openclaw/auth ]]; then chmod 640 /run/openclaw/auth; fi
     if [[ -f /run/openclaw/proxy-auth-token ]]; then chmod 640 /run/openclaw/proxy-auth-token; fi
     chmod 600 /run/openclaw/config.yaml"
  echo "  HMAC secret + config locked: 0600/0640 ${DAEMON_USER}:${DAEMON_USER}"

  # 13. Read proxy-auth-token for HTTPS_PROXY URL construction.
  # The token is generated by the daemon — we read it after startup so the
  # caller can embed it in HTTPS_PROXY for ENV_FLAGS.
  PROXY_AUTH_TOKEN=$(docker exec -u root "${CONTAINER_ID}" cat /run/openclaw/proxy-auth-token 2>/dev/null || echo "")
  if [[ -n "${PROXY_AUTH_TOKEN}" ]]; then
    echo "  Proxy auth token: available"
  else
    echo "  WARNING: proxy-auth-token not found — HTTP proxy auth may fail"
  fi

  # 14. Install MITM CA into system trust store
  docker exec "${CONTAINER_ID}" bash -c \
    "if [[ -f /etc/openclaw/ca/ca.crt ]]; then
       cp /etc/openclaw/ca/ca.crt /usr/local/share/ca-certificates/vibeshield-mitm.crt
       update-ca-certificates 2>/dev/null
       chmod 0755 /etc/openclaw/ca
       chmod 0644 /etc/openclaw/ca/ca.crt
       chmod 0600 /etc/openclaw/ca/ca.key
     fi"
  echo "  MITM CA installed in system trust store"

  # 15. Create git-askpass-claw script (fetches token from daemon via get-github-token)
  # get-github-token is a claw-wrap symlink that calls printenv GH_TOKEN through the daemon.
  # The daemon injects the real GH_TOKEN; vscode's env never contains it.
  docker exec "${CONTAINER_ID}" bash -c 'cat > /opt/vibeshield/bin/git-askpass-claw << "ASKPASS"
#!/bin/sh
exec /usr/local/bin/get-github-token GH_TOKEN 2>/dev/null
ASKPASS
chmod +x /opt/vibeshield/bin/git-askpass-claw'
  echo "  Created git-askpass-claw helper (socket-based token retrieval)"

  echo "  claw-wrap daemon running inside container (user: ${DAEMON_USER})"
  {
    echo "=== claw-wrap container setup $(date) ==="
    echo "  Binary: /usr/local/bin/claw-wrap"
    echo "  Symlinks: gh, get-github-token → claw-wrap; git → setgid wrapper"
    echo "  Daemon: in-container as ${DAEMON_USER} (logged to /var/log/vibeshield/claw-wrap.log)"
    echo "  HMAC + config: 0600 ${DAEMON_USER}:${DAEMON_USER}"
    echo "  CA: system trust store"
  } >> "${LAUNCH_LOG:-/dev/null}"
}

# --- Resolve secrets ---
ENV_FLAGS=()
ANTHROPIC_KEY=""

LAUNCH_LOG="${WORKSPACE_FOLDER}/.vibeshield-launch.log"

# Detect secrets mode. claw-wrap runs inside the container (ADR-012), so no
# host binary is needed. Mode is determined by credential availability only.
detect_secrets_mode

# Diagnostic: log which 1Password conditions pass/fail
{
  echo "=== vibeshield diagnostic $(date) ==="
  echo "WORKSPACE_FOLDER=${WORKSPACE_FOLDER}"
  echo "SECRETS_MODE=${SECRETS_MODE}"
  [[ -n "${OP_VIBESHIELD_SERVICE_ACCOUNT_TOKEN:-}" ]] && echo "OP token: set" || echo "OP token: NOT set"
  [[ -f "${ENV_VIBESHIELD}" ]] && echo ".env.vibeshield: found" || echo ".env.vibeshield: NOT found (${ENV_VIBESHIELD})"
  command -v op &>/dev/null && echo "op CLI: found ($(command -v op))" || echo "op CLI: NOT found"
  command -v claw-wrap &>/dev/null && echo "claw-wrap: found ($(claw-wrap --version 2>/dev/null | head -1))" || echo "claw-wrap: NOT found"
  [[ -n "${FIREWALL_MODE}" ]] && echo "Firewall mode: ${FIREWALL_MODE}" || echo "Firewall mode: (default)"
  echo "Skip permissions: ${SKIP_PERMISSIONS}"
  echo "Auto-allow: ${AUTO_ALLOW}"
} | tee "${LAUNCH_LOG}"

if [[ "${SECRETS_MODE}" == "op-proxy" || "${SECRETS_MODE}" == "env-proxy" ]]; then
  # --- Proxy mode: resolve credentials on host, daemon starts in container later ---
  echo "Secrets mode: ${SECRETS_MODE} (credentials resolved on host, daemon runs in container)"
  if ! claw_wrap_resolve_credentials; then
    echo ""
    echo "  WARNING: Credential resolution failed."
    echo "  Proxy mode keeps all secrets out of the container."
    echo "  Falling back to env-direct passes REAL API keys into the container."
    echo ""
    echo "  Common causes:"
    echo "    - op:// refs in .env.vibeshield but OP_SERVICE_ACCOUNT_TOKEN not set"
    echo "    - 1Password CLI not installed (brew install 1password-cli)"
    echo "    - ANTHROPIC_API_KEY not in .env.vibeshield or host environment"
    echo ""
    read -r -p "  Continue with real credentials in container? [y/N] " ACCEPT_ENV_DIRECT
    if [[ ! "${ACCEPT_ENV_DIRECT}" =~ ^[Yy] ]]; then
      echo "  Fix credentials and re-run ./vibeshield"
      exit 1
    fi
    SECRETS_MODE="env-direct"
  else
    # In proxy mode, ENV_FLAGS contain only the dummy key and proxy vars.
    # No real secrets cross into the container environment.
    # VS_CRED_* vars are kept until claw_wrap_container_setup() passes them
    # to the in-container daemon via docker exec -e, then cleaned up.
    ENV_FLAGS=()
    ENV_FLAGS+=(-e "ANTHROPIC_API_KEY=${PROXY_DUMMY_KEY}")
    ENV_FLAGS+=(-e "_VIBESHIELD_CLAUDE_KEY=${PROXY_DUMMY_KEY}")  # ralphex strips ANTHROPIC_API_KEY; wrapper re-injects from this
    ENV_FLAGS+=(-e "GITHUB_TOKEN=")  # Override remoteEnv — claw-wrap CLI wrapper handles auth
    ENV_FLAGS+=(-e "OPENROUTER_API_KEY=dummy")  # Overwritten by claw-wrap proxy route
    ENV_FLAGS+=(-e "CODEX_API_KEY=")  # No claw-wrap route for direct OpenAI — use codex login in env-direct mode
    ENV_FLAGS+=(-e "OP_SERVICE_ACCOUNT_TOKEN=")  # Never needed in container with proxy
    ENV_FLAGS+=(-e "HTTPS_PROXY=http://127.0.0.1:18080")
    ENV_FLAGS+=(-e "NODE_EXTRA_CA_CERTS=/etc/openclaw/ca/ca.crt")
    ENV_FLAGS+=(-e "SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt")
    ENV_FLAGS+=(-e "GIT_ASKPASS=/opt/vibeshield/bin/git-askpass-claw")
    ENV_FLAGS+=(-e "GIT_TERMINAL_PROMPT=0")
    ENV_FLAGS+=(-e "GH_TOKEN=")  # Prevent Docker inheritance of host GH_TOKEN
    ANTHROPIC_KEY="proxy-managed"  # Pass the API key validation check
    echo "  ENV_FLAGS: dummy API key + proxy vars + git askpass (no real secrets)"
    # Hide .env.vibeshield from container — credentials already resolved on host,
    # the file serves no purpose inside the container and contains real secrets.
    # Move on host → bind mount reflects change instantly inside container.
    # Restore on exit via trap (handles detach, Ctrl-C, SIGTERM).
    if [[ -f "${ENV_VIBESHIELD}" ]]; then
      mv "${ENV_VIBESHIELD}" "${ENV_VIBESHIELD}.bak"

# --- Copy host Claude config (skills, plugins, agents) ---
# Snapshot host config into the container as root-owned read-only files.
# This ensures: (1) the agent can't tamper with skills/plugins, (2) a
# compromised host file after launch doesn't propagate to the running
# container, and (3) we can audit exactly what was copied.
HOST_CLAUDE_DIR="${HOME}/.claude"
CONTAINER_CLAUDE_DIR="/home/vscode/.claude"
COPIED_ITEMS=()

copy_host_dir() {
  local dir_name="$1"
  local lock="${2:-true}"  # "true" = root-owned read-only, "false" = vscode-owned writable
  local src="${HOST_CLAUDE_DIR}/${dir_name}"
  local dst="${CONTAINER_CLAUDE_DIR}/${dir_name}"

  if [[ ! -d "${src}" ]]; then
    return
  fi

  # Count items to copy (follow symlinks)
  local count
  count=$(find -L "${src}" -type f 2>/dev/null | wc -l | tr -d ' ')
  if [[ "${count}" -eq 0 ]]; then
    return
  fi

  # Remove any existing copy (from previous launch) and recreate
  docker exec "${CONTAINER_ID}" rm -rf "${dst}"
  docker exec "${CONTAINER_ID}" mkdir -p "${dst}"

  # Copy from host into container using tar to dereference symlinks.
  # Host skills/plugins often contain symlinks to package caches that
  # don't exist inside the container — tar -h resolves them to real files.
  # --no-xattrs suppresses macOS extended attribute warnings in GNU tar.
  if [[ "${lock}" == "true" ]]; then
    # Extract as root, then lock down (root-owned, read-only)
    tar -chf - --no-xattrs -C "${src}" . 2>/dev/null | docker exec -i "${CONTAINER_ID}" tar -xf - -C "${dst}" 2>/dev/null
    docker exec "${CONTAINER_ID}" chown -R root:root "${dst}"
    docker exec "${CONTAINER_ID}" chmod -R a+rX,a-w "${dst}"
  else
    # Extract as vscode with --no-same-permissions so umask applies (755/644).
    # chmod doesn't reliably propagate on Docker named volumes, so we avoid
    # extracting as root and trying to fix permissions afterward.
    docker exec "${CONTAINER_ID}" chown vscode:vscode "${dst}"
    tar -chf - --no-xattrs -C "${src}" . 2>/dev/null | docker exec -i -u vscode "${CONTAINER_ID}" tar -xf - --no-same-permissions -C "${dst}" 2>/dev/null
  fi

  COPIED_ITEMS+=("${dir_name} (${count} files)")
}


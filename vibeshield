#!/usr/bin/env bash
# vibeshield — hardened devcontainer for AI-assisted development.
#
# Usage: ./vibeshield [COMMAND] [OPTIONS]
#
# Commands:
#   (default)   Launch Claude Code in the vibeshield container
#   init        Re-run scaffolding setup (download/refresh from GitHub)
#
# Options:
#   --mode MODE                    Firewall mode: lockdown|standard|open (default: standard)
#   --auto-allow                   Sandbox auto-allow: autonomous Bash within sandbox bounds
#   --dangerously-skip-permissions Run Claude Code with --dangerously-skip-permissions
#   --shell                        Open a shell in the container (no secrets, no Claude)
#   --status                       Show container and firewall status, then exit
#   --ralphex [args...]             Run ralphex (must be last; remaining args passed through)
#   -h, --help                     Show this help
set -euo pipefail

# Prevent macOS tar from including ._* AppleDouble resource fork files.
# Only affects macOS; ignored on Linux. Exported once here instead of
# prefixing every tar invocation.
export COPYFILE_DISABLE=1

SCRIPT_VERSION="0.1.0"
VIBESHIELD_REPO="https://github.com/swannysec/vibeshield"
WORKSPACE_FOLDER="$(cd "$(dirname "$0")" && pwd)"

# --- Parse arguments ---
FIREWALL_MODE=""
SKIP_PERMISSIONS=false
AUTO_ALLOW=false
FORCE_INIT=false
ACTION="launch"  # launch | shell | status | init | ralphex
RALPHEX_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    init)
      ACTION="init"
      shift
      ;;
    --mode)
      FIREWALL_MODE="$2"
      shift 2
      ;;
    --force)
      FORCE_INIT=true
      shift
      ;;
    --auto-allow)
      AUTO_ALLOW=true
      shift
      ;;
    --dangerously-skip-permissions)
      SKIP_PERMISSIONS=true
      shift
      ;;
    --shell)
      ACTION="shell"
      shift
      ;;
    --status)
      ACTION="status"
      shift
      ;;
    --ralphex)
      ACTION="ralphex"
      shift
      # Collect remaining args for ralphex
      RALPHEX_ARGS=("$@")
      break
      ;;
    --version)
      echo "vibeshield ${SCRIPT_VERSION}"
      exit 0
      ;;
    -h|--help)
      sed -n '2,17p' "$0" | sed -E 's/^# ?//'
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
  esac
done

# Validate mode if specified
if [[ -n "${FIREWALL_MODE}" ]]; then
  case "${FIREWALL_MODE}" in
    lockdown|standard|open) ;;
    *)
      echo "ERROR: Invalid mode '${FIREWALL_MODE}'. Must be lockdown, standard, or open." >&2
      exit 1
      ;;
  esac
fi

# Validate flag combinations
if [[ "${SKIP_PERMISSIONS}" == "true" && "${AUTO_ALLOW}" == "true" ]]; then
  echo "ERROR: --auto-allow and --dangerously-skip-permissions are mutually exclusive." >&2
  echo "" >&2
  echo "  --auto-allow:                   Autonomous Bash within sandbox bounds (recommended)" >&2
  echo "  --dangerously-skip-permissions: Full autonomy, no sandbox enforcement on prompts" >&2
  exit 1
fi

if [[ "${AUTO_ALLOW}" == "true" && "${FIREWALL_MODE}" == "open" ]]; then
  echo "WARNING: --auto-allow + open mode has reduced protection"
  echo ""
  echo "  Open mode disables the iptables firewall. The sandbox network proxy"
  echo "  will have an empty allowedDomains list (unrestricted). Only container"
  echo "  isolation and deny rules remain."
  echo ""
  read -r -p "Continue? [y/N] " CONFIRM
  if [[ ! "${CONFIRM}" =~ ^[Yy] ]]; then
    echo "Aborted."
    exit 1
  fi
fi

# Warn about dangerous combinations
if [[ "${SKIP_PERMISSIONS}" == "true" && "${FIREWALL_MODE}" == "open" ]]; then
  echo "WARNING: --dangerously-skip-permissions + open mode = MINIMAL SECURITY"
  echo ""
  echo "  This combination disables:"
  echo "    - Network firewall (open mode = no outbound restrictions)"
  echo "    - Permission prompts (skip-permissions = all tools allowed)"
  echo ""
  echo "  Only the container and VM boundaries remain. The agent can:"
  echo "    - Send data to any internet destination"
  echo "    - Execute any command without prompts"
  echo "    - Access all environment variables including secrets"
  echo ""
  echo "  Use this ONLY for trusted, disposable workloads with minimal credentials."
  echo ""
  read -r -p "Type 'I understand the risks' to proceed: " CONFIRM
  if [[ "${CONFIRM}" != "I understand the risks" ]]; then
    echo "Aborted."
    exit 1
  fi
fi

# ============================================================================
# Bootstrap: download vibeshield scaffolding from GitHub
# ============================================================================
bootstrap() {
  echo "Initializing vibeshield..."

  # Download repo tarball to temp directory
  local tmp
  tmp=$(mktemp -d)
  trap "rm -rf '${tmp}'" EXIT

  echo "Downloading scaffolding from GitHub..."
  local downloaded=false

  # Try unauthenticated download first (works for public repos)
  if curl -fsSL "${VIBESHIELD_REPO}/archive/refs/heads/main.tar.gz" \
       | tar xz -C "${tmp}" --strip-components=1 2>/dev/null; then
    downloaded=true
  fi

  # Fall back to gh CLI for private repos (uses stored GitHub auth)
  if [[ "${downloaded}" != true ]]; then
    if command -v gh &>/dev/null; then
      echo "  Public download failed, trying gh CLI (private repo?)..."
      if gh api repos/swannysec/vibeshield/tarball/main \
           | tar xz -C "${tmp}" --strip-components=1 2>/dev/null; then
        downloaded=true
      fi
    fi
  fi

  if [[ "${downloaded}" != true ]]; then
    echo "ERROR: Failed to download vibeshield scaffolding from GitHub." >&2
    echo "  For public repos: check your internet connection." >&2
    echo "  For private repos: install gh CLI and run 'gh auth login' first." >&2
    exit 1
  fi

  local src="${tmp}"

  # --- Copy scaffolding ---
  RSYNC_EXCLUDES=(
    --exclude '__pycache__'
    --exclude '*.pyc'
    --exclude '.DS_Store'
  )

  copy_dir() {
    local rel="$1"
    local s="${src}/${rel}"
    local d="${WORKSPACE_FOLDER}/${rel}"
    [[ -d "${s}" ]] || return 0
    mkdir -p "${d}"
    if command -v rsync &>/dev/null; then
      rsync -a "${RSYNC_EXCLUDES[@]}" "${s}/" "${d}/"
    else
      cp -R "${s}/." "${d}/"
      find "${d}" -name '__pycache__' -type d -exec rm -rf {} + 2>/dev/null || true
      find "${d}" -name '*.pyc' -delete 2>/dev/null || true
      find "${d}" -name '.DS_Store' -delete 2>/dev/null || true
    fi
  }

  copy_file() {
    local rel="$1"
    local s="${src}/${rel}"
    local d="${WORKSPACE_FOLDER}/${rel}"
    [[ -f "${s}" ]] || return 0
    mkdir -p "$(dirname "${d}")"
    cp "${s}" "${d}"
  }

  copy_dir  ".devcontainer"
  copy_dir  ".claude/skills"
  # Container template used as merge source below, not copied to target projects.
  copy_file ".env.vibeshield.example"
  copy_dir  "tests"
  # Only copy docs that target projects need. vibeshield's own documentation
  # (threat-model, recipes, research, reviews) is NOT copied — it confuses
  # agents into thinking it's part of the target project's context.
  copy_dir  "docs/optional"

  # --- Append .gitignore entries ---
  local gitignore="${WORKSPACE_FOLDER}/.gitignore"
  local entries=(
    "# vibeshield"
    ".env"
    ".env.*"
    "!.env.vibeshield.example"
    ".vibeshield-launch.log"
    ".vibeshield-state/"
  )

  touch "${gitignore}"
  local needs_newline=false
  if [[ -s "${gitignore}" ]] && [[ "$(tail -c 1 "${gitignore}" | wc -l)" -eq 0 ]]; then
    needs_newline=true
  fi

  local added=false
  for entry in "${entries[@]}"; do
    if ! grep -Fxq "${entry}" "${gitignore}"; then
      if [[ "${needs_newline}" == true ]]; then
        echo "" >> "${gitignore}"
        needs_newline=false
      fi
      echo "${entry}" >> "${gitignore}"
      added=true
    fi
  done
  if [[ "${added}" == true ]]; then
    echo "  Updated .gitignore"
  fi

  # --- Append vibeshield context to CLAUDE.md (preserves existing content) ---
  local claudemd="${WORKSPACE_FOLDER}/.claude/CLAUDE.md"
  mkdir -p "$(dirname "${claudemd}")"

  local section='<!-- vibeshield:start -->
## Vibeshield Sandbox

This project runs in a hardened devcontainer with network and filesystem restrictions.

- If a network request fails due to a blocked domain, suggest the user add it to `.devcontainer/network/config.local.yaml`. Do not attempt workarounds.
- Never read `.env`, `.env.vibeshield`, or any `.env.*` file. Reference variable names (e.g., `$ANTHROPIC_API_KEY`), not values.
<!-- vibeshield:end -->'

  if [[ -f "${claudemd}" ]]; then
    if grep -q '<!-- vibeshield:start -->' "${claudemd}"; then
      local t
      t=$(mktemp)
      sed '/<!-- vibeshield:start -->/,/<!-- vibeshield:end -->/d' "${claudemd}" > "${t}"
      mv "${t}" "${claudemd}"
    fi
    printf '\n%s\n' "${section}" >> "${claudemd}"
    echo "  Updated .claude/CLAUDE.md"
  else
    printf '%s\n' "${section}" > "${claudemd}"
    echo "  Created .claude/CLAUDE.md"
  fi

  # --- Merge or create settings.json ---
  # The container template (settings.container.json) is the source of truth for
  # security rules. It has sandbox.enabled=true and all container-specific deny
  # rules. The host settings.json is more permissive for development.
  local settings_src="${src}/.claude/settings.container.json"
  local settings_dst="${WORKSPACE_FOLDER}/.claude/settings.json"

  if [[ ! -f "${settings_src}" ]]; then
    echo "ERROR: Container settings template not found in downloaded scaffolding." >&2
    echo "  Expected: .claude/settings.container.json" >&2
    echo "  This may indicate a corrupted or outdated vibeshield release." >&2
    exit 1
  fi

  # settings.container.json exists (guard above ensures this).
  # Copy or merge it into the target project's settings.json.
  mkdir -p "$(dirname "${settings_dst}")"
  if [[ ! -f "${settings_dst}" ]]; then
      cp "${settings_src}" "${settings_dst}"
      echo "  Created .claude/settings.json"
    elif command -v python3 &>/dev/null; then
      python3 - "${settings_dst}" "${settings_src}" << 'PYEOF'
import json, sys

dst_path, src_path = sys.argv[1], sys.argv[2]

with open(dst_path) as f:
    existing = json.load(f)
with open(src_path) as f:
    vs = json.load(f)

perms = existing.setdefault("permissions", {})

# Collect all existing rules to avoid duplicates across lists
all_existing = set()
for key in ("allow", "deny", "ask"):
    all_existing.update(perms.get(key, []))

# Add vibeshield rules not already present in any list
for key in ("allow", "deny", "ask"):
    existing_list = perms.setdefault(key, [])
    for rule in vs.get("permissions", {}).get(key, []):
        if rule not in all_existing:
            existing_list.append(rule)

# Deny rules must win: if a vibeshield deny rule exists in user's allow or
# ask list, remove it from those lists. This prevents pre-seeded allow rules
# from suppressing security deny rules during bootstrap.
vs_deny = set(vs.get("permissions", {}).get("deny", []))
for key in ("allow", "ask"):
    perms[key] = [r for r in perms.get(key, []) if r not in vs_deny]

# Sandbox and managed metadata are vibeshield requirements
existing["sandbox"] = vs.get("sandbox", existing.get("sandbox", {}))
existing["vibeshield_managed"] = vs.get("vibeshield_managed", {})

with open(dst_path, "w") as f:
    json.dump(existing, f, indent=2)
    f.write("\n")
PYEOF
      echo "  Merged security rules into existing .claude/settings.json"
    else
      echo "  WARNING: python3 not found — cannot merge settings.json" >&2
      echo "  Run /vibeshield-init inside the container to merge security rules." >&2
    fi

  # Clean up trap
  rm -rf "${tmp}"
  trap - EXIT

  echo ""
  echo "vibeshield initialized."
  echo ""
  echo "Next steps:"
  echo "  1. cp .env.vibeshield.example .env.vibeshield"
  echo "  2. Edit .env.vibeshield with your API keys"
  echo "  3. ./vibeshield"
  echo ""
  echo "Options:"
  echo "  ./vibeshield --mode lockdown    # Strict: Claude API + GitHub only"
  echo "  ./vibeshield --status           # Check container & firewall state"
  echo "  ./vibeshield --help             # All options"
}

# ============================================================================
# Auto-bootstrap: if no .devcontainer, set up first
# ============================================================================
if [[ "${ACTION}" == "init" ]]; then
  if [[ -d "${WORKSPACE_FOLDER}/.devcontainer" && "${FORCE_INIT}" != "true" ]]; then
    echo "WARNING: .devcontainer/ already exists in this directory." >&2
    echo "  Re-running init will overwrite your devcontainer configuration" >&2
    echo "  with the latest from GitHub (main branch), reverting any local changes." >&2
    echo "" >&2
    echo "  To proceed anyway: ./vibeshield init --force" >&2
    exit 1
  fi
  bootstrap
  exit 0
fi

if [[ ! -d "${WORKSPACE_FOLDER}/.devcontainer" ]]; then
  if [[ "${ACTION}" == "status" ]]; then
    echo "vibeshield is not initialized in this directory."
    echo "Run: ./vibeshield init"
    exit 1
  fi
  echo "No .devcontainer found — running first-time setup."
  echo ""
  bootstrap
  exit 0
fi

# ============================================================================
# Launch: everything below requires an initialized project
# ============================================================================

# --- Helper: find running container ---
find_container() {
  docker ps -q --filter "label=devcontainer.local_folder=${WORKSPACE_FOLDER}" 2>/dev/null || true
}

# --- Status action ---
if [[ "${ACTION}" == "status" ]]; then
  CONTAINER_ID=$(find_container)
  if [[ -z "${CONTAINER_ID}" ]]; then
    echo "Container:  not running"
    exit 0
  fi
  echo "Container:  running (${CONTAINER_ID:0:12})"

  # Firewall mode
  FW_MODE=$(docker exec "${CONTAINER_ID}" cat /opt/vibeshield/state/current-mode 2>/dev/null || echo "unknown")
  echo "Mode:       ${FW_MODE}"

  # Rule count
  RULE_COUNT=$(docker exec "${CONTAINER_ID}" sudo iptables -L OUTPUT -n 2>/dev/null | wc -l || echo "0")
  echo "FW rules:   ${RULE_COUNT}"

  # tmux session
  if docker exec -u vscode "${CONTAINER_ID}" tmux has-session -t claude 2>/dev/null; then
    echo "Session:    claude (active)"
  else
    echo "Session:    none"
  fi

  # Connectivity
  HTTP_CODE=$(docker exec "${CONTAINER_ID}" curl -s --max-time 3 -o /dev/null -w "%{http_code}" https://api.anthropic.com 2>/dev/null || echo "000")
  if [[ "${HTTP_CODE}" != "000" ]]; then
    echo "API:        reachable (HTTP ${HTTP_CODE})"
  else
    echo "API:        unreachable"
  fi

  # Proxy status (daemon runs inside container)
  if docker exec "${CONTAINER_ID}" pgrep -x claw-wrap &>/dev/null; then
    local _proxy_user
    _proxy_user=$(docker exec "${CONTAINER_ID}" ps -o user= -p "$(docker exec "${CONTAINER_ID}" pgrep -x claw-wrap | head -1)" 2>/dev/null || echo "unknown")
    echo "Proxy:      claw-wrap running (in-container, user: ${_proxy_user})"
    # Check CLI socket
    docker exec "${CONTAINER_ID}" test -S /run/openclaw/secrets.sock 2>/dev/null \
      && echo "  CLI:      secrets.sock OK" || echo "  CLI:      secrets.sock MISSING"
    # Check HTTP proxy
    docker exec "${CONTAINER_ID}" curl -s --max-time 1 http://127.0.0.1:18080 &>/dev/null \
      && echo "  HTTP:     127.0.0.1:18080 OK" || echo "  HTTP:     127.0.0.1:18080 unreachable"
  else
    echo "Proxy:      not running (env-direct mode or daemon stopped)"
  fi

  exit 0
fi

# --- First-run setup: create .env.vibeshield from example ---
ENV_VIBESHIELD="${WORKSPACE_FOLDER}/.env.vibeshield"
ENV_EXAMPLE="${WORKSPACE_FOLDER}/.env.vibeshield.example"

if [[ ! -f "${ENV_VIBESHIELD}" && -f "${ENV_EXAMPLE}" ]]; then
  echo ""
  echo "No .env.vibeshield found. This file configures secrets for the container."
  echo ""
  read -r -p "Create from example template? [Y/n] " CREATE_ENV
  CREATE_ENV="${CREATE_ENV:-Y}"
  if [[ "${CREATE_ENV}" =~ ^[Yy] ]]; then
    cp "${ENV_EXAMPLE}" "${ENV_VIBESHIELD}"
    echo "Created .env.vibeshield — edit it with your op:// references or API keys."
    echo ""
    # Check if they have an editor preference
    EDITOR_CMD="${EDITOR:-${VISUAL:-}}"
    if [[ -n "${EDITOR_CMD}" ]]; then
      read -r -p "Open in ${EDITOR_CMD} now? [Y/n] " OPEN_EDITOR
      OPEN_EDITOR="${OPEN_EDITOR:-Y}"
      if [[ "${OPEN_EDITOR}" =~ ^[Yy] ]]; then
        "${EDITOR_CMD}" "${ENV_VIBESHIELD}"
      fi
    else
      echo "Edit .env.vibeshield before continuing, then re-run ./vibeshield"
      exit 0
    fi
  fi
fi

# --- claw-wrap secrets proxy constants ---
CLAW_WRAP_VERSION="0.4.1"
CLAW_WRAP_CHECKSUMS="${WORKSPACE_FOLDER}/.devcontainer/claw-wrap-checksums.sha256"
PROXY_DUMMY_KEY="sk-ant-api03-proxy-managed-credential-do-not-use-directly-AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"

# --- Secrets mode detection ---
# Determines which secrets management mode to use. claw-wrap runs INSIDE the
# container (ADR-012), so there is no host binary requirement. Proxy mode is
# activated when credentials are available to resolve on the host; the
# container-side setup (claw_wrap_container_setup) handles the daemon.
detect_secrets_mode() {
  # Determine which secrets management mode to use:
  #   op-proxy  — 1Password + claw-wrap (encouraged)
  #   env-proxy — env vars + claw-wrap
  #   env-direct — current behavior, no proxy (default fallback)
  SECRETS_MODE="env-direct"

  if [[ -f "${ENV_VIBESHIELD}" ]]; then
    if grep -q 'op://' "${ENV_VIBESHIELD}" 2>/dev/null; then
      SECRETS_MODE="op-proxy"
    else
      SECRETS_MODE="env-proxy"
    fi
  elif [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
    # Require at least ANTHROPIC_API_KEY for proxy mode — it's the critical credential.
    # GITHUB_TOKEN alone is insufficient (API calls would fail with dummy key).
    SECRETS_MODE="env-proxy"
  fi

  export SECRETS_MODE
}

# --- Host-side credential resolution (Mitigation B) ---
# Resolves all credentials on the HOST so the OP token never enters the container.
# For op:// refs: calls `op read` using OP_SERVICE_ACCOUNT_TOKEN on host.
# For plain values: exports directly as VS_CRED_KEY.
# Fallback (no .env.vibeshield): exports host env vars as VS_CRED_*.
# Returns 1 on failure (caller should fall back to env-direct mode).
claw_wrap_resolve_credentials() {
  # Determine 1Password token (standard or vibeshield-prefixed)
  local _op_token="${OP_SERVICE_ACCOUNT_TOKEN:-${OP_VIBESHIELD_SERVICE_ACCOUNT_TOKEN:-}}"
  local HAS_OP=false
  if command -v op &>/dev/null; then
    HAS_OP=true
  fi

  # 1Password auth strategy:
  #   1. Service account token (headless/CI — OP_SERVICE_ACCOUNT_TOKEN set)
  #   2. Interactive session (biometric/Touch ID — default on macOS)
  # Service account token takes precedence when set. Otherwise, op CLI
  # uses the user's existing session or prompts for biometric auth.
  local OP_ENV=()
  if [[ "${HAS_OP}" == true && -n "${_op_token}" ]]; then
    OP_ENV=(env "OP_SERVICE_ACCOUNT_TOKEN=${_op_token}")
    echo "  1Password: using service account token"
  elif [[ "${HAS_OP}" == true ]]; then
    echo "  1Password: using interactive session (Touch ID may prompt)"
  fi

  if [[ -f "${ENV_VIBESHIELD}" ]]; then
    echo "Resolving credentials on host..."
    while IFS='=' read -r key value; do
      [[ -z "${key}" || "${key}" =~ ^[[:space:]]*# ]] && continue
      # Trim whitespace without xargs (xargs corrupts backslashes/quotes in secrets — SEC-005)
      key="${key#"${key%%[![:space:]]*}"}" && key="${key%"${key##*[![:space:]]}"}"
      value="${value#"${value%%[![:space:]]*}"}" && value="${value%"${value##*[![:space:]]}"}"
      [[ -z "${key}" || -z "${value}" ]] && continue

      # Validate key format (uppercase letters, digits, underscores only)
      if [[ ! "${key}" =~ ^[A-Z][A-Z0-9_]*$ ]]; then
        echo "  WARNING: Invalid key in .env.vibeshield: '${key}' — skipping"
        continue
      fi

      if [[ "${value}" == op://* ]]; then
        if [[ "${HAS_OP}" != true ]]; then
          echo "  WARNING: ${key} uses op:// but 1Password CLI is not installed — skipping"
          continue
        fi
        local resolved
        # stderr is NOT suppressed — allows biometric/Touch ID prompt on macOS.
        # Service account token (if set) is passed via OP_ENV prefix.
        resolved=$(${OP_ENV[@]+"${OP_ENV[@]}"} op read "${value}") || {
          echo "  WARNING: Failed to resolve ${key} (${value})"
          continue
        }
        export "VS_CRED_${key}=${resolved}"
        echo "  Resolved ${key} via 1Password"
      else
        export "VS_CRED_${key}=${value}"
        echo "  Loaded ${key}"
      fi
    done < "${ENV_VIBESHIELD}"
  else
    # No .env.vibeshield — use host env vars if available
    if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
      export VS_CRED_ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY}"
      echo "  Exported ANTHROPIC_API_KEY from host env"
    fi
    if [[ -n "${GITHUB_TOKEN:-}" ]]; then
      export VS_CRED_GITHUB_TOKEN="${GITHUB_TOKEN}"
      echo "  Exported GITHUB_TOKEN from host env"
    fi
    if [[ -n "${OPENROUTER_API_KEY:-}" ]]; then
      export VS_CRED_OPENROUTER_API_KEY="${OPENROUTER_API_KEY}"
      echo "  Exported OPENROUTER_API_KEY from host env"
    fi
    if [[ -n "${CODEX_API_KEY:-}" ]]; then
      export VS_CRED_CODEX_API_KEY="${CODEX_API_KEY}"
      echo "  Exported CODEX_API_KEY from host env"
    fi
  fi

  # Verify at least ANTHROPIC_API_KEY was resolved
  if [[ -z "${VS_CRED_ANTHROPIC_API_KEY:-}" ]]; then
    echo "  ERROR: No ANTHROPIC_API_KEY resolved for proxy mode"
    return 1
  fi
}

# --- claw-wrap config generation (in-container) ---
# Generate claw-wrap YAML config inside the running container via docker exec.
# All credentials are already resolved as VS_CRED_* env vars by
# claw_wrap_resolve_credentials() — no op:// resolution happens here.
# Writes config to /run/openclaw/config.yaml (container-side paths).
claw_wrap_config_generate_in_container() {
  local config_dir="/run/openclaw"

  # Build credential entries from VS_CRED_* env vars
  local cred_yaml=""
  for varname in $(compgen -v VS_CRED_); do
    local key="${varname#VS_CRED_}"
    local cred_name
    case "${key}" in
      ANTHROPIC_API_KEY)  cred_name="anthropic-key" ;;
      GITHUB_TOKEN)       cred_name="github-token" ;;
      OPENROUTER_API_KEY) cred_name="openrouter-key" ;;
      *)                  cred_name=$(echo "${key}" | tr '[:upper:]' '[:lower:]' | tr '_' '-') ;;
    esac
    cred_yaml+="  ${cred_name}:"$'\n'
    cred_yaml+="    source: 'env:${varname}'"$'\n'
  done

  # Write config via docker exec heredoc (chowned to DAEMON_USER in step 6)
  docker exec -u root "${CONTAINER_ID}" bash -c "umask 0077 && cat > ${config_dir}/config.yaml << 'YAML_HEAD'
proxy:
  hmac_secret_file: ${config_dir}/auth
  timeout: 300s
  replay_cache_ttl: 30s
  credential_cache_ttl: 1m

credentials:
${cred_yaml}YAML_HEAD
chmod 0600 ${config_dir}/config.yaml"

  # Append tool configurations (static template from spec).
  # blocked_args: block irreversible/destructive operations and credential
  # access only. Read-only operations are allowed — see spec recommendations
  # #9, #10, #12 in docs/secrets-proxy-research.md.
  docker exec -u root "${CONTAINER_ID}" bash -c 'cat >> /run/openclaw/config.yaml << '"'"'YAML_TOOLS'"'"'

tools:
  gh:
    binary: /usr/bin/gh
    env:
      GH_TOKEN: github-token
    blocked_args:
      - pattern: "repo\\s+delete"
        match: command
        message: "Repository deletion is blocked"
      - pattern: "gist"

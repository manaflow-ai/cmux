            for name in extra:
                if not isinstance(name, str) or len(name) > 256 or not env_re.match(name):
                    print(f'  WARNING: Invalid env var name in config.local.yaml: {name!r}', file=sys.stderr)
                elif name in NEVER_ALLOW_ENV:
                    print(f'  WARNING: Blocked dangerous env var in config.local.yaml: {name}', file=sys.stderr)
                else:
                    ALLOWED_ENV.add(name)
                    added.append(name)
            if added:
                print('  Custom env vars from config.local.yaml: ' + ', '.join(sorted(added)))
    except FileNotFoundError:
        pass
    except ImportError:
        pass  # PyYAML not available
    except Exception as e:
        print(f'  WARNING: Could not read config.local.yaml for env vars: {e}', file=sys.stderr)

if 'env' in host and isinstance(host['env'], dict):
    merged_env = container.get('env', {})
    skipped = []
    for k, v in host['env'].items():
        if k in ALLOWED_ENV and isinstance(v, str):
            merged_env[k] = v
        else:
            skipped.append(k)
    if skipped:
        print('  Skipped non-allowlisted env vars: ' + ', '.join(sorted(skipped)), file=sys.stderr)
    container['env'] = merged_env

# Skip: permissions (container has its own), statusLine (host-specific path),
# attribution (container setting), sandbox (managed by vibeshield)

with open(spath, 'w') as f:
    json.dump(container, f, indent=2)
    f.write('\n')

merged = []
if 'enabledPlugins' in container:
    merged.append(f\"{len(container.get('enabledPlugins', []))} enabledPlugins\")
if 'model' in host and isinstance(host['model'], str):
    merged.append('model')
if 'env' in host and isinstance(host['env'], dict):
    merged.append(f\"{len(container.get('env', {}))} env vars\")
if merged:
    print(f\"  Merged from host settings: {', '.join(merged)}\")
else:
    print('  No mergeable settings found in host settings.json')
" || echo "  WARNING: Settings merge failed (python3 error)"
fi

# Also copy project-level skills (e.g., vibeshield-init) into the container's
# user-level skills directory. Project skills are merged after host skills so
# they take precedence on name collision. Same root-owned read-only treatment.
PROJECT_SKILLS="${WORKSPACE_FOLDER}/.claude/skills"
if [[ -d "${PROJECT_SKILLS}" ]]; then
  CONTAINER_SKILLS="${CONTAINER_CLAUDE_DIR}/skills"
  docker exec "${CONTAINER_ID}" mkdir -p "${CONTAINER_SKILLS}"
  # Temporarily unlock if host copy already locked it
  docker exec "${CONTAINER_ID}" chmod u+w "${CONTAINER_SKILLS}" 2>/dev/null || true
  tar -chf - --no-xattrs -C "${PROJECT_SKILLS}" . 2>/dev/null | docker exec -i "${CONTAINER_ID}" tar -xf - -C "${CONTAINER_SKILLS}" 2>/dev/null
  docker exec "${CONTAINER_ID}" chown -R root:root "${CONTAINER_SKILLS}"
  docker exec "${CONTAINER_ID}" chmod -R a+rX,a-w "${CONTAINER_SKILLS}"
  proj_count=$(find -L "${PROJECT_SKILLS}" -type f 2>/dev/null | wc -l | tr -d ' ')
  COPIED_ITEMS+=("project skills (${proj_count} files)")
fi

# Conditionally deploy ralphex-init skill if ralphex is available.
# Check host PATH first, then container (user may not have ralphex on host),
# then fall back to action flag. The skill lives in docs/optional/ (not
# .claude/skills/) so it doesn't auto-deploy for users who haven't installed ralphex.
RALPHEX_SKILL_SRC="${WORKSPACE_FOLDER}/docs/optional/ralphex-init"
if [[ -d "${RALPHEX_SKILL_SRC}" ]] && { command -v ralphex &>/dev/null || \
     docker exec "${CONTAINER_ID}" command -v ralphex &>/dev/null || \
     [[ "${ACTION}" == "ralphex" ]]; }; then
  CONTAINER_SKILLS="${CONTAINER_CLAUDE_DIR}/skills"
  docker exec "${CONTAINER_ID}" mkdir -p "${CONTAINER_SKILLS}/ralphex-init"
  docker exec "${CONTAINER_ID}" chmod u+w "${CONTAINER_SKILLS}" "${CONTAINER_SKILLS}/ralphex-init" 2>/dev/null || true
  tar -chf - --no-xattrs -C "${RALPHEX_SKILL_SRC}" . 2>/dev/null | \
    docker exec -i "${CONTAINER_ID}" tar -xf - -C "${CONTAINER_SKILLS}/ralphex-init" 2>/dev/null
  docker exec "${CONTAINER_ID}" chown -R root:root "${CONTAINER_SKILLS}/ralphex-init"
  docker exec "${CONTAINER_ID}" chmod -R a+rX,a-w "${CONTAINER_SKILLS}/ralphex-init"
  COPIED_ITEMS+=("ralphex-init skill")
fi

# Copy global CLAUDE.md if it exists (read-only, won't override project CLAUDE.md).
# Use tar to strip macOS extended attributes that docker cp can mangle on volumes.
if [[ -f "${HOST_CLAUDE_DIR}/CLAUDE.md" ]]; then
  tar -cf - --no-xattrs -C "${HOST_CLAUDE_DIR}" CLAUDE.md 2>/dev/null | \
    docker exec -i "${CONTAINER_ID}" tar -xf - -C "${CONTAINER_CLAUDE_DIR}" 2>/dev/null
  docker exec "${CONTAINER_ID}" chown root:root "${CONTAINER_CLAUDE_DIR}/CLAUDE.md"
  docker exec "${CONTAINER_ID}" chmod 444 "${CONTAINER_CLAUDE_DIR}/CLAUDE.md"
  COPIED_ITEMS+=("CLAUDE.md")
fi

if [[ ${#COPIED_ITEMS[@]} -gt 0 ]]; then
  echo "  Copied: ${COPIED_ITEMS[*]}"
else
  echo "  No host config found to copy"
fi

# Log what was copied for audit
{
  echo "=== Config sync $(date) ==="
  for item in "${COPIED_ITEMS[@]+${COPIED_ITEMS[@]}}"; do
    echo "  ${item}"
  done
} >> "${LAUNCH_LOG}"

# --- claw-wrap container setup (proxy mode only) ---
if [[ "${SECRETS_MODE}" != "env-direct" ]]; then
  if ! claw_wrap_container_setup; then
    echo "  WARNING: Container proxy setup failed — falling back to env-direct mode"
    SECRETS_MODE="env-direct"
    # Clean up credential file from failed proxy setup (CA-007)
    docker exec -u root "${CONTAINER_ID}" rm -f /run/openclaw/env 2>/dev/null || true
    # Re-resolve secrets for env-direct fallback
    ENV_FLAGS=()
    if [[ -n "${VS_CRED_ANTHROPIC_API_KEY:-}" ]]; then
      ENV_FLAGS+=(-e "ANTHROPIC_API_KEY=${VS_CRED_ANTHROPIC_API_KEY}")
    fi
    if [[ -n "${VS_CRED_GITHUB_TOKEN:-}" ]]; then
      ENV_FLAGS+=(-e "GITHUB_TOKEN=${VS_CRED_GITHUB_TOKEN}")
    fi
    if [[ -n "${VS_CRED_OPENROUTER_API_KEY:-}" ]]; then
      ENV_FLAGS+=(-e "OPENROUTER_API_KEY=${VS_CRED_OPENROUTER_API_KEY}")
    fi
    if [[ -n "${VS_CRED_CODEX_API_KEY:-}" ]]; then
      ENV_FLAGS+=(-e "CODEX_API_KEY=${VS_CRED_CODEX_API_KEY}")
    fi
  fi
  # Update HTTPS_PROXY with proxy auth token (generated by daemon at startup).
  # ENV_FLAGS array has alternating -e KEY=VALUE elements. Replace the value in place.
  # CA-005: Warn if proxy is active but auth token is missing (daemon requires Basic auth).
  if [[ -z "${PROXY_AUTH_TOKEN:-}" && "${SECRETS_MODE}" != "env-direct" ]]; then
    echo "WARNING: Proxy mode active but auth token missing — daemon will reject unauthenticated requests"
  fi
  if [[ -n "${PROXY_AUTH_TOKEN:-}" && "${SECRETS_MODE}" != "env-direct" ]]; then
    for i in "${!ENV_FLAGS[@]}"; do
      if [[ "${ENV_FLAGS[$i]}" == "HTTPS_PROXY="* ]]; then
        ENV_FLAGS[$i]="HTTPS_PROXY=http://claw:${PROXY_AUTH_TOKEN}@127.0.0.1:18080"
        break
      fi
    done
    unset PROXY_AUTH_TOKEN
  fi

  # Clean up VS_CRED_* vars now that they've been passed to daemon (CA-009/SEC-007)
  for varname in $(compgen -v VS_CRED_); do
    unset "${varname}"
  done
  unset OP_SERVICE_ACCOUNT_TOKEN OP_VIBESHIELD_SERVICE_ACCOUNT_TOKEN 2>/dev/null || true
fi

# --- Apply firewall mode ---
if [[ -n "${FIREWALL_MODE}" ]]; then
  echo "Applying firewall mode: ${FIREWALL_MODE}"
  # Write state file so apply-firewall.sh uses it on next container start
  docker exec "${CONTAINER_ID}" bash -c "echo '${FIREWALL_MODE}' > /opt/vibeshield/state/current-mode"
  # Apply immediately if reload-firewall is available
  docker exec "${CONTAINER_ID}" bash -c \
    "if command -v reload-firewall &>/dev/null; then
       sudo reload-firewall --mode ${FIREWALL_MODE} ${FIREWALL_MODE:+$([ "${FIREWALL_MODE}" = "open" ] && echo "--confirm" || true)}
     fi" 2>&1 | while IFS= read -r line; do echo "  ${line}"; done
fi

# --- Sync sandbox allowedDomains from firewall config ---
# Ensures the sandbox network proxy has the domain list before Claude starts.
# sync-permissions.py populates allowedDomains from the firewall mode config.
# Read actual container mode if user didn't specify one
if [[ -n "${FIREWALL_MODE}" ]]; then
  SYNC_MODE="${FIREWALL_MODE}"
else
  SYNC_MODE=$(docker exec "${CONTAINER_ID}" cat /opt/vibeshield/state/current-mode 2>/dev/null || echo "standard")
fi
echo "Syncing sandbox domains for mode: ${SYNC_MODE}"
docker exec "${CONTAINER_ID}" sudo python3 -I /opt/vibeshield/sync-permissions.py --mode "${SYNC_MODE}" 2>&1 \
  | while IFS= read -r line; do echo "  ${line}"; done

# --- Configure auto-allow mode ---
# Always reset autoAllowBashIfSandboxed in workspace settings to prevent
# stale state from persisting across sessions via the .claude volume.
# sync-permissions.py writes autoAllowBashIfSandboxed: false by default;
# we override to true only when --auto-allow is explicitly passed.
if [[ "${AUTO_ALLOW}" == "true" ]]; then
  echo "Enabling sandbox auto-allow mode..."
  docker exec "${CONTAINER_ID}" sudo python3 -I -c "
import json, sys, shutil, os
# Prefer settings.container.json (vibeshield source repo) over settings.json (target projects)
container_cfg = '${WORKSPACE_INNER}/.claude/settings.container.json'
fallback_cfg = '${WORKSPACE_INNER}/.claude/settings.json'
ws_path = container_cfg if os.path.exists(container_cfg) else fallback_cfg
auth_path = '/opt/vibeshield/state/' + os.path.basename(ws_path)
with open(ws_path) as f:
    s = json.load(f)
s.setdefault('sandbox', {})['autoAllowBashIfSandboxed'] = True
content = json.dumps(s, indent=2) + '\n'
# Write workspace copy
with open(ws_path, 'w') as f:
    f.write(content)
# Update authoritative copy so SEC-4 hash matches
with open(auth_path, 'w') as f:
    f.write(content)
print('  Sandbox auto-allow: enabled (workspace + authoritative copy)')
"
fi

# --- ralphex launch (non-interactive, no tmux) ---
# Dashboard: ralphex serves a web dashboard on port 8080 inside the container.
# appPort was removed to avoid conflicts when multiple containers run.
# To access the dashboard: docker port "${CONTAINER_ID}" 8080, or manually:
#   docker exec -d "${CONTAINER_ID}" socat TCP-LISTEN:8080,fork,reuseaddr TCP:127.0.0.1:8080
# Or from the host: docker exec -it "${CONTAINER_ID}" curl http://127.0.0.1:8080
if [[ "${ACTION}" == "ralphex" ]]; then
  if [[ "${SKIP_PERMISSIONS}" == "true" || "${AUTO_ALLOW}" == "true" ]]; then
    echo "NOTE: --dangerously-skip-permissions and --auto-allow are ignored in ralphex mode."
    echo "  ralphex manages its own Claude invocation flags (claude_args in ralphex config)."
  fi

  # --- Install claude wrapper for ralphex ---
  # ralphex strips ANTHROPIC_API_KEY from child env (hardcoded in executor.go).
  # This wrapper re-injects it from _VIBESHIELD_CLAUDE_KEY before exec'ing real claude.
  # The alternate var name survives ralphex's env filtering.
  REAL_CLAUDE_PATH=$(docker exec "${CONTAINER_ID}" bash -c 'command -v claude')
  WRAPPER_TMP=$(mktemp)
  cat > "${WRAPPER_TMP}" << WRAPPER
#!/bin/bash
# vibeshield claude wrapper — re-injects API key stripped by ralphex.
# ralphex filters ANTHROPIC_API_KEY from child env ("claude uses different auth").
# _VIBESHIELD_CLAUDE_KEY carries the same value through ralphex's filter.
if [ -n "\${_VIBESHIELD_CLAUDE_KEY}" ]; then
  export ANTHROPIC_API_KEY="\${_VIBESHIELD_CLAUDE_KEY}"
fi
exec ${REAL_CLAUDE_PATH} "\$@"
WRAPPER
  docker cp "${WRAPPER_TMP}" "${CONTAINER_ID}:/opt/vibeshield/bin/claude-for-ralphex"
  docker exec -u root "${CONTAINER_ID}" bash -c 'chown root:root /opt/vibeshield/bin/claude-for-ralphex && chmod 755 /opt/vibeshield/bin/claude-for-ralphex'
  rm -f "${WRAPPER_TMP}"

  # Configure ralphex to use the wrapper (global config, lowest precedence —
  # any local .ralphex/config claude_command takes priority).
  docker exec -u vscode "${CONTAINER_ID}" mkdir -p /home/vscode/.config/ralphex
  docker exec -u vscode "${CONTAINER_ID}" bash -c '
    cfg=/home/vscode/.config/ralphex/config
    if [ -f "$cfg" ] && grep -q "^claude_command" "$cfg" 2>/dev/null; then
      sed -i "s|^claude_command.*|claude_command = /opt/vibeshield/bin/claude-for-ralphex|" "$cfg"
    else
      # Append to existing config or create new one
      echo "" >> "$cfg"
      echo "# vibeshield: use wrapper that re-injects API key stripped by ralphex" >> "$cfg"
      echo "claude_command = /opt/vibeshield/bin/claude-for-ralphex" >> "$cfg"
    fi'

  # Reset .claude/settings.json to committed state before ralphex starts.
  # sync-permissions runs twice during launch (postStartCommand with forced
  # standard mode, then launcher with user's mode) which always dirties the
  # working tree. ralphex refuses to create branches with uncommitted changes.
  docker exec -u vscode "${CONTAINER_ID}" bash -c \
    'cd "'"${WORKSPACE_INNER}"'" && git checkout -- .claude/settings.json 2>/dev/null || true'

  echo "Launching ralphex in vibeshield container..."
  # ralphex runs claude as a subprocess with --output-format stream-json.
  # No tmux needed — ralphex handles its own process management.
  # Uses --dangerously-skip-permissions (ralphex default).
  docker exec -it -u vscode \
    -e TERM=xterm-256color \
    ${ENV_FLAGS[@]+"${ENV_FLAGS[@]}"} \
    -w "${WORKSPACE_INNER}" \
    "${CONTAINER_ID}" \
    ralphex ${RALPHEX_ARGS[@]+"${RALPHEX_ARGS[@]}"}
  exit $?
fi

# --- Launch ---
# Use tmux as a PTY insulation layer. Docker's PTY relay deadlocks when
# Node.js/Ink toggles raw mode between TUI component transitions.
# tmux creates its own PTY pair and never stops reading from Docker's PTY,
# preventing the deadlock. Secrets are passed via -e flags (memory only).
CLAUDE_CMD="cd ${WORKSPACE_INNER} && exec claude"
if [[ "${SKIP_PERMISSIONS}" == "true" ]]; then
  CLAUDE_CMD="cd ${WORKSPACE_INNER} && exec claude --dangerously-skip-permissions"
  echo "WARNING: Running with --dangerously-skip-permissions"
elif [[ "${AUTO_ALLOW}" == "true" ]]; then
  echo "Running with sandbox auto-allow (deny rules active, sandbox enforced)"
fi

echo "Launching Claude Code in vibeshield container..."
# Note: no 'exec' — EXIT trap must fire to restore .env.vibeshield
if docker exec -u vscode "${CONTAINER_ID}" tmux has-session -t claude 2>/dev/null; then
  # Reattach to existing session (preserves context after disconnect)
  docker exec -it -u vscode -e TERM=xterm-256color "${CONTAINER_ID}" \
    tmux -u -2 attach -t claude
else
  # Create detached tmux session with env vars, configure it, then attach
  docker exec -u vscode -e TERM=xterm-256color \
    ${ENV_FLAGS[@]+"${ENV_FLAGS[@]}"} \
    "${CONTAINER_ID}" \
    tmux -u -2 new-session -d -s claude
  # Hide status bar, set inner TERM for Ink compatibility, increase scrollback.
  # mouse=on: enable mouse wheel scrollback without entering copy mode manually.
  # Shift+Enter: requires Ghostty keybind (keybind = shift+enter=text:\x1b\r),
  # not a tmux config — see anthropics/claude-code#1282.
  docker exec -u vscode "${CONTAINER_ID}" \
    tmux set-option -t claude status off \; \
    set-option -t claude default-terminal xterm-256color \; \
    set-option -t claude history-limit 10000 \; \
    set-option -t claude mouse on
  # Launch claude inside the tmux session
  docker exec -u vscode "${CONTAINER_ID}" \
    tmux send-keys -t claude "${CLAUDE_CMD}" Enter
  # Attach interactively
  docker exec -it -u vscode -e TERM=xterm-256color "${CONTAINER_ID}" \
    tmux -u -2 attach -t claude
fi

    "mobile.tailscale.pairingHelp": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "QR-Kopplung erfordert normalerweise beide Geräte im selben Tailscale-Netzwerk. Tailscale zuerst einschalten oder über Host und Port in einem vertrauenswürdigen lokalen Netzwerk koppeln."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "QR pairing usually needs both devices on the same Tailscale network. Turn Tailscale on first, or pair by host and port on a trusted local network."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El emparejamiento por QR normalmente requiere que ambos dispositivos estén en la misma red Tailscale. Activa Tailscale primero, o empareja por host y puerto en una red local de confianza."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le jumelage QR nécessite généralement que les deux appareils soient sur le même réseau Tailscale. Activez d'abord Tailscale, ou jumelez par hôte et port sur un réseau local de confiance."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'abbinamento QR di solito richiede entrambi i dispositivi sulla stessa rete Tailscale. Attiva prima Tailscale, oppure abbina tramite host e porta su una rete locale attendibile."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "QR ペアリングには通常、両方のデバイスが同じ Tailscale ネットワークに接続されている必要があります。まず Tailscale をオンにするか、信頼できるローカルネットワーク上でホストとポートを指定してペアリングしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "QR 페어링은 보통 두 기기 모두 같은 Tailscale 네트워크에 있어야 합니다. 먼저 Tailscale을 켜거나, 신뢰할 수 있는 로컬 네트워크에서 호스트와 포트로 페어링하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "QR koppelen vereist meestal dat beide apparaten op hetzelfde Tailscale-netwerk zitten. Zet Tailscale eerst aan, of koppel via host en poort op een vertrouwd lokaal netwerk."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Parowanie przez kod QR zazwyczaj wymaga, aby oba urządzenia były w tej samej sieci Tailscale. Najpierw włącz Tailscale lub sparuj przez hosta i port w zaufanej sieci lokalnej."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O pareamento por QR geralmente requer que ambos os dispositivos estejam na mesma rede Tailscale. Ative o Tailscale primeiro, ou pareie pelo host e porta em uma rede local confiável."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сопряжение по QR-коду обычно требует, чтобы оба устройства были в одной сети Tailscale. Сначала включите Tailscale или выполните сопряжение по хосту и порту в надёжной локальной сети."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "QR ile eşleştirme genellikle her iki cihazın aynı Tailscale ağında olmasını gerektirir. Önce Tailscale'i açın veya güvenilir yerel ağda sunucu ve port ile eşleştirin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "二维码配对通常需要两台设备在同一 Tailscale 网络中。请先开启 Tailscale，或在受信任的本地网络中通过主机和端口手动配对。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "QR 配對通常需要兩台裝置在同一個 Tailscale 網路上。請先開啟 Tailscale，或在受信任的區域網路上透過主機和連接埠進行配對。"
          }
        }
      }
    },

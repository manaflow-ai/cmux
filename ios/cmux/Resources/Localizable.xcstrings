    "mobile.deviceTree.footer": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Geräte und ihre cmux-Builds stammen aus der Team-Registry. Build antippen zum Verbinden, dann Workspace zum Öffnen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Devices and their cmux builds come from your team's registry. Tap a build to connect, then a workspace to open it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los dispositivos y sus compilaciones de cmux provienen del registro de tu equipo. Toca una compilación para conectarte y luego un espacio de trabajo para abrirlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les appareils et leurs builds cmux proviennent du registre de votre équipe. Appuyez sur un build pour vous connecter, puis sur un espace de travail pour l'ouvrir."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I dispositivi e le build cmux vengono dal registro del tuo team. Tocca una build per connetterti, poi un workspace per aprirlo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイスとそのcmuxビルドはチームのレジストリから取得されます。ビルドをタップして接続し、ワークスペースをタップして開きます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기기와 cmux 빌드는 팀 레지스트리에서 가져옵니다. 빌드를 탭하여 연결하고, 워크스페이스를 탭하여 여세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Apparaten en hun cmux-builds komen uit het register van je team. Tik op een build om verbinding te maken, dan op een werkruimte om hem te openen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Urządzenia i ich buildy cmux pochodzą z rejestru Twojego zespołu. Dotknij build, aby się połączyć, a następnie przestrzeń roboczą, aby ją otworzyć."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Dispositivos e seus builds do cmux vêm do registro da sua equipe. Toque em um build para conectar, depois em um workspace para abri-lo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Устройства и их сборки cmux берутся из реестра команды. Нажмите на сборку для подключения, затем выберите рабочее пространство."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cihazlar ve cmux derlemeleri ekibinizin kayıt defterinden gelir. Bağlanmak için bir derlemeye, açmak için bir çalışma alanına dokunun."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设备及其 cmux 构建版本来自团队注册表。点击构建版本进行连接，再点击工作区将其打开。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "裝置及其 cmux 建置來自您的團隊登錄表。點選建置以連線，再點選工作區以開啟。"
          }
        }
      }
    },

            "state": "translated",
            "value": "Podaj hosta lub adres IP bez spacji i ścieżek URL."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Insira um host ou endereço IP, sem espaços ou caminhos URL."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Введите хост или IP-адрес без пробелов и путей URL."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",

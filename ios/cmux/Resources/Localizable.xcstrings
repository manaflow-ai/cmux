    "mobile.recovery.lostDescription": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erneut versuchen, um Live-Terminal-Updates wiederherzustellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Retry to restore live terminal updates."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reintentar para restaurar las actualizaciones del terminal en vivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réessayez pour rétablir les mises à jour du terminal en direct."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Riprova per ripristinare gli aggiornamenti live del terminale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ライブターミナルの更新を復元するには再試行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다시 시도하여 실시간 터미널 업데이트를 복원하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Opnieuw proberen om live terminalupdates te herstellen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spróbuj ponownie, aby przywrócić aktualizacje terminala na żywo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tente novamente para restaurar as atualizações ao vivo do terminal."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Повторите попытку, чтобы восстановить обновления терминала в реальном времени."

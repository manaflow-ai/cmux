    "mobile.pairing.hostUnreachableFormat": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d nicht erreichbar. Sicherstellen, dass der Mac aufgewacht und im selben Tailscale-Netzwerk wie dieses Gerät ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Can't reach %@:%d. Make sure your Mac is awake and on the same Tailscale network as this device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se puede alcanzar %@:%d. Asegúrate de que tu Mac está activo y en la misma red Tailscale que este dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible d'atteindre %@:%d. Assurez-vous que votre Mac est éveillé et sur le même réseau Tailscale que cet appareil."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile raggiungere %@:%d. Assicurati che il tuo Mac sia attivo e sulla stessa rete Tailscale di questo dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d に接続できません。Macがスリープしておらず、この端末と同じTailscaleネットワーク上にあることを確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d에 접근할 수 없습니다. Mac이 깨어 있고 이 기기와 같은 Tailscale 네트워크에 있는지 확인하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kan %@:%d niet bereiken. Zorg dat je Mac wakker is en op hetzelfde Tailscale-netwerk zit als dit apparaat."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie można dotrzeć do %@:%d. Upewnij się, że Twój Mac jest wybudzony i w tej samej sieci Tailscale co to urządzenie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não é possível alcançar %@:%d. Certifique-se de que seu Mac está ativo e na mesma rede Tailscale que este dispositivo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удаётся достичь %@:%d. Убедитесь, что Mac активен и находится в той же сети Tailscale, что и это устройство."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d adresine ulaşılamıyor. Mac'inizin uyanık ve bu cihazla aynı Tailscale ağında olduğundan emin olun."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法连接到 %@:%d，请确保 Mac 已唤醒且与此设备在同一 Tailscale 网络中。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法連線至 %@:%d。請確認您的 Mac 已喚醒並與此裝置連線至相同的 Tailscale 網路。"
          }
        }
      }
    },
    "mobile.pairing.invalidCode": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies ist kein cmux-Kopplungs-QR. Den Code aus dem Fenster „iPhone koppeln“ auf dem Mac scannen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This isn't a cmux pairing QR. Scan the code shown in the Pair iPhone window on your Mac."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este no es un QR de emparejamiento de cmux. Escanea el código que aparece en la ventana Emparejar iPhone en tu Mac."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce n'est pas un QR de jumelage cmux. Scannez le code affiché dans la fenêtre Jumeler l'iPhone sur votre Mac."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo non è un QR di abbinamento cmux. Scansiona il codice mostrato nella finestra Abbina iPhone sul tuo Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これはcmuxのペアリングQRコードではありません。Macの「iPhoneをペアリング」ウインドウに表示されているコードをスキャンしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이것은 cmux 페어링 QR이 아닙니다. Mac의 iPhone 페어링 창에 표시된 코드를 스캔하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit is geen cmux-koppel-QR. Scan de code die in het venster 'iPhone koppelen' op je Mac wordt getoond."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "To nie jest kod QR do parowania cmux. Zeskanuj kod wyświetlany w oknie parowania iPhone'a na Macu."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este não é um QR de pareamento do cmux. Escaneie o código mostrado na janela Parear iPhone no seu Mac."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это не QR-код сопряжения cmux. Отсканируйте код в окне «Сопряжение с iPhone» на вашем Mac."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu bir cmux eşleştirme QR'ı değil. Mac'inizdeki iPhone Eşleştir penceresinde gösterilen kodu tarayın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这不是 cmux 配对二维码，请扫描 Mac 上「配对 iPhone」窗口中显示的二维码。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這不是 cmux 配對 QR 碼。請掃描 Mac 上「配對 iPhone」視窗中顯示的 QR 碼。"
          }
        }
      }
    },
    "mobile.pairing.localNetworkPermission": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS hat die Verbindung blockiert. cmux in den iOS-Einstellungen erlauben, das lokale Netzwerk zu verwenden, dann erneut versuchen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS blocked the connection. Allow cmux to use the Local Network in iOS Settings, then try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS bloqueó la conexión. Permite que cmux use la Red local en Ajustes de iOS e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS a bloqué la connexion. Autorisez cmux à utiliser le réseau local dans les réglages iOS, puis réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS ha bloccato la connessione. Consenti a cmux di usare la rete locale nelle Impostazioni iOS, poi riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iOSが接続をブロックしました。iOSの設定でcmuxにローカルネットワークの使用を許可してから、もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS가 연결을 차단했습니다. iOS 설정에서 cmux의 로컬 네트워크 사용을 허용한 후 다시 시도하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS heeft de verbinding geblokkeerd. Geef cmux toegang tot het lokale netwerk in iOS-instellingen en probeer het opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS zablokował połączenie. Zezwól cmux na używanie sieci lokalnej w Ustawieniach iOS i spróbuj ponownie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O iOS bloqueou a conexão. Permita que o cmux use a Rede Local nos Ajustes do iOS e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS заблокировал соединение. Разрешите cmux использовать локальную сеть в настройках iOS, затем попробуйте снова."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS bağlantıyı engelledi. iOS Ayarları'nda cmux'un Yerel Ağ'ı kullanmasına izin verin, ardından tekrar deneyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS 已阻止连接。请在 iOS 设置中允许 cmux 使用本地网络后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS 封鎖了連線。請在 iOS 設定中允許 cmux 使用本機網路，然後再試。"
          }
        }
      }
    },
    "mobile.pairing.loopbackRejected": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Code verweist auf den Mac selbst (localhost), daher kann das iPhone ihn nicht verwenden. Tailscale auf dem Mac einrichten, dann einen neuen Code scannen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This code points at the Mac itself (localhost), so your iPhone can't use it. Set up Tailscale on the Mac, then scan a fresh code."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este código apunta al Mac mismo (localhost), por lo que tu iPhone no puede usarlo. Configura Tailscale en el Mac y luego escanea un código nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce code pointe vers le Mac lui-même (localhost), votre iPhone ne peut donc pas l'utiliser. Configurez Tailscale sur le Mac, puis scannez un nouveau code."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo codice punta al Mac stesso (localhost), quindi il tuo iPhone non può usarlo. Configura Tailscale sul Mac, poi scansiona un codice aggiornato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このコードは Mac 自身（localhost）を指しているため、iPhone からは使えません。Mac に Tailscale を設定してから、新しいコードをスキャンしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 코드는 Mac 자체(localhost)를 가리키므로 iPhone에서 사용할 수 없습니다. Mac에서 Tailscale을 설정한 후 새 코드를 스캔하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze code verwijst naar de Mac zelf (localhost), waardoor je iPhone hem niet kan gebruiken. Stel Tailscale in op de Mac en scan daarna een nieuwe code."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ten kod wskazuje na samego Maca (localhost), więc iPhone nie może go użyć. Skonfiguruj Tailscale na Macu, a następnie zeskanuj nowy kod."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este código aponta para o próprio Mac (localhost), então seu iPhone não pode usá-lo. Configure o Tailscale no Mac e escaneie um novo código."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот код указывает на сам Mac (localhost), поэтому iPhone не может его использовать. Настройте Tailscale на Mac, затем отсканируйте свежий код."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu kod Mac'in kendisine (localhost) işaret ediyor, bu yüzden iPhone'unuz onu kullanamaz. Mac'te Tailscale'i kurun, ardından yeni bir kod tarayın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此二维码指向 Mac 本机（localhost），iPhone 无法使用。请在 Mac 上设置 Tailscale，然后扫描新二维码。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此 QR 碼指向 Mac 本機（localhost），iPhone 無法使用。請在 Mac 上設定 Tailscale，然後重新掃描新的 QR 碼。"
          }
        }
      }
    },

    "mobile.addDevice.accountHelp": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Manuelles Koppeln verwendet dieses Konto. Falls es nicht mit dem Mac übereinstimmt, QR-Code/Link vom Mac scannen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Manual pairing uses this account. If it does not match the Mac, scan a QR/link from the Mac."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El emparejamiento manual usa esta cuenta. Si no coincide con el Mac, escanea un QR/enlace desde el Mac."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le jumelage manuel utilise ce compte. S'il ne correspond pas au Mac, scannez un QR/lien depuis le Mac."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'abbinamento manuale usa questo account. Se non corrisponde al Mac, scansiona un QR/link dal Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "手動ペアリングではこのアカウントを使用します。Mac と一致しない場合は、Mac から QR/リンクをスキャンしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "수동 페어링은 이 계정을 사용합니다. Mac과 일치하지 않으면 Mac에서 QR/링크를 스캔하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Handmatig koppelen gebruikt dit account. Als het niet overeenkomt met de Mac, scan dan een QR/link van de Mac."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Parowanie ręczne używa tego konta. Jeśli nie zgadza się z kontem na Macu, zeskanuj kod QR lub link z Maca."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O pareamento manual usa esta conta. Se não corresponder ao Mac, escaneie um QR/link a partir do Mac."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ручное сопряжение использует этот аккаунт. Если он не совпадает с Mac, отсканируйте QR-код или ссылку с Mac."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Manuel eşleştirme bu hesabı kullanır. Mac ile eşleşmiyorsa Mac'ten bir QR/bağlantı tarayın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "手动配对使用此账号。若与 Mac 不匹配，请扫描 Mac 上的二维码或链接。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "手動配對使用此帳號。若與 Mac 上的帳號不符，請從 Mac 掃描 QR 碼或連結。"
          }
        }
      }
    },

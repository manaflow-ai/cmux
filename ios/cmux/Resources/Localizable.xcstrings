    "mobile.toolbar.editor.commandFooter": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Text, der beim Antippen ins Terminal eingegeben wird. „Nach Eingabe ausführen“ aktivieren, um Return automatisch zu drücken."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The text typed into the terminal when tapped. Turn on Run after typing to press Return automatically."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El texto que se escribe en el terminal al tocarlo. Activa Ejecutar al escribir para pulsar Return automáticamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le texte tapé dans le terminal lors de l'appui. Activez Exécuter après la saisie pour appuyer automatiquement sur Retour."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il testo digitato nel terminale quando viene toccato. Attiva Esegui dopo la digitazione per premere Return automaticamente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タップしたときにターミナルへ入力されるテキストです。「入力後に実行」をオンにすると、自動的にReturnが押されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "탭했을 때 터미널에 입력되는 텍스트입니다. 입력 후 실행을 켜면 Return이 자동으로 눌립니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De tekst die in de terminal wordt getypt wanneer je tikt. Schakel 'Uitvoeren na typen' in om automatisch op Return te drukken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tekst wpisywany do terminala po dotknięciu. Włącz opcję Uruchom po wpisaniu, aby automatycznie nacisnąć Return."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O texto digitado no terminal ao tocar. Ative Executar após digitar para pressionar Return automaticamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Текст, вводимый в терминал при нажатии. Включите «Выполнить после ввода», чтобы автоматически нажимать Return."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dokunulduğunda terminale yazılan metin. Yazarken Çalıştır'ı açarak Return'ü otomatik basın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",

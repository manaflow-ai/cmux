            "value": "Código no válido. Por favor, inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Code invalide. Veuillez réessayer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Codice non valido. Riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",

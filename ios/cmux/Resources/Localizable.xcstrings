    "mobile.pairing.secureRouteRequired": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Kopplungsroute ist nicht vertrauenswürdig. Mit einem neuen QR-Code/Link von diesem Computer erneut koppeln."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This pairing route is not trusted. Pair again with a fresh QR/link from that computer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta ruta de emparejamiento no es de confianza. Empareja de nuevo con un QR/enlace nuevo desde ese equipo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette route de jumelage n'est pas approuvée. Jumelez à nouveau avec un nouveau QR/lien depuis cet ordinateur."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo percorso di abbinamento non è attendibile. Abbina di nuovo con un QR/link aggiornato da quel computer."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このペアリング経路は信頼できません。そのコンピュータの新しい QR/リンクで再度ペアリングしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 페어링 경로는 신뢰할 수 없습니다. 해당 컴퓨터에서 새 QR/링크로 다시 페어링하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze koppelroute wordt niet vertrouwd. Koppel opnieuw met een verse QR/link van die computer."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta trasa parowania nie jest zaufana. Sparuj ponownie, używając nowego kodu QR lub linku z tego komputera."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta rota de pareamento não é confiável. Pareie novamente com um QR/link novo daquele computador."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Маршрут сопряжения не является доверенным. Выполните сопряжение заново с новым QR-кодом или ссылкой с компьютера."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu eşleştirme yolu güvenilir değil. O bilgisayardan yeni bir QR/bağlantıyla tekrar eşleştirin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此配对路由不受信任，请从该电脑重新获取二维码/链接进行配对。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此配對路徑不受信任。請從電腦重新掃描 QR 碼或連結進行配對。"
          }
        }
      }
    },

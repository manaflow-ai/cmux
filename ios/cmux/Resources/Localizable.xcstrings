    "mobile.onboarding.tailscaleBody": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale ist eine kostenlose App, die Geräten ein privates Netzwerk gibt. Dies einmalig auf iPhone und Mac durchführen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale is a free app that gives your devices a private network. Do this once, on both the phone and the Mac."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale es una app gratuita que conecta tus dispositivos en una red privada. Hazlo una vez, tanto en el iPhone como en el Mac."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale est une application gratuite qui donne à vos appareils un réseau privé. Faites cela une fois, sur le téléphone et sur le Mac."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale è un'app gratuita che crea una rete privata per i tuoi dispositivi. Fallo una volta, sia sul telefono che sul Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscaleは、端末同士をプライベートなネットワークでつなぐ無料アプリです。iPhoneとMacの両方で一度だけ設定してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale은 기기에 프라이빗 네트워크를 제공하는 무료 앱입니다. iPhone과 Mac에서 각각 한 번씩 설정하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale is een gratis app die je apparaten een privénetwerk geeft. Doe dit eenmalig, op zowel de telefoon als de Mac."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale to bezpłatna aplikacja, która zapewnia urządzeniom prywatną sieć. Zrób to raz, zarówno na telefonie, jak i na Macu."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Tailscale é um app gratuito que cria uma rede privada para seus dispositivos. Faça isso uma vez, no celular e no Mac."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale — бесплатное приложение, создающее приватную сеть для ваших устройств. Сделайте это однократно на телефоне и Mac."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale, cihazlarınıza özel bir ağ veren ücretsiz bir uygulamadır. Bunu bir kez yapın, hem telefonda hem de Mac'te."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale 是一款免费应用，可为您的设备建立私有网络。在手机和 Mac 上各操作一次即可。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale 是一款免費應用程式，可為您的裝置建立私密網路。在手機和 Mac 上各完成一次設定即可。"
          }
        }
      }
    },

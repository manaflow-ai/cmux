          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac'inizde eşleştirme penceresini açın ve yeni bir QR veya bağlantı tarayın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Mac 上打开配对窗口并扫描新的二维码或链接。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Mac 上開啟配對視窗，然後掃描新的 QR 碼或連結。"
          }
        }
      }
    },
    "mobile.pairing.guidance.sameAccount": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beide Geräte müssen mit demselben cmux-Konto angemeldet sein."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Both devices must be signed in to the same cmux account."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ambos dispositivos deben tener iniciada sesión en la misma cuenta de cmux."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les deux appareils doivent être connectés au même compte cmux."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Entrambi i dispositivi devono essere connessi allo stesso account cmux."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "両方の端末が同じcmuxアカウントでサインインしている必要があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "두 기기 모두 같은 cmux 계정으로 로그인되어 있어야 합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Beide apparaten moeten zijn aangemeld bij hetzelfde cmux-account."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Oba urządzenia muszą być zalogowane na to samo konto cmux."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ambos os dispositivos devem estar conectados à mesma conta cmux."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Оба устройства должны быть авторизованы в одном аккаунте cmux."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her iki cihaz da aynı cmux hesabıyla oturum açmış olmalıdır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "两台设备必须登录同一 cmux 账号。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "兩台裝置必須登入相同的 cmux 帳號。"
          }
        }
      }
    },
    "mobile.pairing.guidance.updateApp": {
      "extractionState": "manual",
      "localizations": {

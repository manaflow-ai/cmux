    "mobile.addDevice.help": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale-, LAN- oder lokalen Host und Port eingeben. QR-Code/Link-Kopplung von diesem Computer ist der sicherste Einrichtungsweg."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter a Tailscale, LAN, or local host and port. QR/link pairing from that computer is still the safest setup path."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Introduce un host y puerto de Tailscale, LAN o local. El emparejamiento por QR/enlace desde ese equipo sigue siendo la forma más segura."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Entrez un hôte Tailscale, LAN ou local avec un port. Le jumelage QR/lien depuis cet ordinateur reste la méthode de configuration la plus sûre."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inserisci un host e una porta Tailscale, LAN o locale. L'abbinamento tramite QR/link da quel computer è comunque il percorso di configurazione più sicuro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale、LAN、またはローカルのホストとポートを入力してください。そのコンピュータからの QR/リンクでのペアリングが最も安全な設定方法です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale, LAN 또는 로컬 호스트와 포트를 입력하세요. 해당 컴퓨터의 QR/링크 페어링이 가장 안전한 설정 방법입니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voer een Tailscale-, LAN- of lokale host en poort in. QR/link koppelen vanaf die computer is nog steeds de veiligste aanpak."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Podaj hosta Tailscale, LAN lub lokalnego oraz port. Parowanie przez kod QR lub link z tego komputera jest nadal najbezpieczniejszą metodą."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Insira um host Tailscale, LAN ou local e a porta. O pareamento por QR/link a partir desse computador ainda é a forma mais segura."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Введите адрес Tailscale, LAN или локального хоста и порт. Сопряжение по QR-коду или ссылке с компьютера по-прежнему самый надёжный способ."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir Tailscale, LAN veya yerel ana makine ve port girin. O bilgisayardan QR/bağlantı ile eşleştirme hâlâ en güvenli kurulum yoludur."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "输入 Tailscale、局域网或本地主机及端口。从该电脑扫码/链接配对仍是最安全的设置方式。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "輸入 Tailscale、LAN 或本機主機名稱及連接埠。透過 QR 碼或連結從電腦配對仍是最安全的設定方式。"
          }
        }
      }
    },

    "mobile.pairing.attachTicketExpired": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This pairing link expired. Pair again with a fresh QR/link from that computer."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このペアリングリンクの有効期限が切れました。そのコンピュータの新しい QR/リンクでペアリングしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此配对链接已过期。请用那台电脑上新的二维码/链接重新配对。"
          }
        }
      }
    },
    "mobile.pairing.authorizationFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't verify your account with this Mac. Make sure both devices use the same cmux account and a matching build (both release, or both development), then try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この Mac でアカウントを確認できませんでした。両方のデバイスで同じ cmux アカウントと一致するビルド（どちらもリリース版、またはどちらも開発版）を使用していることを確認してから、もう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法在这台 Mac 上验证你的账户。请确认两台设备使用同一 cmux 账户，且构建版本匹配（都是正式版，或都是开发版），然后重试。"
          }
        }
      }
    },

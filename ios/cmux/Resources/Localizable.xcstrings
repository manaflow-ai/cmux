    "mobile.loading.timeout.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux konnte diese Sitzung nicht vollständig wiederherstellen. Stelle sicher, dass die Mac-App läuft, und versuche es erneut oder füge diesen Mac erneut hinzu."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux could not finish restoring this session. Check that the Mac app is running, then retry or add this Mac again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux no pudo terminar de restaurar esta sesión. Comprueba que la app de Mac esté en ejecución, luego reintenta o agrega este Mac de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux n'a pas pu terminer la restauration de cette session. Vérifiez que l'application Mac est en cours d'exécution, puis réessayez ou ajoutez ce Mac à nouveau."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux non è riuscito a completare il ripristino di questa sessione. Verifica che l'app Mac sia in esecuzione, poi riprova o aggiungi di nuovo questo Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux はこのセッションの復元を完了できませんでした。Mac アプリが起動していることを確認してから、再試行するか、この Mac をもう一度追加してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux이(가) 이 세션 복원을 완료하지 못했습니다. Mac 앱이 실행 중인지 확인한 후 다시 시도하거나 이 Mac을 다시 추가하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux kon het herstellen van deze sessie niet voltooien. Controleer of de Mac-app actief is en probeer opnieuw of voeg deze Mac opnieuw toe."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux nie mógł zakończyć przywracania tej sesji. Sprawdź, czy aplikacja Mac jest uruchomiona, a następnie spróbuj ponownie lub dodaj tego Maca ponownie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux não conseguiu concluir a restauração desta sessão. Verifique se o app para Mac está em execução e tente novamente ou adicione este Mac novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux не смог завершить восстановление этой сессии. Убедитесь, что приложение Mac запущено, затем повторите попытку или добавьте этот Mac снова."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux bu oturumu geri yüklemeyi tamamlayamadı. Mac uygulamasının çalıştığını kontrol edin, ardından yeniden deneyin veya bu Mac'i tekrar ekleyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux 无法完成此会话的恢复。请确认 Mac 应用正在运行，然后重试或重新添加此 Mac。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux 無法完成還原此工作階段。請確認 Mac 應用程式正在執行，然後重試或重新新增此 Mac。"
          }
        }
      }
    },

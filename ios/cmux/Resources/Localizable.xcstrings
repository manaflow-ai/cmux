      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Feedback konnte nicht gesendet werden. Verbindung prüfen und erneut versuchen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not send feedback. Check your connection and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudieron enviar los comentarios. Comprueba tu conexión e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible d'envoyer les commentaires. Vérifiez votre connexion et réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile inviare il feedback. Controlla la connessione e riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フィードバックを送信できませんでした。接続を確認してもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "피드백을 전송할 수 없습니다. 연결 상태를 확인하고 다시 시도하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kon feedback niet versturen. Controleer je verbinding en probeer het opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie można wysłać opinii. Sprawdź połączenie i spróbuj ponownie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível enviar o feedback. Verifique sua conexão e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось отправить отзыв. Проверьте подключение и попробуйте снова."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Geri bildirim gönderilemedi. Bağlantınızı kontrol edip tekrar deneyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法发送反馈，请检查网络连接后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法傳送意見。請確認連線後再試。"
          }
        }
      }
    },
    "mobile.feedback.explanation.agent": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sendet Diagnosen (Debug-Log + sichtbares Terminal) und Notiz direkt an den gekoppelten Mac."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sends diagnostics (debug log + visible terminal) and your note straight to the paired Mac."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía diagnósticos (registro de depuración y terminal visible) y tu nota directamente al Mac emparejado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoie les diagnostics (journal de débogage + terminal visible) et votre note directement au Mac jumelé."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Invia diagnostica (log debug + terminale visibile) e la tua nota direttamente al Mac abbinato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "診断情報（デバッグログ＋表示中のターミナル）とメモをペアリング済みの Mac に直接送信します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "진단 정보(디버그 로그 + 보이는 터미널)와 메모를 페어링된 Mac으로 바로 전송합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verstuurt diagnostische gegevens (debuglog + zichtbare terminal) en je notitie rechtstreeks naar de gekoppelde Mac."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wysyła diagnostykę (dziennik debugowania i widoczny terminal) oraz Twoją notatkę bezpośrednio do sparowanego Maca."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Envia diagnósticos (log de depuração + terminal visível) e sua mensagem diretamente ao Mac pareado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отправляет диагностику (журнал отладки + видимый терминал) и ваш комментарий напрямую на сопряжённый Mac."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tanılama bilgilerini (hata ayıklama günlüğü + görünür terminal) ve notunuzu doğrudan eşleştirilmiş Mac'e gönderir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将诊断信息（调试日志和可见终端内容）及您的说明直接发送到已配对的 Mac。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "傳送診斷資訊（偵錯日誌 + 可見終端機）及您的備註至已配對的 Mac。"
          }
        }
      }
    },
    "mobile.feedback.explanation.email": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sendet Feedback per E-Mail an das cmux-Team, mit App-Version und Gerät."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Emails your feedback to the cmux team, stamped with your app version and device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía tus comentarios por correo al equipo de cmux, con tu versión de la app y dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoie vos commentaires par e-mail à l'équipe cmux, avec votre version d'application et votre appareil."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Invia il tuo feedback al team cmux via email, con la versione dell'app e il dispositivo allegati."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリのバージョンとデバイス情報を付けて、フィードバックを cmux チームにメールで送信します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앱 버전과 기기 정보와 함께 피드백을 cmux 팀에 이메일로 전송합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stuurt je feedback per e-mail naar het cmux-team, met je app-versie en apparaat."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wysyła Twoją opinię e-mailem do zespołu cmux z Twoją wersją aplikacji i urządzeniem."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Envia seu feedback por e-mail para a equipe do cmux, com sua versão do app e dispositivo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отправляет ваш отзыв команде cmux с указанием версии приложения и устройства."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Geri bildiriminizi uygulama sürümünüz ve cihazınızla damgalanmış şekilde cmux ekibine e-posta olarak gönderir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将您的反馈连同应用版本和设备信息发送至 cmux 团队邮箱。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "以電子郵件將意見傳送至 cmux 團隊，並附上您的應用程式版本和裝置資訊。"
          }
        }
      }
    },

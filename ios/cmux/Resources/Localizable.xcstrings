    "mobile.pairing.accountMismatch": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Mac ist mit einem anderen cmux-Konto angemeldet. Abmelden und mit dem Konto, das diesem Mac gehört, erneut anmelden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This Mac is signed in to a different cmux account. Sign out and sign back in with the account that owns this Mac."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este Mac tiene iniciada sesión en una cuenta de cmux diferente. Cierra sesión e inicia sesión de nuevo con la cuenta propietaria de este Mac."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce Mac est connecté à un autre compte cmux. Déconnectez-vous et reconnectez-vous avec le compte propriétaire de ce Mac."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo Mac è connesso a un account cmux diverso. Esci e accedi nuovamente con l'account proprietario di questo Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このMacは別のcmuxアカウントでサインインしています。サインアウトして、このMacを所有するアカウントでサインインし直してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 Mac은 다른 cmux 계정으로 로그인되어 있습니다. 로그아웃한 후 이 Mac의 계정으로 다시 로그인하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze Mac is aangemeld bij een ander cmux-account. Log uit en meld je opnieuw aan met het account dat eigenaar is van deze Mac."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ten Mac jest zalogowany na inne konto cmux. Wyloguj się i zaloguj ponownie na konto, które jest właścicielem tego Maca."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este Mac está conectado a uma conta cmux diferente. Saia e entre novamente com a conta que possui este Mac."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На этом Mac выполнен вход в другой аккаунт cmux. Выйдите и войдите снова с аккаунтом, которому принадлежит этот Mac."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu Mac farklı bir cmux hesabıyla oturum açmış. Çıkış yapın ve bu Mac'e ait hesapla tekrar giriş yapın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此 Mac 登录的是其他 cmux 账号，请退出登录后使用拥有此 Mac 的账号重新登录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此 Mac 已登入不同的 cmux 帳號。請登出後以擁有此 Mac 的帳號重新登入。"
          }
        }
      }
    },
    "mobile.pairing.appNotRunning": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Mac ist erreichbar, aber cmux läuft dort nicht (oder mobile Kopplung ist deaktiviert). cmux auf dem Mac öffnen, dann erneut versuchen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your Mac is reachable, but cmux isn't running there (or mobile pairing is off). Open cmux on the Mac, then try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu Mac es accesible, pero cmux no está ejecutándose allí (o el emparejamiento móvil está desactivado). Abre cmux en el Mac e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre Mac est accessible, mais cmux n'est pas en cours d'exécution (ou le jumelage mobile est désactivé). Ouvrez cmux sur le Mac, puis réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo Mac è raggiungibile, ma cmux non è in esecuzione (o l'abbinamento mobile è disattivato). Apri cmux sul Mac, poi riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Macには接続できますが、cmuxが起動していません（またはモバイルのペア設定がオフです）。Macでcmuxを開いてから、もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac에 접근할 수 있지만 cmux가 실행 중이지 않습니다(또는 모바일 페어링이 꺼져 있습니다). Mac에서 cmux를 열고 다시 시도하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je Mac is bereikbaar, maar cmux wordt er niet uitgevoerd (of mobiel koppelen is uitgeschakeld). Open cmux op de Mac en probeer het opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twój Mac jest osiągalny, ale cmux tam nie działa (lub parowanie mobilne jest wyłączone). Otwórz cmux na Macu i spróbuj ponownie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu Mac está acessível, mas o cmux não está em execução (ou o pareamento móvel está desativado). Abra o cmux no Mac e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac доступен, но cmux на нём не запущен (или мобильное сопряжение отключено). Откройте cmux на Mac и попробуйте снова."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac'inize ulaşılabiliyor, ancak cmux orada çalışmıyor (veya mobil eşleştirme kapalı). Mac'te cmux'u açın, ardından tekrar deneyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的 Mac 可访问，但 cmux 未在其上运行（或移动端配对已关闭）。请在 Mac 上打开 cmux 后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "您的 Mac 可連線，但 cmux 未在上面執行（或行動裝置配對已關閉）。請在 Mac 上開啟 cmux 後再試。"
          }
        }
      }
    },
    "mobile.pairing.attachTicketExpired": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Kopplungslink ist abgelaufen. Mit einem neuen QR-Code/Link von diesem Computer erneut koppeln."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This pairing link expired. Pair again with a fresh QR/link from that computer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este enlace de emparejamiento ha expirado. Empareja de nuevo con un QR/enlace nuevo desde ese equipo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce lien de jumelage a expiré. Jumelez à nouveau avec un nouveau QR/lien depuis cet ordinateur."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo link di abbinamento è scaduto. Abbina di nuovo con un QR/link aggiornato da quel computer."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このペアリングリンクの有効期限が切れました。そのコンピュータの新しい QR/リンクでペアリングしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 페어링 링크가 만료되었습니다. 해당 컴퓨터에서 새 QR/링크로 다시 페어링하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze koppellink is verlopen. Koppel opnieuw met een verse QR/link van die computer."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ten link parowania wygasł. Sparuj ponownie, używając nowego kodu QR lub linku z tego komputera."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este link de pareamento expirou. Pareie novamente com um QR/link novo daquele computador."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Срок действия ссылки для сопряжения истёк. Выполните сопряжение заново с новым QR-кодом или ссылкой с компьютера."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu eşleştirme bağlantısının süresi doldu. O bilgisayardan yeni bir QR/bağlantıyla tekrar eşleştirin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此配对链接已过期，请从该电脑重新获取二维码/链接进行配对。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此配對連結已過期。請從電腦重新掃描 QR 碼或連結進行配對。"
          }
        }
      }
    },
    "mobile.pairing.authorizationFailed": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Konto konnte nicht mit diesem Mac verifiziert werden. Sicherstellen, dass beide Geräte mit derselben E-Mail-Adresse angemeldet sind, dann erneut versuchen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't verify your account with this Mac. Make sure both devices are signed in with the same email, then try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo verificar tu cuenta con este Mac. Asegúrate de que ambos dispositivos tienen el mismo correo electrónico y vuelve a intentarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de vérifier votre compte avec ce Mac. Assurez-vous que les deux appareils sont connectés avec le même e-mail, puis réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile verificare il tuo account con questo Mac. Assicurati che entrambi i dispositivi siano connessi con la stessa email, poi riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この Mac でアカウントを確認できませんでした。両方のデバイスが同じメールアドレスでサインインしていることを確認してから、もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 Mac으로 계정을 확인할 수 없습니다. 두 기기 모두 같은 이메일로 로그인되어 있는지 확인하고 다시 시도하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kon je account niet verifiëren bij deze Mac. Zorg dat beide apparaten zijn aangemeld met hetzelfde e-mailadres en probeer het opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie udało się zweryfikować Twojego konta na tym Macu. Upewnij się, że oba urządzenia są zalogowane na ten sam adres e-mail i spróbuj ponownie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível verificar sua conta com este Mac. Certifique-se de que ambos os dispositivos estão conectados com o mesmo e-mail e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось подтвердить ваш аккаунт на этом Mac. Убедитесь, что оба устройства входят с одним адресом электронной почты, и попробуйте снова."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu Mac ile hesabınız doğrulanamadı. Her iki cihazın da aynı e-posta ile oturum açtığından emin olun, ardından tekrar deneyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法通过此 Mac 验证账号，请确保两台设备使用同一邮箱登录后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法透過此 Mac 驗證您的帳號。請確認兩台裝置均以相同電子郵件登入，然後再試一次。"
          }
        }
      }
    },

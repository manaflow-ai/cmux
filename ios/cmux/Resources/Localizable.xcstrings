    "mobile.pairing.requestTimedOut": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Computer hat nicht geantwortet. Host und Port prüfen und erneut versuchen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The computer did not respond. Check the host and port, then try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El equipo no respondió. Comprueba el host y el puerto, luego inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'ordinateur n'a pas répondu. Vérifiez l'hôte et le port, puis réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il computer non ha risposto. Controlla l'host e la porta, poi riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コンピュータが応答しませんでした。ホストとポートを確認して、もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "컴퓨터가 응답하지 않습니다. 호스트와 포트를 확인하고 다시 시도하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De computer heeft niet gereageerd. Controleer de host en poort en probeer het opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Komputer nie odpowiedział. Sprawdź hosta i port, a następnie spróbuj ponownie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O computador não respondeu. Verifique o host e a porta e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Компьютер не ответил. Проверьте хост и порт, затем попробуйте снова."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bilgisayar yanıt vermedi. Sunucu ve portu kontrol edip tekrar deneyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "电脑未响应，请检查主机和端口后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "電腦未回應。請確認主機和連接埠後再試。"
          }
        }
      }
    },

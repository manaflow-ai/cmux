    "mobile.pairing.connectTimedOutFormat": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine Antwort von %@:%d. Der Mac schläft möglicherweise oder ist nicht mit Tailscale verbunden. Sicherstellen, dass er aufgewacht und im selben Tailscale-Netzwerk ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No response from %@:%d. Your Mac may be asleep or off Tailscale. Make sure it's awake and on the same Tailscale network."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin respuesta de %@:%d. Es posible que tu Mac esté dormido o fuera de Tailscale. Asegúrate de que está activo y en la misma red Tailscale."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune réponse de %@:%d. Votre Mac est peut-être en veille ou hors de Tailscale. Assurez-vous qu'il est éveillé et sur le même réseau Tailscale."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessuna risposta da %@:%d. Il tuo Mac potrebbe essere in sospensione o fuori da Tailscale. Assicurati che sia attivo e sulla stessa rete Tailscale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d から応答がありません。Macがスリープしているか、Tailscaleに接続されていない可能性があります。Macがスリープしておらず、同じTailscaleネットワーク上にあることを確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d에서 응답이 없습니다. Mac이 절전 상태이거나 Tailscale에서 벗어났을 수 있습니다. Mac이 깨어 있고 같은 Tailscale 네트워크에 있는지 확인하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geen reactie van %@:%d. Je Mac is mogelijk in slaapstand of niet verbonden met Tailscale. Zorg dat hij wakker is en op hetzelfde Tailscale-netwerk zit."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Brak odpowiedzi od %@:%d. Twój Mac może być uśpiony lub poza Tailscale. Upewnij się, że jest wybudzony i w tej samej sieci Tailscale."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sem resposta de %@:%d. Seu Mac pode estar em modo de suspensão ou fora do Tailscale. Certifique-se de que está ativo e na mesma rede Tailscale."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нет ответа от %@:%d. Возможно, Mac спит или отключён от Tailscale. Убедитесь, что он активен и в одной сети Tailscale."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d adresinden yanıt yok. Mac'iniz uyuyor veya Tailscale dışında olabilir. Uyandırın ve aynı Tailscale ağında olduğundan emin olun."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d 无响应，您的 Mac 可能已休眠或不在 Tailscale 网络中。请确保其已唤醒且在同一 Tailscale 网络上。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未收到 %@:%d 的回應。您的 Mac 可能已休眠或離開 Tailscale 網路。請確認 Mac 已喚醒並連線至相同的 Tailscale 網路。"
          }
        }
      }
    },
    "mobile.pairing.connectionDroppedFormat": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit %@:%d verbunden, aber der Host hat die Verbindung getrennt. Prüfen, ob die Host-App noch läuft."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Connected to %@:%d, but the host closed the connection. Check that the host app is still running."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conectado a %@:%d, pero el host cerró la conexión. Comprueba que la app del host sigue en ejecución."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Connecté à %@:%d, mais l'hôte a fermé la connexion. Vérifiez que l'application hôte est toujours en cours d'exécution."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Connesso a %@:%d, ma l'host ha chiuso la connessione. Verifica che l'app host sia ancora in esecuzione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d に接続しましたが、ホストが接続を閉じました。ホストアプリがまだ実行中であることを確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d에 연결되었지만 호스트가 연결을 종료했습니다. 호스트 앱이 실행 중인지 확인하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbonden met %@:%d, maar de host heeft de verbinding verbroken. Controleer of de host-app nog actief is."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Połączono z %@:%d, ale host zamknął połączenie. Sprawdź, czy aplikacja hosta nadal działa."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Conectado a %@:%d, mas o host encerrou a conexão. Verifique se o app do host ainda está em execução."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подключено к %@:%d, но хост закрыл соединение. Убедитесь, что приложение на хосте ещё запущено."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d adresine bağlandı, ancak sunucu bağlantıyı kapattı. Sunucu uygulamasının hâlâ çalıştığını kontrol edin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已连接到 %@:%d，但主机关闭了连接，请确认主机应用仍在运行。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已連線至 %@:%d，但主機關閉了連線。請確認主機應用程式仍在執行。"
          }
        }
      }
    },
    "mobile.pairing.connectionFailedFormat": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d konnte nicht erreicht werden. Prüfen, ob der Host über Tailscale oder LAN erreichbar ist und der Port korrekt ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not reach %@:%d. Check that the host is reachable over Tailscale or LAN and that the port is correct."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo alcanzar %@:%d. Comprueba que el host es accesible por Tailscale o LAN y que el puerto es correcto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible d'atteindre %@:%d. Vérifiez que l'hôte est accessible via Tailscale ou LAN et que le port est correct."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile raggiungere %@:%d. Verifica che l'host sia raggiungibile tramite Tailscale o LAN e che la porta sia corretta."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d に到達できませんでした。ホストが Tailscale または LAN 経由で到達可能で、ポートが正しいことを確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d에 연결할 수 없습니다. 호스트가 Tailscale 또는 LAN을 통해 접근 가능하고 포트가 올바른지 확인하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kan %@:%d niet bereiken. Controleer of de host bereikbaar is via Tailscale of LAN en of de poort correct is."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie można dotrzeć do %@:%d. Sprawdź, czy host jest osiągalny przez Tailscale lub LAN i czy port jest prawidłowy."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível alcançar %@:%d. Verifique se o host está acessível via Tailscale ou LAN e se a porta está correta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось достичь %@:%d. Проверьте доступность хоста через Tailscale или LAN и правильность порта."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d adresine ulaşılamadı. Sunucunun Tailscale veya LAN üzerinden erişilebilir olduğunu ve portun doğru olduğunu kontrol edin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法连接到 %@:%d，请确认主机可通过 Tailscale 或局域网访问且端口正确。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法連線至 %@:%d。請確認主機可透過 Tailscale 或 LAN 連線，且連接埠正確。"
          }
        }
      }
    },
    "mobile.pairing.connectionTimedOutFormat": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine Antwort von %@:%d. Sicherstellen, dass die Host-App geöffnet ist und mobile Verbindungen akzeptiert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No response from %@:%d. Make sure the host app is open and accepting mobile connections."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin respuesta de %@:%d. Asegúrate de que la app del host está abierta y acepta conexiones móviles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune réponse de %@:%d. Assurez-vous que l'application hôte est ouverte et accepte les connexions mobiles."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessuna risposta da %@:%d. Assicurati che l'app host sia aperta e accetti connessioni mobile."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d から応答がありません。ホストアプリが開いていて、モバイル接続を受け入れていることを確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d에서 응답이 없습니다. 호스트 앱이 열려 있고 모바일 연결을 허용하는지 확인하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geen reactie van %@:%d. Zorg dat de host-app open is en mobiele verbindingen accepteert."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Brak odpowiedzi od %@:%d. Upewnij się, że aplikacja hosta jest otwarta i akceptuje połączenia mobilne."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sem resposta de %@:%d. Certifique-se de que o app do host está aberto e aceitando conexões móveis."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нет ответа от %@:%d. Убедитесь, что приложение на хосте открыто и принимает мобильные подключения."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d adresinden yanıt yok. Sunucu uygulamasının açık ve mobil bağlantıları kabul ettiğinden emin olun."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d 无响应，请确保主机应用已打开并允许移动端连接。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未收到 %@:%d 的回應。請確認主機應用程式已開啟並接受行動裝置連線。"
          }
        }
      }
    },
    "mobile.pairing.dnsFailedFormat": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ konnte nicht aufgelöst werden. Prüfen, ob Tailscale auf beiden Geräten verbunden ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't resolve %@. Check that Tailscale is connected on both devices."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo resolver %@. Comprueba que Tailscale está conectado en ambos dispositivos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de résoudre %@. Vérifiez que Tailscale est connecté sur les deux appareils."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile risolvere %@. Verifica che Tailscale sia connesso su entrambi i dispositivi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ を解決できませんでした。両方の端末でTailscaleが接続されていることを確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@을(를) 확인할 수 없습니다. 두 기기 모두 Tailscale에 연결되어 있는지 확인하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kan %@ niet omzetten. Controleer of Tailscale op beide apparaten is verbonden."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie można rozpoznać %@. Sprawdź, czy Tailscale jest połączony na obu urządzeniach."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível resolver %@. Verifique se o Tailscale está conectado em ambos os dispositivos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось разрешить %@. Убедитесь, что Tailscale подключён на обоих устройствах."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ çözümlenemedi. Her iki cihazda da Tailscale'in bağlı olduğunu kontrol edin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法解析 %@，请确认两台设备均已连接 Tailscale。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法解析 %@。請確認兩台裝置都已連線至 Tailscale。"
          }
        }
      }
    },
    "mobile.pairing.emailMismatchFormat": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser QR-Code ist für %@, aber dieses iPhone ist als %@ angemeldet. Mit derselben E-Mail-Adresse wie der Mac anmelden, dann erneut scannen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This QR is for %@, but this iPhone is signed in as %@. Sign in with the same email as the Mac, then scan again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este QR es para %@, pero este iPhone ha iniciado sesión como %@. Inicia sesión con el mismo correo electrónico que el Mac y escanea de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce QR est pour %@, mais cet iPhone est connecté en tant que %@. Connectez-vous avec le même e-mail que le Mac, puis scannez à nouveau."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo QR è per %@, ma questo iPhone è connesso come %@. Accedi con la stessa email del Mac, poi scansiona di nuovo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この QR は %@ 用ですが、この iPhone は %@ としてサインインしています。Mac と同じメールアドレスでサインインしてから、もう一度スキャンしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 QR은 %@ 계정용이지만 이 iPhone은 %@(으)로 로그인되어 있습니다. Mac과 같은 이메일로 로그인한 후 다시 스캔하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze QR is voor %@, maar deze iPhone is aangemeld als %@. Meld je aan met hetzelfde e-mailadres als de Mac en scan opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ten kod QR jest dla %@, ale ten iPhone jest zalogowany jako %@. Zaloguj się na ten sam adres e-mail co Mac i zeskanuj ponownie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este QR é para %@, mas este iPhone está conectado como %@. Faça login com o mesmo e-mail do Mac e escaneie novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот QR-код предназначен для %@, но на iPhone выполнен вход как %@. Войдите с тем же адресом, что и на Mac, затем отсканируйте снова."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu QR %@ için, ancak bu iPhone %@ olarak oturum açmış. Mac ile aynı e-posta ile giriş yapın, ardından tekrar tarayın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此二维码属于 %@，但此 iPhone 当前登录为 %@。请使用与 Mac 相同的邮箱登录后重新扫描。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此 QR 碼屬於 %@，但此 iPhone 目前登入為 %@。請以與 Mac 相同的電子郵件登入，然後重新掃描。"
          }
        }
      }
    },

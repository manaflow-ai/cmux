    "mobile.computers.footer": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Macs, die in deinem Konto angemeldet sind. Arbeitsbereiche aller Computer erscheinen gemeinsam in der Hauptliste."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Macs signed in to your account. Workspaces from every computer appear together in the main list."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los Macs con sesión iniciada en tu cuenta. Los espacios de trabajo de cada computadora aparecen juntos en la lista principal."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les Macs connectés à votre compte. Les espaces de travail de chaque ordinateur apparaissent ensemble dans la liste principale."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I Mac collegati al tuo account. I workspace di ogni computer appaiono insieme nell'elenco principale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アカウントにサインインしている Mac。すべてのコンピュータのワークスペースがメインのリストにまとめて表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "계정에 로그인된 Mac 목록입니다. 모든 컴퓨터의 워크스페이스가 메인 목록에 함께 표시됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De Macs die zijn aangemeld bij uw account. Werkruimten van elke computer verschijnen samen in de hoofdlijst."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Maki zalogowane na Twoje konto. Przestrzenie robocze z każdego komputera pojawiają się razem na głównej liście."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os Macs conectados à sua conta. Os espaços de trabalho de todos os computadores aparecem juntos na lista principal."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac, подключённые к вашему аккаунту. Рабочие пространства со всех компьютеров отображаются вместе в основном списке."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hesabınıza giriş yapmış Mac'ler. Her bilgisayardaki çalışma alanları ana listede bir arada görünür."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已登录您账号的 Mac。所有电脑的工作区将统一显示在主列表中。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已登入您帳號的 Mac。所有電腦的工作區會一起顯示在主列表中。"
          }
        }
      }
    },

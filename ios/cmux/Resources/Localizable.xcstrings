    "mobile.terminal.inputQueueFull": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Terminal kann derzeit keine weiteren Eingaben annehmen. Einen Moment warten und erneut versuchen oder Terminal neu öffnen, wenn es weiterhin nicht verfügbar ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The terminal can't accept more input right now. Wait a moment and retry, or reopen the terminal if it stays unavailable."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El terminal no puede aceptar más entradas en este momento. Espera un momento y vuelve a intentarlo, o reabre el terminal si continúa no disponible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le terminal ne peut pas accepter d'entrée supplémentaire pour l'instant. Attendez un moment et réessayez, ou rouvrez le terminal s'il reste indisponible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il terminale non può accettare altro input al momento. Attendi un momento e riprova, o riapri il terminale se rimane non disponibile."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ターミナルは現在これ以上の入力を受け付けられません。しばらくしてから再試行するか、利用できない状態が続く場合はターミナルを開き直してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "터미널이 지금은 더 이상 입력을 받을 수 없습니다. 잠시 후 다시 시도하거나, 터미널이 계속 사용 불가능하면 다시 여세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De terminal kan op dit moment geen invoer meer verwerken. Wacht even en probeer het opnieuw, of heropen de terminal als die onbeschikbaar blijft."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Terminal nie może teraz przyjąć więcej danych. Odczekaj chwilę i spróbuj ponownie lub otwórz terminal, jeśli pozostaje niedostępny."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O terminal não pode aceitar mais entradas agora. Aguarde um momento e tente novamente, ou reabra o terminal se continuar indisponível."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Терминал не может принять больше ввода прямо сейчас. Подождите немного и повторите попытку или переоткройте терминал, если он остаётся недоступным."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Terminal şu anda daha fazla giriş kabul edemiyor. Bir süre bekleyip tekrar deneyin veya kullanılamaz durumda kalırsa terminali yeniden açın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "终端当前无法接受更多输入，请稍等片刻后重试，或在终端持续不可用时重新打开。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "終端機目前無法接受更多輸入。請稍候後重試，或若終端機持續無法使用，請重新開啟。"
          }
        }
      }
    },

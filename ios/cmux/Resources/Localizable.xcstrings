    "mobile.computers.removeMessage": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Computer und seine Arbeitsbereiche werden hier nicht mehr angezeigt. Koppele ihn erneut, um ihn wieder hinzuzufügen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This computer and its workspaces stop appearing here. Pair it again to add it back."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta computadora y sus espacios de trabajo dejan de aparecer aquí. Vincúlala de nuevo para volver a agregarla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cet ordinateur et ses espaces de travail n'apparaissent plus ici. Couplez-le à nouveau pour le rajouter."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo computer e i suoi workspace smettono di apparire qui. Abbinalo di nuovo per aggiungerlo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このコンピュータとそのワークスペースは表示されなくなります。再度ペアリングすると追加できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 컴퓨터와 해당 워크스페이스가 여기에 더 이상 표시되지 않습니다. 다시 추가하려면 페어링하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze computer en zijn werkruimten worden hier niet meer weergegeven. Koppel opnieuw om het terug te voegen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ten komputer i jego przestrzenie robocze przestaną się tu pojawiać. Sparuj go ponownie, aby go dodać z powrotem."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este computador e seus espaços de trabalho deixarão de aparecer aqui. Pareie-o novamente para adicioná-lo de volta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот компьютер и его рабочие пространства перестанут отображаться здесь. Выполните сопряжение повторно, чтобы добавить его снова."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu bilgisayar ve çalışma alanları burada görünmez. Geri eklemek için yeniden eşleştir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此电脑及其工作区将不再显示。重新配对即可重新添加。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此電腦及其工作區將不再顯示於此。重新配對以恢復。"
          }
        }
      }
    },

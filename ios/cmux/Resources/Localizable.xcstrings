          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "잘못된 코드입니다. 다시 시도해 주세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ongeldige code. Probeer het opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nieprawidłowy kod. Spróbuj ponownie."
          }
        },
        "pt-BR": {

    "mobile.deviceTree.empty": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch keine registrierten Geräte. Mac koppeln, um ihn hier anzuzeigen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No registered devices yet. Pair a Mac to see it here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay dispositivos registrados aún. Empareja un Mac para verlo aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun appareil enregistré. Jumelez un Mac pour le voir ici."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessun dispositivo registrato. Abbina un Mac per vederlo qui."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "登録済みのデバイスはまだありません。Macをペアリングするとここに表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아직 등록된 기기가 없습니다. Mac을 페어링하면 여기에 표시됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nog geen geregistreerde apparaten. Koppel een Mac om hem hier te zien."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Brak zarejestrowanych urządzeń. Sparuj Maca, aby go zobaczyć tutaj."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhum dispositivo registrado ainda. Pareie um Mac para vê-lo aqui."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нет зарегистрированных устройств. Выполните сопряжение Mac, чтобы он появился здесь."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Henüz kayıtlı cihaz yok. Burada görmek için bir Mac eşleştirin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "尚无已注册设备，配对一台 Mac 即可在此查看。"
          }
        },

    "mobile.addDevice.manualRouteWarning": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies stellt eine direkte Verbindung zu dieser Adresse her. Nur in einem vertrauenswürdigen LAN, VPN oder auf einem eigenen Gerät verwenden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will connect directly to that address. Use this only on a trusted LAN, VPN, or device you control."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto se conectará directamente a esa dirección. Úsalo solo en una LAN, VPN o dispositivo de confianza."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela se connectera directement à cette adresse. Utilisez ceci uniquement sur un réseau local, VPN ou appareil de confiance."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Verrà stabilita una connessione diretta a quell'indirizzo. Usalo solo su una LAN, VPN o dispositivo di tua fiducia."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "そのアドレスへ直接接続します。信頼できる LAN、VPN、または管理しているデバイスでのみ使用してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "해당 주소로 직접 연결됩니다. 신뢰할 수 있는 LAN, VPN 또는 직접 제어하는 기기에서만 사용하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit maakt rechtstreeks verbinding met dat adres. Gebruik dit alleen op een vertrouwd LAN, VPN of apparaat dat je beheert."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Połączy się bezpośrednio z tym adresem. Używaj tylko w zaufanej sieci LAN, VPN lub na urządzeniu, które kontrolujesz."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso conectará diretamente a esse endereço. Use apenas em uma LAN confiável, VPN ou dispositivo que você controla."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Будет выполнено прямое подключение к этому адресу. Используйте только в надёжной LAN, VPN или на устройстве под вашим управлением."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu, doğrudan o adrese bağlanacaktır. Yalnızca güvenilir bir LAN, VPN veya kontrol ettiğiniz bir cihazda kullanın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将直接连接到该地址，仅在受信任的局域网、VPN 或您控制的设备上使用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這將直接連線至該位址。請僅在受信任的 LAN、VPN 或您自行管理的裝置上使用。"
          }
        }
      }
    },

    "mobile.pairing.connectionDroppedFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Connected to %@:%d, but the host closed the connection. Check that the host app is still running."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d に接続しましたが、ホストが接続を閉じました。ホストアプリがまだ実行中であることを確認してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已连接到 %@:%d，但主机关闭了连接。请检查主机应用是否仍在运行。"
          }
        }
      }
    },
    "mobile.pairing.connectionFailedFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not reach %@:%d. Check that the host is reachable over Tailscale or LAN and that the port is correct."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d に到達できませんでした。ホストが Tailscale または LAN 経由で到達可能で、ポートが正しいことを確認してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法连接到 %@:%d。请检查主机是否可通过 Tailscale 或局域网访问，以及端口是否正确。"
          }
        }
      }
    },
    "mobile.pairing.connectionTimedOutFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No response from %@:%d. Make sure the host app is open and accepting mobile connections."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d から応答がありません。ホストアプリが開いていて、モバイル接続を受け入れていることを確認してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d 无响应。请确认主机应用已打开并接受移动设备连接。"
          }
        }
      }
    },

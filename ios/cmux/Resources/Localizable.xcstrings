    "mobile.signIn.restoreTimeoutMessage": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux konnte die Überprüfung deiner gespeicherten Sitzung nicht abschließen. Überprüfe deine Verbindung und versuche es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux could not finish checking your saved session. Check your connection, then retry."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux no pudo terminar de verificar tu sesión guardada. Comprueba tu conexión e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux n'a pas pu terminer la vérification de votre session enregistrée. Vérifiez votre connexion, puis réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux non è riuscito a completare la verifica della sessione salvata. Controlla la connessione, poi riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux は保存済みセッションの確認を完了できませんでした。接続を確認してから再試行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux이(가) 저장된 세션 확인을 완료하지 못했습니다. 연결을 확인한 후 다시 시도하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux kon het controleren van uw opgeslagen sessie niet voltooien. Controleer uw verbinding en probeer opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux nie mógł zakończyć sprawdzania Twojej zapisanej sesji. Sprawdź połączenie, a następnie spróbuj ponownie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux não conseguiu concluir a verificação da sua sessão salva. Verifique sua conexão e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux не смог завершить проверку сохранённой сессии. Проверьте соединение и повторите попытку."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux kayıtlı oturumunuzu kontrol etmeyi tamamlayamadı. Bağlantınızı kontrol edin, ardından yeniden deneyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux 无法完成已保存会话的检查。请检查您的网络连接，然后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux 無法完成檢查您的已儲存工作階段。請檢查您的連線後重試。"
          }
        }
      }
    },

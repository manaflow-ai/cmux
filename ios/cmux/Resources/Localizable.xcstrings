    "mobile.computers.empty": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch keine Computer. Füge einen hinzu, um hier seine Arbeitsbereiche zu sehen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No computers yet. Add one to see its workspaces here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay computadoras. Agrega una para ver sus espacios de trabajo aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun ordinateur pour l'instant. Ajoutez-en un pour voir ses espaces de travail ici."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessun computer ancora. Aggiungine uno per vedere qui i suoi workspace."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コンピュータがありません。追加するとワークスペースがここに表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아직 컴퓨터가 없습니다. 추가하면 워크스페이스가 여기에 표시됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nog geen computers. Voeg er een toe om de werkruimten hier te zien."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Brak komputerów. Dodaj jeden, aby wyświetlić jego przestrzenie robocze."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhum computador ainda. Adicione um para ver seus espaços de trabalho aqui."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нет компьютеров. Добавьте один, чтобы увидеть его рабочие пространства здесь."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Henüz bilgisayar yok. Çalışma alanlarını görmek için bir tane ekle."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂无电脑。添加一台以在此查看其工作区。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "尚無電腦。新增一台以在此查看其工作區。"
          }
        }
      }
    },

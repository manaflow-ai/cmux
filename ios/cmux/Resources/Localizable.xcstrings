    "mobile.pairing.versionWarningFormat": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Auf diesem iPhone läuft cmux %@, auf dem Mac läuft cmux %@. Das Koppeln über unterschiedliche Kompatibilitätsstufen kann Terminal-Eingabe, Workspace-Sync oder Benachrichtigungen beeinträchtigen. Nur fortfahren, wenn du diesem Mac vertraust und akzeptierst, dass einige Funktionen möglicherweise nicht funktionieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This iPhone is running cmux %@, but the Mac is running cmux %@. Pairing across different compatibility levels can break terminal input, workspace sync, or notifications. Continue only if you trust this Mac and accept that some features may fail."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este iPhone está ejecutando cmux %@, pero el Mac está ejecutando cmux %@. Emparejar entre niveles de compatibilidad diferentes puede romper la entrada del terminal, la sincronización de espacios de trabajo o las notificaciones. Continúa solo si confías en este Mac y aceptas que algunas funciones pueden fallar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cet iPhone utilise cmux %@, mais le Mac utilise cmux %@. Le jumelage entre différents niveaux de compatibilité peut perturber la saisie du terminal, la synchronisation des espaces de travail ou les notifications. Continuez uniquement si vous faites confiance à ce Mac et acceptez que certaines fonctionnalités puissent ne pas fonctionner."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo iPhone usa cmux %@, ma il Mac usa cmux %@. L'abbinamento tra livelli di compatibilità diversi può causare problemi all'input del terminale, alla sincronizzazione workspace o alle notifiche. Continua solo se ti fidi di questo Mac e accetti che alcune funzioni potrebbero non funzionare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この iPhone は cmux %@ を実行していますが、Mac は cmux %@ を実行しています。異なる互換性レベル間でペアリングすると、ターミナル入力、ワークスペース同期、通知が壊れる可能性があります。この Mac を信頼し、一部の機能が失敗する可能性を受け入れる場合のみ続行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 iPhone은 cmux %@을(를) 실행 중이지만 Mac은 cmux %@을(를) 실행 중입니다. 호환성 수준이 다른 버전 간 페어링은 터미널 입력, 워크스페이스 동기화 또는 알림을 손상시킬 수 있습니다. 이 Mac을 신뢰하고 일부 기능이 작동하지 않을 수 있음을 인지한 경우에만 계속하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze iPhone gebruikt cmux %@, maar de Mac gebruikt cmux %@. Koppelen over verschillende compatibiliteitsniveaus kan terminalinvoer, werkruimtesynchronisatie of meldingen verstoren. Ga alleen door als je deze Mac vertrouwt en accepteert dat sommige functies mogelijk niet werken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ten iPhone używa cmux %@, ale Mac używa cmux %@. Parowanie przez różne poziomy zgodności może powodować problemy z wejściem terminala, synchronizacją przestrzeni roboczych lub powiadomieniami. Kontynuuj tylko jeśli ufasz temu Macowi i akceptujesz, że niektóre funkcje mogą nie działać."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este iPhone está executando cmux %@, mas o Mac está executando cmux %@. Parear versões com níveis de compatibilidade diferentes pode quebrar a entrada do terminal, sincronização de workspace ou notificações. Continue apenas se confiar neste Mac e aceitar que alguns recursos podem falhar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На этом iPhone установлен cmux %@, а на Mac — cmux %@. Сопряжение при разных уровнях совместимости может нарушить ввод в терминале, синхронизацию рабочих пространств или уведомления. Продолжайте, только если доверяете этому Mac и принимаете, что часть функций может не работать."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu iPhone cmux %@ çalıştırıyor, ancak Mac cmux %@ çalıştırıyor. Farklı uyumluluk seviyeleri arasında eşleştirme terminal girişini, çalışma alanı senkronizasyonunu veya bildirimleri bozabilir. Yalnızca bu Mac'e güveniyorsanız ve bazı özelliklerin çalışmayabileceğini kabul ediyorsanız devam edin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此 iPhone 运行的是 cmux %@，但 Mac 运行的是 cmux %@。跨兼容级别配对可能导致终端输入、工作区同步或通知出现问题。仅在信任此 Mac 且接受部分功能可能失效的情况下继续。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此 iPhone 執行的是 cmux %@，但 Mac 執行的是 cmux %@。在不同相容性版本之間配對可能導致終端機輸入、工作區同步或通知失效。請僅在您信任此 Mac 且接受部分功能可能無法使用的情況下繼續。"
          }
        }
      }
    },

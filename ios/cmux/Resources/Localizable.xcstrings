{
  "sourceLanguage": "en",
  "strings": {
    "auth.error.apple_config": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Sign In is not available yet. Please use another sign-in method."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple でのサインインはまだ利用できません。別のサインイン方法を使用してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 登录暂不可用，请使用其他登录方式。"
          }
        }
      }
    },
    "auth.error.code_expired": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Code expired. Please request a new one."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コードの有効期限が切れました。新しいコードをリクエストしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "验证码已过期，请重新获取。"
          }
        }
      }
    },
    "auth.error.config": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign in is temporarily unavailable. Please try again later."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サインインは一時的に利用できません。しばらくしてからもう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "登录暂时不可用，请稍后再试。"
          }
        }
      }
    },
    "auth.error.email_exists": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An account with this email already exists. Try signing in instead."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このメールのアカウントはすでに存在します。サインインを試してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此邮箱已注册账户，请改用登录。"
          }
        }
      }
    },
    "auth.error.generic": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Something went wrong. Please try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "問題が発生しました。もう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "出了点问题，请重试。"
          }
        }
      }
    },
    "auth.error.invalid_code": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid code. Please check and try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コードが無効です。確認してもう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "验证码无效，请检查后重试。"
          }
        }
      }
    },
    "auth.error.invalid_code_short": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid code. Please try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コードが無効です。もう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "验证码无效，请重试。"
          }
        }
      }
    },
    "auth.error.invalid_email": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please enter a valid email address."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効なメールアドレスを入力してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请输入有效的邮箱地址。"
          }
        }
      }
    },
    "auth.error.invalid_mfa": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Incorrect verification code. Please try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "確認コードが正しくありません。もう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "验证码不正确，请重试。"
          }
        }
      }
    },
    "auth.error.network": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not connect to the server. Check your internet connection and try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サーバーに接続できませんでした。インターネット接続を確認してもう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法连接到服务器。请检查网络连接后重试。"
          }
        }
      }
    },
    "auth.error.network_error": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Network error. Please check your connection."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ネットワークエラーです。接続を確認してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "网络错误，请检查你的网络连接。"
          }
        }
      }
    },
    "auth.error.oauth_linked": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This account is already linked to another sign-in method."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアカウントは別のサインイン方法にすでにリンクされています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此账户已关联到另一种登录方式。"
          }
        }
      }
    },
    "auth.error.passkey_failed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Passkey authentication failed. Please try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "パスキー認証に失敗しました。もう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通行密钥认证失败，请重试。"
          }
        }
      }
    },
    "auth.error.rate_limit": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Too many attempts. Please wait a moment and try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "試行回数が多すぎます。少し待ってからもう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "尝试次数过多，请稍候片刻后重试。"
          }
        }
      }
    },
    "auth.error.server_error": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Something went wrong. Please try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "問題が発生しました。もう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "出了点问题，请重试。"
          }
        }
      }
    },
    "auth.error.unauthorized": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Session expired. Please sign in again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セッションの有効期限が切れました。もう一度サインインしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "会话已过期，请重新登录。"
          }
        }
      }
    },
    "auth.error.user_not_found": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No account found with this email."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このメールのアカウントは見つかりません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未找到使用此邮箱的账户。"
          }
        }
      }
    },
    "auth.error.wrong_password": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Incorrect email or password."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メールまたはパスワードが正しくありません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "邮箱或密码不正确。"
          }
        }
      }
    },
    "mobile.addDevice.accountHelp": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Manual pairing uses this account. If it does not match the Mac, scan a QR/link from the Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "手動ペアリングではこのアカウントを使用します。Mac と一致しない場合は、Mac から QR/リンクをスキャンしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "手动配对会使用此账户。如果它与该 Mac 上的账户不一致，请扫描 Mac 上的二维码/链接。"
          }
        }
      }
    },
    "mobile.addDevice.accountTitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This device"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このデバイス"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此设备"
          }
        }
      }
    },
    "mobile.addDevice.formAccessibilityLabel": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add device form"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイス追加フォーム"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加设备表单"
          }
        }
      }
    },
    "mobile.addDevice.help": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter a Tailscale, LAN, or local host and port. QR/link pairing from that computer is still the safest setup path."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale、LAN、またはローカルのホストとポートを入力してください。そのコンピュータからの QR/リンクでのペアリングが最も安全な設定方法です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "输入 Tailscale、局域网或本地主机和端口。从那台电脑扫描二维码/链接配对仍是最安全的设置方式。"
          }
        }
      }
    },
    "mobile.addDevice.hostLabel": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "HOST"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ホスト"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "主机"
          }
        }
      }
    },
    "mobile.addDevice.hostPlaceholder": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "your-mac.tailnet.ts.net"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "your-mac.tailnet.ts.net"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "your-mac.tailnet.ts.net"
          }
        }
      }
    },
    "mobile.addDevice.invalidHost": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter a host or IP address, without spaces or URL paths."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スペースや URL パスを含めず、ホストまたは IP アドレスを入力してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请输入主机或 IP 地址，不要包含空格或 URL 路径。"
          }
        }
      }
    },
    "mobile.addDevice.invalidPort": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter a port from 1 to 65535."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1 から 65535 までのポートを入力してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请输入 1 到 65535 之间的端口。"
          }
        }
      }
    },
    "mobile.addDevice.manualRouteWarning": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will connect directly to that address. Use this only on a trusted LAN, VPN, or device you control."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "そのアドレスへ直接接続します。信頼できる LAN、VPN、または管理しているデバイスでのみ使用してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将直接连接到该地址。请仅在受信任的局域网、VPN 或你掌控的设备上使用。"
          }
        }
      }
    },
    "mobile.addDevice.nameLabel": {
      "extractionState": "manual",
      "localizations": {

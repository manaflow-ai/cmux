          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Open het koppelvenster op je Mac en scan een nieuwe QR of link."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Otwórz okno parowania na Macu i zeskanuj nowy kod QR lub link."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",

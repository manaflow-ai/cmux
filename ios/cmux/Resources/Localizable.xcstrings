    "mobile.pairing.fail.offline": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Gerät scheint offline zu sein. Mit WLAN oder Mobilfunk verbinden, dann erneut versuchen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This device looks offline. Connect to Wi-Fi or cellular, then try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este dispositivo parece estar sin conexión. Conéctate a Wi-Fi o datos móviles e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cet appareil semble hors ligne. Connectez-vous au Wi-Fi ou au réseau cellulaire, puis réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo dispositivo sembra offline. Connettiti al Wi-Fi o alla rete cellulare, poi riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この端末はオフラインのようです。Wi-Fiまたはモバイルデータに接続してから、もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 기기가 오프라인인 것 같습니다. Wi-Fi 또는 셀룰러에 연결한 후 다시 시도하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit apparaat lijkt offline. Maak verbinding via Wi-Fi of mobiele data en probeer het opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "To urządzenie wygląda na offline. Połącz się z Wi-Fi lub siecią komórkową i spróbuj ponownie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este dispositivo parece estar offline. Conecte ao Wi-Fi ou à rede móvel e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это устройство выглядит офлайн. Подключитесь к Wi-Fi или сотовой сети и попробуйте снова."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu cihaz çevrimdışı görünüyor. Wi-Fi'ya veya hücresel ağa bağlanın, ardından tekrar deneyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此设备似乎已离线，请连接 Wi-Fi 或蜂窝网络后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此裝置似乎已離線。請連線至 Wi-Fi 或行動網路後再試。"
          }
        }
      }
    },
    "mobile.pairing.guidance.localNetwork": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einstellungen > cmux > Lokales Netzwerk, dann erneut versuchen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Settings > cmux > Local Network, then try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajustes > cmux > Red local, luego inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réglages > cmux > Réseau local, puis réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impostazioni > cmux > Rete locale, poi riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定 > cmux > ローカルネットワーク を開いてから、もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설정 > cmux > 로컬 네트워크로 이동한 후 다시 시도하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Instellingen > cmux > Lokaal netwerk, daarna opnieuw proberen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ustawienia > cmux > Sieć lokalna, a następnie spróbuj ponownie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajustes > cmux > Rede Local e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Настройки > cmux > Локальная сеть, затем попробуйте снова."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ayarlar > cmux > Yerel Ağ, ardından tekrar deneyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置 > cmux > 本地网络，然后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「設定」>「cmux」>「本機網路」，然後再試一次。"
          }
        }
      }
    },
    "mobile.pairing.guidance.openMacApp": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux auf dem Mac öffnen, dann QR-Code oder Link erneut scannen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open cmux on your Mac, then scan the QR or link from it again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre cmux en tu Mac y escanea el QR o el enlace de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrez cmux sur votre Mac, puis scannez à nouveau le QR ou le lien depuis celui-ci."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apri cmux sul tuo Mac, poi scansiona di nuovo il QR o il link da lì."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Macでcmuxを開いてから、そのQRコードまたはリンクをもう一度スキャンしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac에서 cmux를 열고 QR 또는 링크를 다시 스캔하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Open cmux op je Mac en scan dan de QR of link opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Otwórz cmux na Macu, a następnie zeskanuj ponownie kod QR lub link."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Abra o cmux no seu Mac e escaneie o QR ou link novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Откройте cmux на Mac, затем отсканируйте QR-код или ссылку с него снова."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac'inizde cmux'u açın, ardından QR veya bağlantıyı tekrar tarayın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Mac 上打开 cmux，然后重新扫描其中的二维码或链接。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Mac 上開啟 cmux，然後重新從 Mac 掃描 QR 碼或連結。"
          }
        }
      }
    },
    "mobile.pairing.guidance.reachability": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Prüfen, ob dieses iPhone und der Mac im selben WLAN sind oder beide Tailscale verwenden, der Mac aufgewacht ist und cmux darauf geöffnet ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Check that this phone and your Mac are on the same Wi-Fi or both running Tailscale, that the Mac is awake, and that cmux is open on it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comprueba que este iPhone y tu Mac están en la misma Wi-Fi o ambos ejecutan Tailscale, que el Mac está activo y que cmux está abierto en él."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vérifiez que ce téléphone et votre Mac sont sur le même Wi-Fi ou que Tailscale est actif sur les deux, que le Mac est éveillé et que cmux est ouvert."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Verifica che questo telefono e il tuo Mac siano sulla stessa rete Wi-Fi o che entrambi usino Tailscale, che il Mac sia attivo e che cmux sia aperto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このスマートフォンとMacが同じWi-Fi上にあるか、両方でTailscaleが動作していること、Macがスリープしていないこと、Macでcmuxが開いていることを確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 iPhone과 Mac이 같은 Wi-Fi에 있거나 둘 다 Tailscale을 실행 중인지, Mac이 깨어 있는지, Mac에서 cmux가 열려 있는지 확인하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Controleer of deze telefoon en je Mac op hetzelfde Wi-Fi zitten of dat beide Tailscale gebruiken, dat de Mac wakker is en cmux open heeft."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sprawdź, czy ten telefon i Twój Mac są w tej samej sieci Wi-Fi lub obaj korzystają z Tailscale, że Mac jest wybudzony i że cmux jest na nim otwarty."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Verifique se este telefone e seu Mac estão na mesma rede Wi-Fi ou ambos usando Tailscale, que o Mac está ativo e que o cmux está aberto."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Убедитесь, что телефон и Mac в одной сети Wi-Fi или оба в Tailscale, Mac не спит и cmux на нём открыт."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu telefonun ve Mac'inizin aynı Wi-Fi'da veya her ikisinin de Tailscale çalıştırdığından, Mac'in uyanık olduğundan ve cmux'un açık olduğundan emin olun."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请确认此手机与 Mac 在同一 Wi-Fi 下或均运行 Tailscale，Mac 已唤醒且 cmux 已打开。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請確認此手機與 Mac 在相同的 Wi-Fi 上，或兩台都執行 Tailscale，Mac 已喚醒，且 cmux 已在 Mac 上開啟。"
          }
        }
      }
    },
    "mobile.pairing.guidance.rescanFresh": {
      "extractionState": "manual",
      "localizations": {

    "mobile.onboarding.whatBody": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux führt Terminals und KI-Coding-Agenten auf dem Mac aus. Diese App ermöglicht es, sie zu beobachten, zu tippen und benachrichtigt zu werden, wenn ein Agent eine Eingabe benötigt – direkt vom iPhone."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux runs your terminals and AI coding agents on your Mac. This app lets you watch them, type, and get notified when an agent needs you, right from your phone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux ejecuta tus terminales y agentes de codificación IA en tu Mac. Esta app te permite verlos, escribir y recibir notificaciones cuando un agente te necesita, directamente desde tu iPhone."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux exécute vos terminaux et agents de code IA sur votre Mac. Cette application vous permet de les surveiller, de taper et d'être notifié quand un agent a besoin de vous, directement depuis votre téléphone."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux esegue i tuoi terminali e gli agenti AI sul tuo Mac. Questa app ti permette di guardarli, digitare e ricevere notifiche quando un agente ha bisogno di te, direttamente dal telefono."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "cmuxはMac上でターミナルとAIコーディングエージェントを動かします。このアプリを使えば、iPhoneからその様子を見たり、入力したり、エージェントから呼ばれたときに通知を受け取れます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux는 Mac에서 터미널과 AI 코딩 에이전트를 실행합니다. 이 앱으로 터미널을 보고, 입력하고, 에이전트가 필요로 할 때 알림을 받을 수 있습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux draait je terminals en AI-codeeragenten op je Mac. Met deze app kun je ze bekijken, typen en meldingen ontvangen wanneer een agent je nodig heeft, rechtstreeks vanaf je telefoon."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux uruchamia Twoje terminale i agentów AI na Macu. Ta aplikacja pozwala je obserwować, wpisywać tekst i otrzymywać powiadomienia, gdy agent potrzebuje Twojej uwagi, bezpośrednio z telefonu."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O cmux executa seus terminais e agentes de IA no seu Mac. Este app permite que você os acompanhe, digite e seja notificado quando um agente precisar de você, direto do seu celular."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux запускает терминалы и AI-агенты для написания кода на вашем Mac. Это приложение позволяет следить за ними, вводить команды и получать уведомления, когда агент требует внимания, прямо с телефона."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux, terminallerinizi ve AI kodlama ajanlarınızı Mac'inizde çalıştırır. Bu uygulama onları izlemenizi, yazmanızı ve bir ajan sizi gerektirdiğinde telefonunuzdan bildirim almanızı sağlar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux 在您的 Mac 上运行终端和 AI 编程 agent。此应用让您随时查看终端、输入内容，并在 agent 需要您时收到通知。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux 在您的 Mac 上執行終端機和 AI 程式碼代理。此應用程式讓您隨時查看終端機、輸入文字，並在代理需要您回應時收到通知，直接在手機上完成。"
          }
        }
      }
    },

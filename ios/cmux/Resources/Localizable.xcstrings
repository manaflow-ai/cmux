    "mobile.terminal.inputQueueFull": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The terminal can't accept more input right now. Wait a moment and retry, or reopen the terminal if it stays unavailable."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ターミナルは現在これ以上の入力を受け付けられません。しばらくしてから再試行するか、利用できない状態が続く場合はターミナルを開き直してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "终端目前无法接收更多输入。请稍候重试，若一直不可用，请重新打开终端。"
          }
        }
      }
    },

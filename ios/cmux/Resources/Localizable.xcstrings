    "mobile.signIn.restoringMessage": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gespeicherte Sitzung wird überprüft. Anmeldeoptionen sind pausiert, bis dieser Vorgang abgeschlossen ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Checking your saved session. Sign-in options are paused until this finishes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Verificando tu sesión guardada. Las opciones de inicio de sesión están en pausa hasta que esto finalice."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vérification de votre session enregistrée. Les options de connexion sont suspendues jusqu'à la fin de cette opération."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Verifica della sessione salvata in corso. Le opzioni di accesso sono in pausa fino al termine."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存済みセッションを確認しています。完了するまでサインイン操作は一時停止されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저장된 세션을 확인 중입니다. 완료될 때까지 로그인 옵션이 일시 중지됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uw opgeslagen sessie wordt gecontroleerd. Aanmeldopties zijn gepauzeerd totdat dit klaar is."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sprawdzanie zapisanej sesji. Opcje logowania są wstrzymane do czasu zakończenia."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Verificando sua sessão salva. As opções de login estão pausadas até que isso seja concluído."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проверка сохранённой сессии. Варианты входа недоступны до завершения."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kayıtlı oturumunuz kontrol ediliyor. Bu işlem bitene kadar giriş seçenekleri duraklatılmıştır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在检查已保存的会话，登录选项暂时暂停，请稍候。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "正在檢查您的已儲存工作階段。登入選項暫停，直到完成為止。"
          }
        }
      }
    },

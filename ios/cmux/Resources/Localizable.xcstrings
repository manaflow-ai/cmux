            "state": "translated",
            "value": "Enter a host or IP address, without spaces or URL paths."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Introduce un host o dirección IP, sin espacios ni rutas URL."
          }
        },
        "fr": {

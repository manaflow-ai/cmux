    "mobile.shortcuts.footer": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle, welche Tasten in der Terminal-Tastaturleiste erscheinen, und ziehe sie zum Neuanordnen. Modifikatortasten, Zoom und Einfügen können verschoben oder ausgeblendet werden. Eine benutzerdefinierte Aktion wischen zum Bearbeiten oder Löschen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose which buttons appear on the terminal keyboard bar, and drag to reorder them. The modifier keys, zoom, and paste can be moved or hidden along with the shortcuts. Swipe a custom action to edit or delete it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige qué botones aparecen en la barra del teclado del terminal y arrástralos para reordenarlos. Las teclas modificadoras, el zoom y el pegado se pueden mover u ocultar junto con los atajos. Desliza una acción personalizada para editarla o eliminarla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez les boutons qui apparaissent sur la barre de clavier du terminal et faites-les glisser pour les réorganiser. Les touches de modification, le zoom et le collage peuvent être déplacés ou masqués avec les raccourcis. Balayez une action personnalisée pour la modifier ou la supprimer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli quali pulsanti appaiono nella barra della tastiera del terminale e trascina per riordinarli. I tasti modificatori, lo zoom e incolla possono essere spostati o nascosti insieme alle scorciatoie. Scorri un'azione personalizzata per modificarla o eliminarla."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ターミナルのキーボードバーに表示するボタンを選び、ドラッグして並べ替えできます。修飾キー、ズーム、ペーストもショートカットと一緒に移動したり非表示にしたりできます。カスタムアクションはスワイプで編集または削除できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "터미널 키보드 바에 표시할 버튼을 선택하고 드래그하여 순서를 변경하세요. 수정자 키, 확대/축소, 붙여넣기도 이동하거나 숨길 수 있습니다. 사용자 설정 동작을 스와이프하면 편집하거나 삭제할 수 있습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies welke knoppen op de terminaaltoetsenbalklies verschijnen en sleep om ze te herordenen. De modificatietoetsen, zoom en plakken kunnen worden verplaatst of verborgen samen met de snelkoppelingen. Veeg over een aangepaste actie om deze te bewerken of te verwijderen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz, które przyciski pojawiają się na pasku klawiatury terminala, i przeciągnij, aby je zmienić kolejność. Klawisze modyfikatorów, zoom i wklejanie można przenosić lub ukrywać wraz ze skrótami. Przesuń akcję niestandardową, aby ją edytować lub usunąć."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha quais botões aparecem na barra de teclado do terminal e arraste para reordenar. As teclas modificadoras, zoom e colar podem ser movidos ou ocultados junto com os atalhos. Deslize uma ação personalizada para editá-la ou excluí-la."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите кнопки на панели клавиатуры терминала и перетащите их для изменения порядка. Клавиши-модификаторы, масштаб и вставку можно перемещать или скрывать вместе с ярлыками. Проведите по кастомному действию для редактирования или удаления."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Terminal klavye çubuğunda hangi düğmelerin görüneceğini seçin ve sıralamak için sürükleyin. Değiştirici tuşlar, yakınlaştırma ve yapıştırma, kısayollarla birlikte taşınabilir veya gizlenebilir. Özel eylemi düzenlemek veya silmek için kaydırın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择在终端键盘栏显示的按钮并拖动排序。修饰键、缩放和粘贴可移动或隐藏，自定义操作可左滑编辑或删除。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇終端機鍵盤列上顯示的按鈕，並拖曳以重新排序。修飾鍵、縮放和貼上也可移動或隱藏。向左滑動自訂動作可編輯或刪除。"
          }
        }
      }
    },

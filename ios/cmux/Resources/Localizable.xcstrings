    "mobile.onboarding.pairBody": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sicherstellen, dass cmux auf dem Mac mit demselben Konto angemeldet ist, dann den QR-Code scannen (oder Adresse manuell eingeben). Dies muss pro Mac nur einmal durchgeführt werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Make sure cmux on your Mac is signed in to the same account, then scan the pairing QR code it shows (or enter its address by hand). You only do this once per Mac."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Asegúrate de que cmux en tu Mac tiene iniciada sesión en la misma cuenta y escanea el código QR de emparejamiento que muestra (o introduce su dirección a mano). Solo tienes que hacerlo una vez por Mac."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Assurez-vous que cmux sur votre Mac est connecté au même compte, puis scannez le QR de jumelage qu'il affiche (ou entrez son adresse manuellement). Vous ne le faites qu'une seule fois par Mac."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Assicurati che cmux sul tuo Mac sia connesso allo stesso account, poi scansiona il QR code di abbinamento che mostra (o inserisci il suo indirizzo manualmente). Lo fai una sola volta per Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac版cmuxが同じアカウントでサインインしていることを確認し、表示されるペアリングQRコードを読み取ってください（またはアドレスを手入力します）。これはMacごとに一度だけ行います。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac의 cmux가 같은 계정으로 로그인되어 있는지 확인한 후, 표시된 페어링 QR 코드를 스캔하거나 주소를 직접 입력하세요. Mac당 한 번만 설정하면 됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zorg dat cmux op je Mac is aangemeld bij hetzelfde account en scan dan de QR-koppelcode die hij toont (of voer het adres handmatig in). Dit doe je slechts één keer per Mac."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Upewnij się, że cmux na Macu jest zalogowany na to samo konto, a następnie zeskanuj wyświetlany kod QR parowania (lub ręcznie podaj adres). Robisz to tylko raz na każdego Maca."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Certifique-se de que o cmux no seu Mac está conectado à mesma conta e escaneie o QR de pareamento exibido (ou insira o endereço manualmente). Você faz isso apenas uma vez por Mac."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Убедитесь, что в cmux на Mac выполнен вход в тот же аккаунт, затем отсканируйте QR-код сопряжения (или введите адрес вручную). Это нужно сделать только один раз для каждого Mac."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac'inizdeki cmux'un aynı hesapla oturum açtığından emin olun, ardından gösterdiği eşleştirme QR kodunu tarayın (veya adresini elle girin). Bunu her Mac için yalnızca bir kez yapmanız gerekir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确保 Mac 上的 cmux 已用同一账号登录，然后扫描其显示的配对二维码（或手动输入地址）。每台 Mac 只需配对一次。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "確認 Mac 上的 cmux 已登入相同帳號，然後掃描 Mac 上顯示的配對 QR 碼（或手動輸入位址）。每台 Mac 只需完成一次配對。"
          }
        }
      }
    },

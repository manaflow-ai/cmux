  "strings" : {
    "mobile.addDevice.formAccessibilityLabel" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Add device form" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "デバイス追加フォーム" } }

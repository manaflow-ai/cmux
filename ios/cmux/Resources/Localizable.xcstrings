    "mobile.hostPicker.footer": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle, welchen Mac dieses Gerät steuert. Weitere Macs koppeln behält die anderen, damit du zwischen ihnen wechseln kannst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Switch which Mac this device controls. Pairing another Mac keeps the others, so you can hop between them."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambia qué Mac controla este dispositivo. Emparejar otro Mac mantiene los demás, para que puedas alternar entre ellos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Changez le Mac que cet appareil contrôle. Jumeler un autre Mac conserve les autres, vous pouvez ainsi passer de l'un à l'autre."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambia quale Mac controlla questo dispositivo. Aggiungere un altro Mac mantiene gli altri, così puoi passare da uno all'altro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このデバイスが操作するMacを切り替えます。別のMacをペアリングしても他のMacは保持されるので、行き来できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 기기가 제어할 Mac을 전환하세요. 다른 Mac을 페어링해도 기존 Mac은 유지되므로 자유롭게 전환할 수 있습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wissel van Mac die dit apparaat bestuurt. Door een andere Mac te koppelen blijven de andere behouden, zodat je ertussen kunt wisselen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przełącz, którym Macem steruje to urządzenie. Sparowanie kolejnego Maca zachowuje pozostałe, dzięki czemu możesz przełączać się między nimi."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Alterne qual Mac este dispositivo controla. Parear outro Mac mantém os demais, para que você possa alternar entre eles."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите, каким Mac управляет это устройство. Добавление нового Mac не удаляет остальные."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu cihazın hangi Mac'i kontrol ettiğini değiştirin. Başka bir Mac eşleştirmek diğerlerini korur, böylece aralarında geçiş yapabilirsiniz."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "切换此设备控制的 Mac。配对其他 Mac 不会移除现有配对，可自由切换。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "切換此裝置所控制的 Mac。配對新 Mac 不會移除現有的 Mac，您可以隨時切換。"
          }
        }
      }
    },

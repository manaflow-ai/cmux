{
  "sourceLanguage": "en",
  "strings": {
    "auth.error.apple_config": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple-Anmeldung ist noch nicht verfügbar. Bitte verwende eine andere Anmeldemethode."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Sign In is not available yet. Please use another sign-in method."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El inicio de sesión con Apple aún no está disponible. Por favor, usa otro método."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La connexion avec Apple n'est pas encore disponible. Veuillez utiliser une autre méthode de connexion."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Accesso con Apple non è ancora disponibile. Usa un altro metodo di accesso."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple でのサインインはまだ利用できません。別のサインイン方法を使用してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 로그인을 아직 사용할 수 없습니다. 다른 로그인 방법을 사용해 주세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Sign In is nog niet beschikbaar. Gebruik een andere aanmeldmethode."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Logowanie przez Apple nie jest jeszcze dostępne. Użyj innej metody logowania."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Login com Apple ainda não está disponível. Use outro método de entrada."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вход через Apple пока недоступен. Используйте другой способ входа."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple ile Giriş henüz kullanılabilir değil. Lütfen başka bir giriş yöntemi kullanın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 登录暂不可用，请使用其他登录方式。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 登入目前無法使用。請使用其他登入方式。"
          }
        }
      }
    },
    "auth.error.browser_sign_in_failed": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Browser-Anmeldung konnte nicht abgeschlossen werden. Erneut versuchen oder Anmeldung im Browser öffnen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not complete browser sign-in. Try again or open sign-in in your browser."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo completar el inicio de sesión en el navegador. Inténtalo de nuevo o abre el inicio de sesión en tu navegador."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de terminer la connexion via le navigateur. Réessayez ou ouvrez la connexion dans votre navigateur."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile completare l'accesso tramite browser. Riprova o apri l'accesso nel browser."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブラウザでのサインインを完了できませんでした。もう一度試すか、ブラウザでサインインを開いてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "브라우저 로그인을 완료할 수 없습니다. 다시 시도하거나 브라우저에서 로그인을 여세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aanmelden via browser is mislukt. Probeer het opnieuw of open de aanmeldpagina in je browser."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie udało się zalogować przez przeglądarkę. Spróbuj ponownie lub otwórz logowanie w przeglądarce."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível concluir o login pelo navegador. Tente novamente ou abra o login no seu navegador."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось завершить вход через браузер. Попробуйте ещё раз или откройте страницу входа в браузере."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tarayıcı girişi tamamlanamadı. Tekrar deneyin veya girişi tarayıcınızda açın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "浏览器登录失败，请重试或在浏览器中打开登录页面。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法完成瀏覽器登入。請再試一次，或在瀏覽器中開啟登入頁面。"
          }
        }
      }
    },
    "auth.error.code_expired": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Code abgelaufen. Bitte fordere einen neuen an."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Code expired. Please request a new one."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El código ha expirado. Por favor, solicita uno nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Code expiré. Veuillez en demander un nouveau."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Codice scaduto. Richiedine uno nuovo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コードの有効期限が切れました。新しいコードをリクエストしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "코드가 만료되었습니다. 새 코드를 요청해 주세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Code verlopen. Vraag een nieuwe aan."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kod wygasł. Poproś o nowy."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Código expirado. Solicite um novo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Код истёк. Запросите новый."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kod süresi doldu. Lütfen yeni bir tane isteyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "验证码已过期，请重新获取。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "驗證碼已過期。請重新申請。"
          }
        }
      }
    },
    "auth.error.config": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Anmeldung vorübergehend nicht verfügbar. Bitte später erneut versuchen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign in is temporarily unavailable. Please try again later."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El inicio de sesión no está disponible temporalmente. Inténtalo de nuevo más tarde."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La connexion est temporairement indisponible. Veuillez réessayer plus tard."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accesso è temporaneamente non disponibile. Riprova più tardi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サインインは一時的に利用できません。しばらくしてからもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로그인을 일시적으로 사용할 수 없습니다. 나중에 다시 시도해 주세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aanmelden is tijdelijk niet beschikbaar. Probeer het later opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Logowanie jest tymczasowo niedostępne. Spróbuj ponownie później."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O login está temporariamente indisponível. Tente novamente mais tarde."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вход временно недоступен. Попробуйте позже."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Giriş geçici olarak kullanılamıyor. Lütfen daha sonra tekrar deneyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "登录暂时不可用，请稍后再试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "登入暫時無法使用。請稍後再試。"
          }
        }
      }
    },
    "auth.error.email_exists": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Konto mit dieser E-Mail-Adresse existiert bereits. Versuche dich stattdessen anzumelden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An account with this email already exists. Try signing in instead."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ya existe una cuenta con este correo electrónico. Intenta iniciar sesión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un compte avec cette adresse e-mail existe déjà. Essayez de vous connecter à la place."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esiste già un account con questa email. Prova ad accedere invece."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このメールのアカウントはすでに存在します。サインインを試してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 이메일로 이미 계정이 있습니다. 로그인을 시도해 보세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er bestaat al een account met dit e-mailadres. Probeer in te loggen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Konto z tym adresem e-mail już istnieje. Spróbuj się zalogować."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Já existe uma conta com este e-mail. Tente fazer login."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Аккаунт с этим адресом уже существует. Войдите вместо регистрации."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu e-posta adresiyle zaten bir hesap var. Bunun yerine giriş yapmayı deneyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该邮箱已有账号，请直接登录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此電子郵件已有帳號。請改為登入。"
          }
        }
      }
    },
    "auth.error.generic": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Etwas ist schiefgelaufen. Bitte erneut versuchen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Something went wrong. Please try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Algo salió mal. Por favor, inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une erreur s'est produite. Veuillez réessayer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Qualcosa è andato storto. Riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "問題が発生しました。もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "문제가 발생했습니다. 다시 시도해 주세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er is iets misgegaan. Probeer het opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Coś poszło nie tak. Spróbuj ponownie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Algo deu errado. Tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Что-то пошло не так. Попробуйте ещё раз."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir şeyler ters gitti. Lütfen tekrar deneyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "出错了，请重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "發生錯誤。請再試一次。"
          }
        }
      }
    },
    "auth.error.invalid_callback": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Anmelde-Callback war ungültig. Erneut anmelden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The sign-in callback was invalid. Try signing in again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La devolución de llamada del inicio de sesión no era válida. Intenta iniciar sesión de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le rappel de connexion était invalide. Essayez de vous connecter à nouveau."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il callback di accesso non era valido. Prova ad accedere di nuovo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サインインコールバックが無効です。もう一度サインインしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로그인 콜백이 유효하지 않습니다. 다시 로그인해 주세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De aanmeld-callback was ongeldig. Probeer opnieuw in te loggen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wywołanie zwrotne logowania było nieprawidłowe. Spróbuj zalogować się ponownie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O retorno do login era inválido. Tente fazer login novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Недействительный обратный вызов при входе. Попробуйте войти снова."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Giriş geri çağrısı geçersizdi. Tekrar giriş yapmayı deneyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "登录回调无效，请重新登录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "登入回呼無效。請重新登入。"
          }
        }
      }
    },
    "auth.error.invalid_code": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ungültiger Code. Bitte prüfen und erneut versuchen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid code. Please check and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Código no válido. Compruébalo e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Code invalide. Veuillez vérifier et réessayer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Codice non valido. Controlla e riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コードが無効です。確認してもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "잘못된 코드입니다. 확인 후 다시 시도해 주세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ongeldige code. Controleer de code en probeer het opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nieprawidłowy kod. Sprawdź i spróbuj ponownie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Código inválido. Verifique e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Неверный код. Проверьте и попробуйте ещё раз."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Geçersiz kod. Lütfen kontrol edip tekrar deneyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "验证码无效，请检查后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "驗證碼無效。請確認後再試。"
          }
        }
      }
    },
    "auth.error.invalid_code_short": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {

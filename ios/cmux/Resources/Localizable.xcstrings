    "mobile.onboarding.tailscaleStep2": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beide mit demselben Tailscale-Konto anmelden, damit sie ein Tailnet teilen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign both in to the same Tailscale account so they share one tailnet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicia sesión en ambos con la misma cuenta de Tailscale para que compartan una tailnet."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Connectez les deux au même compte Tailscale pour qu'ils partagent un tailnet."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Connetti entrambi allo stesso account Tailscale così condividono una tailnet."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "両方を同じTailscaleアカウントでサインインし、同じtailnetを共有させます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "같은 Tailscale 계정으로 둘 다 로그인하여 하나의 tailnet을 공유하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Meld beide aan bij hetzelfde Tailscale-account zodat ze één tailnet delen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaloguj oba urządzenia na to samo konto Tailscale, aby współdzieliły jedną sieć tailnet."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Faça login em ambos com a mesma conta Tailscale para compartilharem uma tailnet."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Войдите на обоих в один аккаунт Tailscale, чтобы они оказались в одном tailnet."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tek bir tailnet paylaşmaları için her ikisini de aynı Tailscale hesabına giriş yaptırın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "两者登录同一 Tailscale 账号，共享同一 tailnet。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在兩台裝置上登入相同的 Tailscale 帳號，讓它們共享同一個 tailnet。"
          }
        }
      }
    },
    "mobile.onboarding.tailscaleStep3": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beide auch mit demselben cmux-Konto angemeldet lassen. Die Kopplung prüft, ob sie übereinstimmen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep both signed in to the same cmux account too. Pairing checks that they match."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén ambos con sesión iniciada en la misma cuenta de cmux también. El emparejamiento verifica que coincidan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gardez les deux connectés au même compte cmux également. Le jumelage vérifie qu'ils correspondent."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantieni entrambi connessi allo stesso account cmux. L'abbinamento verifica che corrispondano."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "両方を同じcmuxアカウントでもサインインしておきます。ペアリング時に一致を確認します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "둘 다 같은 cmux 계정으로도 로그인 상태를 유지하세요. 페어링 시 일치 여부를 확인합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Houd beide ook aangemeld bij hetzelfde cmux-account. Bij koppelen wordt gecontroleerd of ze overeenkomen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zadbaj, aby oba były zalogowane na to samo konto cmux. Parowanie sprawdza, czy się zgadzają."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenha ambos conectados à mesma conta cmux também. O pareamento verifica se coincidem."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Также оставайтесь авторизованными в одном аккаунте cmux. Сопряжение проверяет совпадение."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her ikisini de aynı cmux hesabına giriş yaptırın. Eşleştirme, eşleştiklerini doğrular."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "同时保持两者登录同一 cmux 账号，配对时会验证是否一致。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "同時在兩台裝置上保持登入相同的 cmux 帳號。配對時會驗證帳號是否一致。"
          }
        }
      }
    },

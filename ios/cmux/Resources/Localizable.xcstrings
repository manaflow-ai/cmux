        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 앱에 표시되는 Stack 팀의 Mac 및 기기를 전환합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Schakelt welk Stack-team zijn Macs en apparaten deze app toont."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przełącza, które Maki i urządzenia zespołu Stack wyświetla ta aplikacja."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Altera qual equipe do Stack tem seus Macs e dispositivos exibidos neste app."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Переключает, Mac и устройства какой команды Stack отображает это приложение."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu uygulamanın gösterdiği Stack takımının Mac'lerini ve cihazlarını değiştirir."

    "mobile.tailscale.disconnectedHelp": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Mac könnte nicht erreichbar sein, weil Tailscale hier deaktiviert ist. Einschalten, dann erneut versuchen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your Mac may be unreachable because Tailscale is off here. Turn it on, then try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Es posible que tu Mac no sea accesible porque Tailscale está desactivado aquí. Actívalo e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre Mac est peut-être inaccessible car Tailscale est désactivé ici. Activez-le, puis réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo Mac potrebbe non essere raggiungibile perché Tailscale è disattivato qui. Attivalo e riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このデバイスで Tailscale がオフのため、Mac に接続できない可能性があります。Tailscale をオンにしてから、もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "여기서 Tailscale이 꺼져 있어 Mac에 접근할 수 없을 수 있습니다. 켠 다음 다시 시도하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je Mac is mogelijk niet bereikbaar omdat Tailscale hier is uitgeschakeld. Schakel het in en probeer het opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twój Mac może być nieosiągalny, ponieważ Tailscale jest tu wyłączony. Włącz go i spróbuj ponownie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu Mac pode estar inacessível porque o Tailscale está desativado aqui. Ative-o e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac может быть недоступен, потому что Tailscale отключён здесь. Включите его и попробуйте снова."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Burada Tailscale kapalı olduğundan Mac'e ulaşılamıyor olabilir. Açın, ardından tekrar deneyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的 Mac 可能不可访问，因为此设备的 Tailscale 已关闭。请先开启，然后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "您的 Mac 可能無法連線，因為此裝置的 Tailscale 已關閉。請開啟後再試一次。"
          }
        }
      }
    },

    "mobile.setupHelp.intro": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Um Mac-Terminals hier zu sehen, müssen vier Dinge übereinstimmen. Der aktuelle Schritt ist unten markiert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To see your Mac's terminals here, four things have to line up. The step you are on is marked below."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Para ver los terminales de tu Mac aquí, cuatro cosas deben estar en orden. El paso en el que te encuentras está marcado a continuación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour voir les terminaux de votre Mac ici, quatre éléments doivent être alignés. L'étape où vous en êtes est indiquée ci-dessous."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per vedere i terminali del tuo Mac qui, quattro cose devono essere allineate. Il passaggio in cui ti trovi è indicato di seguito."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ここでMacのターミナルを表示するには、4つの条件がそろう必要があります。今いるステップは下に印が付いています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac의 터미널을 여기서 보려면 네 가지가 맞아야 합니다. 현재 단계가 아래에 표시됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Om de terminals van je Mac hier te zien, moeten vier dingen kloppen. De stap waar je bent is hieronder gemarkeerd."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aby zobaczyć terminale Maca tutaj, cztery rzeczy muszą być spełnione. Krok, na którym jesteś, jest oznaczony poniżej."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Para ver os terminais do seu Mac aqui, quatro coisas precisam estar alinhadas. O passo em que você está é indicado abaixo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Чтобы здесь были видны терминалы Mac, необходимо выполнить четыре условия. Текущий шаг отмечен ниже."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac'inizin terminallerini burada görmek için dört şeyin birbirine uyması gerekir. Bulunduğunuz adım aşağıda işaretlenmiştir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "要在此处查看 Mac 终端，需要满足四个条件，您当前所在步骤已在下方标注。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "若要在此查看 Mac 的終端機，需要四件事齊備。您目前所在的步驟已在下方標示。"
          }
        }
      }
    },

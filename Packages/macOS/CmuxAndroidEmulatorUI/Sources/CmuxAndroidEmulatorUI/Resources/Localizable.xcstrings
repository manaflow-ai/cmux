{
  "sourceLanguage": "en",
  "strings": {
    "androidEmulator.action.dismiss": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Dismiss" } },
        "ja": { "stringUnit": { "state": "translated", "value": "閉じる" } }
      }
    },
    "androidEmulator.action.launch": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Launch" } },
        "ja": { "stringUnit": { "state": "translated", "value": "起動" } }
      }
    },
    "androidEmulator.action.refresh": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Refresh" } },
        "ja": { "stringUnit": { "state": "translated", "value": "更新" } }
      }
    },
    "androidEmulator.action.stop": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Stop" } },
        "ja": { "stringUnit": { "state": "translated", "value": "停止" } }
      }
    },
    "androidEmulator.empty.detail": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Create an Android Virtual Device in Android Studio, then refresh." } },
        "ja": { "stringUnit": { "state": "translated", "value": "Android StudioでAndroid仮想デバイスを作成してから、更新してください。" } }
      }
    },
    "androidEmulator.empty.title": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "No Android Virtual Devices" } },
        "ja": { "stringUnit": { "state": "translated", "value": "Android仮想デバイスがありません" } }
      }
    },
    "androidEmulator.error.adbMissing.detail": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "The SDK at %@ does not contain Android Debug Bridge." } },
        "ja": { "stringUnit": { "state": "translated", "value": "%@ のSDKにAndroid Debug Bridgeが含まれていません。" } }
      }
    },
    "androidEmulator.error.avdNotFound.detail": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "The AVD “%@” is no longer available. Refresh the list." } },
        "ja": { "stringUnit": { "state": "translated", "value": "AVD「%@」は利用できなくなりました。一覧を更新してください。" } }
      }
    },
    "androidEmulator.error.command.detail": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "%@ failed: %@" } },
        "ja": { "stringUnit": { "state": "translated", "value": "%@ に失敗しました: %@" } }
      }
    },
    "androidEmulator.error.command.title": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Android Emulator Unavailable" } },
        "ja": { "stringUnit": { "state": "translated", "value": "Android Emulatorを利用できません" } }
      }
    },
    "androidEmulator.error.emulatorMissing.detail": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "The SDK at %@ does not contain the emulator component." } },
        "ja": { "stringUnit": { "state": "translated", "value": "%@ のSDKにemulatorコンポーネントが含まれていません。" } }
      }
    },
    "androidEmulator.error.emulatorMissing.title": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Android Emulator Not Installed" } },
        "ja": { "stringUnit": { "state": "translated", "value": "Android Emulatorがインストールされていません" } }
      }
    },
    "androidEmulator.error.invalidSerial.detail": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Refused to stop the invalid emulator serial “%@”." } },
        "ja": { "stringUnit": { "state": "translated", "value": "無効なエミュレータシリアル「%@」の停止を拒否しました。" } }
      }
    },
    "androidEmulator.error.launch.detail": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "The vendor emulator could not launch: %@" } },
        "ja": { "stringUnit": { "state": "translated", "value": "ベンダーのエミュレータを起動できませんでした: %@" } }
      }
    },
    "androidEmulator.error.sdkNotFound.detail": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "cmux checked ANDROID_HOME, ANDROID_SDK_ROOT, and ~/Library/Android/sdk." } },
        "ja": { "stringUnit": { "state": "translated", "value": "cmuxはANDROID_HOME、ANDROID_SDK_ROOT、~/Library/Android/sdkを確認しました。" } }
      }
    },
    "androidEmulator.error.sdkNotFound.title": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Android SDK Not Found" } },
        "ja": { "stringUnit": { "state": "translated", "value": "Android SDKが見つかりません" } }
      }
    },
    "androidEmulator.install.detail": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Install Android Studio or the Android SDK command-line tools, create an AVD, then refresh." } },
        "ja": { "stringUnit": { "state": "translated", "value": "Android StudioまたはAndroid SDKコマンドラインツールをインストールし、AVDを作成してから更新してください。" } }
      }
    },
    "androidEmulator.sdkPath": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "SDK:" } },
        "ja": { "stringUnit": { "state": "translated", "value": "SDK:" } }
      }
    },
    "androidEmulator.status.launching": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Launching…" } },
        "ja": { "stringUnit": { "state": "translated", "value": "起動中…" } }
      }
    },
    "androidEmulator.status.running": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Running · %@ · %@" } },
        "ja": { "stringUnit": { "state": "translated", "value": "実行中 · %@ · %@" } }
      }
    },
    "androidEmulator.status.stopped": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Stopped" } },
        "ja": { "stringUnit": { "state": "translated", "value": "停止中" } }
      }
    },
    "androidEmulator.status.stopping": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Stopping…" } },
        "ja": { "stringUnit": { "state": "translated", "value": "停止処理中…" } }
      }
    },
    "androidEmulator.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Uses Android tools already installed on this Mac." } },
        "ja": { "stringUnit": { "state": "translated", "value": "このMacにインストール済みのAndroidツールを使用します。" } }
      }
    },
    "androidEmulator.title": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Android Emulators" } },
        "ja": { "stringUnit": { "state": "translated", "value": "Androidエミュレータ" } }
      }
    },
    "androidEmulator.warning.adbFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Could not read running devices from adb: %@" } },
        "ja": { "stringUnit": { "state": "translated", "value": "adbから実行中のデバイスを読み取れませんでした: %@" } }
      }
    },
    "androidEmulator.warning.adbMissing": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Android Debug Bridge is not installed. cmux can launch AVDs but cannot show or stop running devices." } },
        "ja": { "stringUnit": { "state": "translated", "value": "Android Debug Bridgeがインストールされていません。cmuxはAVDを起動できますが、実行中のデバイスの表示や停止はできません。" } }
      }
    }
  },
  "version": "1.0"
}

    "browser.import.destinationProfile.create": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create \"%@\""
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" を作成"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Створити \"%@\""
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" 생성"

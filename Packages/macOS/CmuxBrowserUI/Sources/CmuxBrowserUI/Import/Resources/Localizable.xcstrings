    "browser.import.destinationProfile.mergeHelp": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All selected source profiles go into one cmux profile."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択した元プロファイルは、1つの cmux プロファイルにまとめて取り込まれます。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Усі вибрані вихідні профілі об'єднуються в один профіль cmux."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 모든 원본 프로필이 하나의 cmux 프로필로 합쳐집니다."
          }
        }
      }
    },
    "browser.import.destinationProfile.separateHelp": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Missing cmux profiles are created on import."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "不足している cmux プロファイルは、インポート時に作成されます。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Відсутні профілі cmux створюються під час імпорту."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "없는 cmux 프로필은 가져오기 시 자동으로 생성됩니다."
          }
        }
      }
    },

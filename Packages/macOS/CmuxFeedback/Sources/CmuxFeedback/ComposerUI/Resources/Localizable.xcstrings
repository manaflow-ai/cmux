    "sidebar.help.feedback.connectionError": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't send feedback. Check your connection and try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フィードバックを送信できませんでした。接続を確認して、もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "피드백을 보내지 못했습니다. 연결을 확인하고 다시 시도하세요."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Не вдалося надіслати відгук. Перевірте підключення та спробуйте ще раз."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法发送反馈。请检查网络连接后重试。"
          }
        }
      }
    },
    "sidebar.help.feedback.done": {
      "extractionState": "manual",
      "localizations": {

    "sidebar.help.feedback.cancel": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancel"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キャンセル"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "취소"
          }
        },
        "uk": {
          "stringUnit": {

    "sidebar.help.feedback.emptyMessage": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter a message before sending."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "送信する前にメッセージを入力してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "보내기 전에 메시지를 입력하세요."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Введіть повідомлення перед надсиланням."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "发送前请输入消息。"
          }
        }
      }
    },
    "sidebar.help.feedback.endpointError": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Feedback is unavailable right now. Email founders@manaflow.com instead."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在フィードバックを送信できません。代わりに founders@manaflow.com までメールしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 피드백을 사용할 수 없습니다. 대신 founders@manaflow.com으로 이메일을 보내주세요."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Відгуки зараз недоступні. Напишіть на founders@manaflow.com."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "反馈功能当前不可用。请改为发送邮件至 founders@manaflow.com。"
          }
        }
      }
    },
    "sidebar.help.feedback.genericError": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't send feedback. Please try again."

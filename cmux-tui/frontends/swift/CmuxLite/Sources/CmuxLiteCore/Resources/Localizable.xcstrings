      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Unix socket closed" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "Unix ソケットが閉じられました" } }
      }
    },
    "transport.state.unix_no_data" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Unix socket receive completed without data" } },

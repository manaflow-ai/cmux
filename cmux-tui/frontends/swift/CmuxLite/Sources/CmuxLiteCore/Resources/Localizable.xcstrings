      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Inbound JSON line is not UTF-8" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "受信した JSON 行は UTF-8 ではありません" } }
      }
    },
    "transport.payload.outbound_not_utf8" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Outbound JSON is not UTF-8" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "送信する JSON は UTF-8 ではありません" } }
      }
    },

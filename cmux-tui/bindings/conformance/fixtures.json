{
  "defaults": { "timeout_ms": 5000 },
  "fixtures": [
    {
      "name": "identify",
      "steps": [
        {
          "type": "command",
          "request": { "id": 1, "cmd": "identify" },
          "expect": { "id": 1, "ok": true, "data": { "app": "cmux-tui", "protocol": 8 } },
          "match": "partial"
        }
      ]
    },
    {
      "name": "process-info-argv-and-tty",
      "steps": [
        {
          "type": "command",
          "request": { "id": 1, "cmd": "new-workspace", "name": "conf-process-info", "cols": 80, "rows": 24 },
          "expect": { "id": 1, "ok": true },
          "match": "partial",
          "bind": { "process_surface": "data.surface" }
        },
        {
          "type": "command",
          "request": { "id": 2, "cmd": "process-info", "surface": "$process_surface" },
          "expect": { "id": 2, "ok": true },
          "match": "partial",
          "bind": {
            "process_pid": "data.pid",
            "process_argv0": "data.command[0]",
            "process_cwd": "data.cwd",
            "process_tty": "data.tty"
          }
        },
        {
          "type": "command",
          "request": { "id": 3, "cmd": "process-info", "surface": "$process_surface" },
          "expect": {
            "id": 3,
            "ok": true,
            "data": {
              "pid": "$process_pid",
              "command": ["$process_argv0"],
              "cwd": "$process_cwd",
              "tty": "$process_tty"
            }
          },
          "match": "exact"
        }
      ]
    },
    {
      "name": "server-client-control",
      "steps": [
        {
          "type": "command",
          "request": { "id": 1, "cmd": "identify" },
          "expect": { "id": 1, "ok": true, "data": { "app": "cmux-tui", "protocol": 8 } },
          "match": "partial",
          "bind": {
            "version": "data.version",
            "protocol": "data.protocol",
            "protocol_min": "data.protocol_min",
            "protocol_max": "data.protocol_max",
            "capabilities": "data.capabilities",
            "session": "data.session",
            "session_id": "data.session_id",
            "daemon_instance_id": "data.daemon_instance_id",
            "legacy_revision": "data.topology_revision",
            "canonical_revision": "data.canonical_topology_revision",
            "pid": "data.pid"
          }
        },
        {
          "type": "command",
          "request": { "id": 2, "cmd": "ping" },
          "expect": {
            "id": 2,
            "ok": true,
            "data": {
              "ok": true,
              "version": "$version",
              "protocol": "$protocol",
              "protocol_min": "$protocol_min",
              "protocol_max": "$protocol_max",
              "capabilities": "$capabilities",
              "session": "$session",
              "session_id": "$session_id",
              "daemon_instance_id": "$daemon_instance_id",
              "topology_revision": "$legacy_revision",
              "canonical_topology_revision": "$canonical_revision",
              "pid": "$pid"
            }
          },
          "match": "exact"
        },
        {
          "type": "command",
          "request": { "id": 3, "cmd": "set-window-title", "title": "cmux-conformance" },
          "expect": { "id": 3, "ok": true, "data": {} },
          "match": "exact"
        },
        {
          "type": "command",
          "request": { "id": 4, "cmd": "clear-window-title" },
          "expect": { "id": 4, "ok": true, "data": {} },
          "match": "exact"
        }
      ]
    },
    {
      "name": "protocol-v8-topology-resume-and-presentations",
      "steps": [
        {
          "type": "command",
          "request": { "id": 1, "cmd": "new-workspace", "name": "conf-v8", "cols": 80, "rows": 24 },
          "expect": { "id": 1, "ok": true },
          "match": "partial"
        },
        {
          "type": "command",
          "request": { "id": 2, "cmd": "topology-snapshot" },
          "expect": {
            "id": 2,
            "ok": true,
            "data": {
              "revision": 1,
              "topology": { "workspaces": [{ "name": "conf-v8" }] }
            }
          },
          "match": "partial",
          "bind": {
            "daemon_instance_id": "data.daemon_instance_id",
            "session_id": "data.session_id",
            "revision": "data.revision",
            "workspace_id": "data.topology.workspaces[0].id",
            "workspace_uuid": "data.topology.workspaces[0].uuid",
            "screen_id": "data.topology.workspaces[0].screens[0].id",
            "screen_uuid": "data.topology.workspaces[0].screens[0].uuid",
            "pane_id": "data.topology.workspaces[0].screens[0].panes[0].id",
            "pane_uuid": "data.topology.workspaces[0].screens[0].panes[0].uuid",
            "surface_id": "data.topology.workspaces[0].screens[0].panes[0].tabs[0].id",
            "surface_uuid": "data.topology.workspaces[0].screens[0].panes[0].tabs[0].uuid"
          }
        },
        {
          "type": "command",
          "request": {
            "id": 3,
            "cmd": "open-presentation",
            "view": {
              "workspace_uuid": "$workspace_uuid",
              "screen_uuid": "$screen_uuid",
              "pane_uuid": "$pane_uuid",
              "surface_uuid": "$surface_uuid"
            }
          },
          "expect": {
            "id": 3,
            "ok": true,
            "data": {
              "generation": 1,
              "view": {
                "workspace": "$workspace_id",
                "workspace_uuid": "$workspace_uuid",
                "screen": "$screen_id",
                "screen_uuid": "$screen_uuid",
                "pane": "$pane_id",
                "pane_uuid": "$pane_uuid",
                "tab": "$surface_id",
                "surface_uuid": "$surface_uuid"
              },
              "zoom": { "pane": null, "pane_uuid": null },
              "scroll": { "surface": null, "surface_uuid": null, "offset": 0 }
            }
          },
          "match": "partial",
          "bind": {
            "presentation_id": "data.presentation_id",
            "presentation_client": "data.client"
          }
        },
        {
          "type": "command",
          "request": {
            "id": 4,
            "cmd": "update-presentation",
            "presentation_id": "$presentation_id",
            "expected_generation": 1,
            "view": {
              "workspace_uuid": "$workspace_uuid",
              "screen_uuid": "$screen_uuid",
              "pane_uuid": "$pane_uuid",
              "surface_uuid": "$surface_uuid"
            }
          },
          "expect": {
            "id": 4,
            "ok": true,
            "data": {
              "presentation_id": "$presentation_id",
              "generation": 1,
              "client": "$presentation_client",
              "view": {
                "workspace": "$workspace_id",
                "workspace_uuid": "$workspace_uuid",
                "screen": "$screen_id",
                "screen_uuid": "$screen_uuid",
                "pane": "$pane_id",
                "pane_uuid": "$pane_uuid",
                "tab": "$surface_id",
                "surface_uuid": "$surface_uuid"
              },
              "zoom": { "pane": null, "pane_uuid": null },
              "scroll": { "surface": null, "surface_uuid": null, "offset": 0 }
            }
          },
          "match": "exact"
        },
        {
          "type": "command",
          "request": {
            "id": 5,
            "cmd": "update-presentation",
            "presentation_id": "$presentation_id",
            "expected_generation": 1,
            "scroll": { "surface_uuid": "$surface_uuid", "offset": 4 }
          },
          "expect": {
            "id": 5,
            "ok": true,
            "data": {
              "presentation_id": "$presentation_id",
              "generation": 2,
              "client": "$presentation_client",
              "view": {
                "workspace": "$workspace_id",
                "workspace_uuid": "$workspace_uuid",
                "screen": "$screen_id",
                "screen_uuid": "$screen_uuid",
                "pane": "$pane_id",
                "pane_uuid": "$pane_uuid",
                "tab": "$surface_id",
                "surface_uuid": "$surface_uuid"
              },
              "zoom": { "pane": null, "pane_uuid": null },
              "scroll": { "surface": "$surface_id", "surface_uuid": "$surface_uuid", "offset": 4 }
            }
          },
          "match": "exact"
        },
        {
          "type": "command",
          "request": {
            "id": 6,
            "cmd": "close-presentation",
            "presentation_id": "$presentation_id"
          },
          "expect": { "id": 6, "ok": true, "data": {} },
          "match": "exact"
        },
        {
          "type": "stream",
          "name": "topology",
          "request": {
            "id": 7,
            "cmd": "subscribe-topology",
            "daemon_instance_id": "$daemon_instance_id",
            "session_id": "$session_id",
            "revision": "$revision"
          },
          "expect": {
            "id": 7,
            "ok": true,
            "data": {
              "status": "subscribed",
              "daemon_instance_id": "$daemon_instance_id",
              "session_id": "$session_id",
              "from_revision": "$revision"
            }
          },
          "match": "partial"
        },
        {
          "type": "command",
          "request": { "id": 8, "cmd": "rename-workspace", "workspace": "$workspace_id", "name": "conf-v8-renamed" },
          "expect": { "id": 8, "ok": true },
          "match": "partial"
        },
        {
          "type": "expect_events",
          "stream": "topology",
          "expect": [
            {
              "event": "topology-delta",
              "daemon_instance_id": "$daemon_instance_id",
              "session_id": "$session_id",
              "operation": "workspace-renamed"
            }
          ]
        }
      ]
    },
    {
      "name": "workspace-tab-split-rename",
      "steps": [
        {
          "type": "command",
          "request": { "id": 1, "cmd": "new-workspace", "name": "conf-tree", "cols": 80, "rows": 24 },
          "expect": { "id": 1, "ok": true },
          "match": "partial",
          "bind": { "surface0": "data.surface" }
        },
        {
          "type": "command",
          "request": { "id": 2, "cmd": "list-workspaces" },
          "expect": { "id": 2, "ok": true },
          "match": "partial",
          "bind": {
            "workspace0": "data.workspaces[1].id",
            "pane0": "data.workspaces[1].screens[0].panes[0].id"
          }
        },
        {
          "type": "command",
          "request": { "id": 3, "cmd": "new-tab", "pane": "$pane0" },
          "expect": { "id": 3, "ok": true },
          "match": "partial",
          "bind": { "surface1": "data.surface" }
        },
        {
          "type": "command",
          "request": { "id": 4, "cmd": "split", "pane": "$pane0", "dir": "right" },
          "expect": { "id": 4, "ok": true },
          "match": "partial",
          "bind": { "surface2": "data.surface" }
        },
        {
          "type": "command",
          "request": { "id": 5, "cmd": "rename-surface", "surface": "$surface1", "name": "renamed-tab" },
          "expect": { "id": 5, "ok": true },
          "match": "partial"
        },
        {
          "type": "command",
          "request": { "id": 6, "cmd": "list-workspaces" },
          "expect": { "id": 6, "ok": true },
          "match": "partial"
        }
      ]
    },
    {
      "name": "move-tab-same-position",
      "requires": { "commands": ["move-tab"] },
      "steps": [
        {
          "type": "command",
          "request": { "id": 1, "cmd": "new-workspace", "name": "conf-move-tab", "cols": 80, "rows": 24 },
          "expect": { "id": 1, "ok": true },
          "match": "partial",
          "bind": { "surface0": "data.surface" }
        },
        {
          "type": "command",
          "request": { "id": 2, "cmd": "list-workspaces" },
          "expect": { "id": 2, "ok": true },
          "match": "partial",
          "bind": { "pane0": "data.workspaces[2].screens[0].panes[0].id" }
        },
        {
          "type": "command",
          "request": { "id": 3, "cmd": "move-tab", "surface": "$surface0", "pane": "$pane0", "index": 0 },
          "expect": { "id": 3, "ok": true },
          "match": "partial"
        }
      ]
    },
    {
      "name": "window-manager-layout-ops",
      "requires": { "commands": ["export-layout", "pane-neighbor", "zoom-pane"] },
      "steps": [
        {
          "type": "command",
          "request": { "id": 1, "cmd": "new-workspace", "name": "conf-wm", "cols": 80, "rows": 24 },
          "expect": { "id": 1, "ok": true },
          "match": "partial"
        },
        {
          "type": "command",
          "request": { "id": 2, "cmd": "list-workspaces" },
          "expect": { "id": 2, "ok": true },
          "match": "partial",
          "bind": { "pane0": "data.workspaces[3].screens[0].panes[0].id" }
        },
        {
          "type": "command",
          "request": { "id": 3, "cmd": "split", "pane": "$pane0", "dir": "right" },
          "expect": { "id": 3, "ok": true },
          "match": "partial"
        },
        {
          "type": "command",
          "request": { "id": 4, "cmd": "list-workspaces" },
          "expect": { "id": 4, "ok": true },
          "match": "partial",
          "bind": { "pane1": "data.workspaces[3].screens[0].panes[1].id" }
        },
        {
          "type": "command",
          "request": { "id": 5, "cmd": "export-layout" },
          "expect": {
            "id": 5,
            "ok": true,
            "data": {
              "layout": { "type": "split", "dir": "right", "ratio": 0.5 },
              "panes": [{ "pane": "$pane0" }, { "pane": "$pane1" }]
            }
          },
          "match": "partial"
        },
        {
          "type": "command",
          "request": { "id": 6, "cmd": "pane-neighbor", "pane": "$pane0", "dir": "right" },
          "expect": { "id": 6, "ok": true, "data": { "pane": "$pane1" } },
          "match": "partial"
        },
        {
          "type": "command",
          "request": { "id": 7, "cmd": "zoom-pane", "pane": "$pane1", "mode": "toggle" },
          "expect": { "id": 7, "ok": true, "data": { "pane": "$pane1", "zoomed": true, "zoomed_pane": "$pane1" } },
          "match": "partial"
        }
      ]
    },
    {
      "name": "subscribe-tree-changed",
      "steps": [
        {
          "type": "stream",
          "name": "events",
          "request": { "id": 1, "cmd": "subscribe" },
          "expect": { "id": 1, "ok": true },
          "match": "partial"
        },
        {
          "type": "command",
          "request": { "id": 2, "cmd": "new-workspace", "name": "conf-events", "cols": 80, "rows": 24 },
          "expect": { "id": 2, "ok": true },
          "match": "partial"
        },
        {
          "type": "expect_events",
          "stream": "events",
          "expect": [
            { "event": "tree-changed" }
          ]
        }
      ]
    },
    {
      "name": "subscribe-title-changed-carries-title",
      "steps": [
        {
          "type": "command",
          "request": { "id": 1, "cmd": "new-workspace", "name": "conf-title", "cols": 80, "rows": 24 },
          "expect": { "id": 1, "ok": true },
          "match": "partial",
          "bind": { "surface0": "data.surface" }
        },
        {
          "type": "stream",
          "name": "events",
          "request": { "id": 2, "cmd": "subscribe" },
          "expect": { "id": 2, "ok": true },
          "match": "partial"
        },
        {
          "type": "command",
          "request": { "id": 3, "cmd": "send", "surface": "$surface0", "text": "printf '\\033]2;conformance title\\007'; sleep 30\r" },
          "expect": { "id": 3, "ok": true },
          "match": "partial"
        },
        {
          "type": "expect_events",
          "stream": "events",
          "expect": [
            { "event": "title-changed", "surface": "$surface0", "title": "conformance title" }
          ]
        },
        {
          "type": "command",
          "request": { "id": 4, "cmd": "send", "surface": "$surface0", "text": "\u0003" },
          "expect": { "id": 4, "ok": true },
          "match": "partial"
        }
      ]
    },
    {
      "name": "attach-resize-carries-replay",
      "steps": [
        {
          "type": "command",
          "request": { "id": 1, "cmd": "new-workspace", "name": "conf-attach-resize", "cols": 80, "rows": 24 },
          "expect": { "id": 1, "ok": true },
          "match": "partial",
          "bind": { "surface0": "data.surface" }
        },
        {
          "type": "stream",
          "name": "attach",
          "request": { "cmd": "attach-surface", "surface": "$surface0" },
          "expect": { "ok": true },
          "match": "partial"
        },
        {
          "type": "command",
          "request": { "id": 2, "cmd": "resize-surface", "surface": "$surface0", "cols": 100, "rows": 31 },
          "expect": { "id": 2, "ok": true, "data": { "accepted": true } },
          "match": "partial"
        },
        {
          "type": "expect_events",
          "stream": "attach",
          "expect": [
            {
              "event": "resized",
              "surface": "$surface0",
              "cols": 100,
              "rows": 31,
              "replay": { "__match__": "nonempty-string" }
            }
          ]
        }
      ]
    },
    {
      "name": "send-read-screen-round-trip",
      "steps": [
        {
          "type": "command",
          "request": { "id": 1, "cmd": "new-workspace", "name": "conf-io", "cols": 80, "rows": 24 },
          "expect": { "id": 1, "ok": true },
          "match": "partial",
          "bind": { "surface0": "data.surface" }
        },
        {
          "type": "command",
          "request": { "id": 2, "cmd": "send", "surface": "$surface0", "text": "printf 'cmux-conformance-marker\\n'\r" },
          "expect": { "id": 2, "ok": true },
          "match": "partial"
        },
        {
          "type": "wait_contains",
          "request": { "id": 3, "cmd": "read-screen", "surface": "$surface0" },
          "path": "data.text",
          "contains": "cmux-conformance-marker",
          "timeout_ms": 10000
        }
      ]
    },
    {
      "name": "overflow-event-schema",
      "steps": [
        {
          "type": "parse_event",
          "event": { "event": "overflow", "error": "subscriber fell behind", "scope": "surface", "surface": 7 },
          "expect": { "event": "overflow", "error": "subscriber fell behind", "scope": "surface", "surface": 7 },
          "match": "partial"
        }
      ]
    },
    {
      "name": "implemented-verbs-json",
      "requires": {
        "commands": ["run", "wait-for", "send-key", "copy", "ids", "notify", "list-agents", "report-agent"]
      },
      "steps": [
        {
          "type": "command",
          "request": { "id": 1, "cmd": "run", "command": "printf 'cmux-run-marker\\n'; cat", "name": "conf-run", "cols": 80, "rows": 24 },
          "expect": { "id": 1, "ok": true },
          "match": "partial",
          "bind": { "surface0": "data.surface" }
        },
        {
          "type": "wait_contains",
          "request": { "id": 2, "cmd": "copy", "surface": "$surface0", "mode": "screen" },
          "path": "data.text",
          "contains": "cmux-run-marker",
          "timeout_ms": 10000
        },
        {
          "type": "command",
          "request": { "id": 3, "cmd": "wait-for", "surface": "$surface0", "pattern": "cmux-run-marker", "timeout_ms": 5000 },
          "expect": { "id": 3, "ok": true, "data": { "matched": true } },
          "match": "partial"
        },
        {
          "type": "command",
          "request": { "id": 4, "cmd": "ids", "kind": "surface" },
          "expect": { "id": 4, "ok": true },
          "match": "partial"
        },
        {
          "type": "command",
          "request": { "id": 5, "cmd": "notify", "title": "Build", "body": "ok", "level": "info", "surface": "$surface0" },
          "expect": { "id": 5, "ok": true },
          "match": "partial"
        },
        {
          "type": "command",
          "request": { "id": 6, "cmd": "report-agent", "surface": "$surface0", "state": "working", "source": "socket", "session": "conf" },
          "expect": { "id": 6, "ok": true, "data": { "state": "working", "source": "socket", "session": "conf" } },
          "match": "partial"
        },
        {
          "type": "command",
          "request": { "id": 7, "cmd": "list-agents", "surface": "$surface0", "state": "working" },
          "expect": { "id": 7, "ok": true, "data": { "agents": [ { "surface": "$surface0", "state": "working", "source": "socket", "session": "conf" } ] } },
          "match": "partial"
        },
        {
          "type": "command",
          "request": { "id": 8, "cmd": "send-key", "surface": "$surface0", "keys": ["h", "i", "enter"] },
          "expect": { "id": 8, "ok": true, "data": {} },
          "match": "partial"
        },
        {
          "type": "wait_contains",
          "request": { "id": 9, "cmd": "copy", "surface": "$surface0", "mode": "scrollback" },
          "path": "data.text",
          "contains": "hi",
          "timeout_ms": 10000
        }
      ]
    }
  ]
}

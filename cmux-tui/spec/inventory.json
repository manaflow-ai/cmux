  "feature_families": [
    {"id": "topology-layout-focus", "wire_status": "implemented", "programmability": "partial", "route": "control commands and tree snapshots/events; SDK and conformance parity remain incomplete"},
    {"id": "terminal-text-key-paste", "wire_status": "implemented", "programmability": "partial", "route": "send, send-key, attach-surface; typed and behavioral coverage is incomplete"},
    {"id": "terminal-mouse-focus-input", "wire_status": "partial", "programmability": "partial", "route": "native byte encoder; proposed send-mouse and send-focus"},
    {"id": "terminal-rendering", "wire_status": "partial", "programmability": "partial", "route": "render attach is implemented; terminal-host-v1 resize replay is incompatible until its decoder is repaired; typed SDK parity is incomplete"},
    {"id": "terminal-selection-search-history", "wire_status": "partial", "programmability": "partial", "route": "copy and read-scrollback; proposed cursor, range, search, and clear primitives"},
    {"id": "process-execution-outcome", "wire_status": "partial", "programmability": "partial", "route": "run and process-info; proposed execution records and exit events"},
    {"id": "browser-control-rendering", "wire_status": "implemented", "programmability": "partial", "route": "browser commands and browser attach; typed SDK methods and conformance remain incomplete"},
    {"id": "browser-target-lifecycle", "wire_status": "partial", "programmability": "partial", "route": "browser-state; proposed correlated target, dialog, download, and crash operations"},
    {"id": "clients-authentication-pairing", "wire_status": "partial", "programmability": "partial", "route": "identify, list-clients, pairing; proposed principal, rights, Origin, and credential lifecycle"},
    {"id": "streams-recovery-cancellation", "wire_status": "partial", "programmability": "partial", "route": "subscribe and attach; proposed stream ids, cancel, cursors, and replay"},
    {"id": "agent-lifecycle", "wire_status": "partial", "programmability": "partial", "route": "list-agents and report-agent; proposed caller context, durable records, leases, and events"},
    {"id": "notification-lifecycle", "wire_status": "partial", "programmability": "partial", "route": "notify and notification event; proposed durable list, state transitions, and delivery results"},
    {"id": "hooks-feeds-adapters", "wire_status": "proposed", "programmability": "missing", "route": "versioned hook, feed, and agent-adapter contracts"},
    {"id": "configuration", "wire_status": "partial", "programmability": "partial", "route": "local config and reload-config; proposed schema, get, validate, patch, and change event"},
    {"id": "plugins", "wire_status": "partial", "programmability": "partial", "route": "sidebar-plugin-v0; proposed manifest, permissions, contributions, and transactional management"},
    {"id": "file-sidebar", "wire_status": "presentation-only", "programmability": "partial", "route": "local host filesystem; proposed separately permissioned remote filesystem capability"},
    {"id": "machines-scopes-lifecycle", "wire_status": "external-protocol", "programmability": "partial", "route": "machine-provider-v0-v1; generated SDK and full conformance remain incomplete"},
    {"id": "provider-authority-management", "wire_status": "external-protocol", "programmability": "partial", "route": "provider-management-v1; typed administration client remains incomplete"},
    {"id": "session-discovery-start-relay", "wire_status": "partial", "programmability": "partial", "route": "CLI and transport contract; proposed typed lifecycle helpers"},
    {"id": "frontend-presentation-actions", "wire_status": "presentation-only", "programmability": "partial", "route": "local frontend state; proposed frontend action adapter"},
    {"id": "transport-security-limits", "wire_status": "partial", "programmability": "partial", "route": "Unix/WebSocket controls; proposed uniform bounds, safe session names, Origin allowlist, and revocation"},
    {"id": "keyboard-action-routing", "wire_status": "partial", "programmability": "partial", "route": "native Action and MenuAction inventories; proposed discoverable keymap and frontend action invocation"},
    {"id": "host-terminal-integration", "wire_status": "partial", "programmability": "partial", "route": "OSC colors, clipboard, pointer shape, and cell-pixel behavior; proposed negotiated host capabilities"},
    {"id": "localization", "wire_status": "presentation-only", "programmability": "partial", "route": "native locale catalog; proposed frontend-owned locale and message-key contract"},
    {"id": "diagnostics-data-retention", "wire_status": "partial", "programmability": "partial", "route": "status events and local bounded diagnostics; proposed redacted diagnostic records and retention policy"},
    {"id": "session-restore-import-export", "wire_status": "partial", "programmability": "partial", "route": "workspace registry and terminal-host adoption; proposed exact whole-session snapshot/import"},
    {"id": "distribution-version-identity", "wire_status": "partial", "programmability": "partial", "route": "identify, binary stamps, and package manifests; proposed normative version/platform matrix"},
    {"id": "window-host-integration", "wire_status": "presentation-only", "programmability": "partial", "route": "window-title events and frontend projections; proposed window action adapter"}

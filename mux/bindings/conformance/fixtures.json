{
  "defaults": { "timeout_ms": 5000 },
  "fixtures": [
    {
      "name": "identify",
      "steps": [
        {
          "type": "command",
          "request": { "id": 1, "cmd": "identify" },
          "expect": { "id": 1, "ok": true, "data": { "app": "cmux-mux", "protocol": 5 } },
          "match": "partial"
        }
      ]
    },
    {
      "name": "workspace-tab-split-rename",
      "steps": [
        {
          "type": "command",
          "request": { "id": 1, "cmd": "new-workspace", "name": "conf-tree", "cols": 80, "rows": 24 },
          "expect": { "id": 1, "ok": true },
          "match": "partial",
          "bind": { "surface0": "data.surface" }
        },
        {
          "type": "command",
          "request": { "id": 2, "cmd": "list-workspaces" },
          "expect": { "id": 2, "ok": true },
          "match": "partial",
          "bind": {
            "workspace0": "data.workspaces[0].id",
            "pane0": "data.workspaces[0].screens[0].panes[0].id"
          }
        },
        {
          "type": "command",
          "request": { "id": 3, "cmd": "new-tab", "pane": "$pane0" },
          "expect": { "id": 3, "ok": true },
          "match": "partial",
          "bind": { "surface1": "data.surface" }
        },
        {
          "type": "command",
          "request": { "id": 4, "cmd": "split", "pane": "$pane0", "dir": "right" },
          "expect": { "id": 4, "ok": true },
          "match": "partial",
          "bind": { "surface2": "data.surface" }
        },
        {
          "type": "command",
          "request": { "id": 5, "cmd": "rename-surface", "surface": "$surface1", "name": "renamed-tab" },
          "expect": { "id": 5, "ok": true },
          "match": "partial"
        },
        {
          "type": "command",
          "request": { "id": 6, "cmd": "list-workspaces" },
          "expect": { "id": 6, "ok": true },
          "match": "partial"
        }
      ]
    },
    {
      "name": "move-tab-same-position",
      "requires": { "commands": ["move-tab"] },
      "steps": [
        {
          "type": "command",
          "request": { "id": 1, "cmd": "new-workspace", "name": "conf-move-tab", "cols": 80, "rows": 24 },
          "expect": { "id": 1, "ok": true },
          "match": "partial",
          "bind": { "surface0": "data.surface" }
        },
        {
          "type": "command",
          "request": { "id": 2, "cmd": "list-workspaces" },
          "expect": { "id": 2, "ok": true },
          "match": "partial",
          "bind": { "pane0": "data.workspaces[0].screens[0].panes[0].id" }
        },
        {
          "type": "command",
          "request": { "id": 3, "cmd": "move-tab", "surface": "$surface0", "pane": "$pane0", "index": 0 },
          "expect": { "id": 3, "ok": true },
          "match": "partial"
        }
      ]
    },
    {
      "name": "subscribe-tree-changed",
      "steps": [
        {
          "type": "stream",
          "name": "events",
          "request": { "id": 1, "cmd": "subscribe" },
          "expect": { "id": 1, "ok": true },
          "match": "partial"
        },
        {
          "type": "command",
          "request": { "id": 2, "cmd": "new-workspace", "name": "conf-events", "cols": 80, "rows": 24 },
          "expect": { "id": 2, "ok": true },
          "match": "partial"
        },
        {
          "type": "expect_events",
          "stream": "events",
          "expect": [
            { "event": "tree-changed" }
          ]
        }
      ]
    },
    {
      "name": "send-read-screen-round-trip",
      "steps": [
        {
          "type": "command",
          "request": { "id": 1, "cmd": "new-workspace", "name": "conf-io", "cols": 80, "rows": 24 },
          "expect": { "id": 1, "ok": true },
          "match": "partial",
          "bind": { "surface0": "data.surface" }
        },
        {
          "type": "command",
          "request": { "id": 2, "cmd": "send", "surface": "$surface0", "text": "printf 'cmux-conformance-marker\\n'\r" },
          "expect": { "id": 2, "ok": true },
          "match": "partial"
        },
        {
          "type": "wait_contains",
          "request": { "id": 3, "cmd": "read-screen", "surface": "$surface0" },
          "path": "data.text",
          "contains": "cmux-conformance-marker",
          "timeout_ms": 10000
        }
      ]
    }
  ]
}

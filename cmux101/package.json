{
  "name": "cmux101",
  "version": "0.1.0",
  "description": "An agentic coding CLI with first-class cmux integration",
  "type": "module",
  "bin": {
    "cmux101": "./bin/cmux101"
  },
  "scripts": {
    "start": "bun run src/cli/index.ts",
    "build": "bun build --compile --target=bun-darwin-arm64 --outfile=dist/cmux101 src/cli/index.ts",
    "build:all": "bun run scripts/build-all.ts",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "openai": "^4.80.0",
    "@google/generative-ai": "^0.21.0",
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "google-auth-library": "^9.14.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5",
    "chalk": "^5.3.0",
    "fast-glob": "^3.3.2",
    "diff": "^7.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.13",
    "@types/react": "^18.3.12",
    "@types/diff": "^7.0.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}

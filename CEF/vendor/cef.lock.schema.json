{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/manaflow-ai/cmux/Prototypes/cef-webview/vendor/cef.lock.schema.json",
  "title": "cmux CEF lockfile",
  "description": "Pinned CEF binary distribution metadata. Sole source of truth for which CEF cmux ships.",
  "type": "object",
  "required": ["version", "channel", "platforms", "sources"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "comment": {
      "type": "string",
      "description": "Free-form human-readable note. Not consumed by tooling."
    },
    "version": {
      "type": "string",
      "description": "Full CEF version string as published in the cef-builds index, e.g. '146.0.10+g8219561+chromium-146.0.7680.179'.",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+\\+g[0-9a-f]+\\+chromium-[0-9.]+$"
    },
    "channel": {
      "type": "string",
      "enum": ["stable", "beta"]
    },
    "platforms": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "macosarm64": {
          "$ref": "#/definitions/platform"
        },
        "macosx64": {
          "$ref": "#/definitions/platform"
        }
      },
      "minProperties": 1
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "base_url", "kind"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "base_url": { "type": "string", "format": "uri" },
          "kind": { "type": "string", "enum": ["public", "mirror"] }
        }
      }
    }
  },
  "definitions": {
    "platform": {
      "type": "object",
      "required": ["tarball", "sha1", "size_bytes", "extracted_dir_name"],
      "additionalProperties": false,
      "properties": {
        "tarball": {
          "type": "string",
          "description": "Tarball filename as served by the source. Used to compose the download URL.",
          "pattern": "^cef_binary_.+_macos(arm64|x64)\\.tar\\.bz2$"
        },
        "sha1": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "extracted_dir_name": {
          "type": "string",
          "description": "Top-level directory name created when the tarball is extracted.",
          "pattern": "^cef_binary_.+_macos(arm64|x64)$"
        }
      }
    }
  }
}

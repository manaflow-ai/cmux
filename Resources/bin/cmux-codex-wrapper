#!/bin/bash
# cmux codex wrapper - per-invocation Codex hook injection + launch detection.
#
# When running inside a cmux terminal (CMUX_SURFACE_ID is set), this wrapper
# makes `codex` carry cmux's hooks for THIS invocation only (nothing is written
# to ~/.codex), so Codex's own SessionStart/UserPromptSubmit/Stop/PreToolUse/
# PostToolUse/PermissionRequest fire back into cmux with Codex's real session_id.
# It also fires a best-effort one-way `cmux hooks codex session-start` BEFORE
# exec so a session is detected at launch even if Codex's own SessionStart is
# delayed; the registry dedups by session id so the two are idempotent.
#
# Outside cmux (no CMUX_SURFACE_ID / live socket), or when the user opts out
# (CMUX_CODEX_HOOKS_DISABLED=1), the wrapper does NOTHING but exec the real
# codex. Every failure path below also execs the real codex, so installing the
# wrapper can never break `codex`.

# Deliberately NOT using `set -e`/`set -u`: a wrapper that aborts on any error
# would break the user's `codex`. Each helper handles its own failures and the
# script always reaches an `exec "$REAL_CODEX"`.

# Keep the user's original lookup path for the launched Codex process and for
# finding installations outside the standard package-manager locations.
# Session entrypoints reject candidates physically contained by the current
# Git project, so a project-controlled PATH entry cannot select executable code
# before Codex's project trust decision applies. Every wrapper utility resolves
# from macOS system paths for the same reason.
cmux_codex_lookup_path="${PATH:-}"
PATH="/usr/bin:/bin:/usr/sbin:/sbin"
export PATH

cmux_codex_wrapper_is_self_or_shim() {
    local candidate="$1"
    [[ -n "$candidate" ]] || return 1
    if [[ -e "$candidate" && "$candidate" -ef "$0" ]]; then
        return 0
    fi
    if [[ -n "${CMUX_CODEX_WRAPPER_SHIM:-}" &&
          -e "$candidate" &&
          -e "$CMUX_CODEX_WRAPPER_SHIM" &&
          "$candidate" -ef "$CMUX_CODEX_WRAPPER_SHIM" ]]; then
        return 0
    fi
    if [[ -n "${CMUX_CODEX_WRAPPER_SHIM_ROOT:-}" &&
          "$candidate" == "${CMUX_CODEX_WRAPPER_SHIM_ROOT%/}/codex" ]]; then
        return 0
    fi
    case "$candidate" in
        */cmux-cli-shims/*/codex|*/cmux-cli-shims/codex)
            return 0
            ;;
        */Contents/Resources/bin/codex|*/Resources/bin/codex)
            return 0
            ;;
    esac
    return 1
}

# Return success only for an executable Codex candidate that is neither this
# wrapper nor one of cmux's per-surface shims.
cmux_codex_candidate_is_real() {
    local candidate="$1"
    [[ -f "$candidate" && -x "$candidate" ]] || return 1
    ! cmux_codex_wrapper_is_self_or_shim "$candidate"
}

# Resolve a candidate's directory without following the final executable
# symlink. Package-manager entrypoints commonly use a `codex` symlink to
# `codex.js`; keeping the entrypoint basename lets persisted sessions route back
# through this wrapper.
cmux_codex_logical_candidate() {
    local candidate="$1"
    local physical_directory
    physical_directory="$(
        cd -P "$(dirname "$candidate")" 2>/dev/null && pwd -P
    )" || return 1
    printf '%s/%s' "${physical_directory%/}" "$(basename "$candidate")"
}

# Resolve a candidate's directory and final symlink chain without invoking
# anything from the user's PATH. The physical target is checked alongside the
# logical entrypoint so a repository-owned symlink cannot escape validation.
cmux_codex_physical_candidate() {
    local candidate="$1"
    local target
    local hops=0
    while [[ -L "$candidate" ]]; do
        target="$(/usr/bin/readlink "$candidate" 2>/dev/null)" || return 1
        if [[ "$target" == /* ]]; then
            candidate="$target"
        else
            candidate="$(dirname "$candidate")/$target"
        fi
        (( hops += 1 ))
        (( hops <= 40 )) || return 1
    done

    local physical_directory
    physical_directory="$(
        cd -P "$(dirname "$candidate")" 2>/dev/null && pwd -P
    )" || return 1
    printf '%s/%s' "${physical_directory%/}" "$(basename "$candidate")"
}

# Print the nearest physical ancestor of a directory that contains a Git
# marker. Outside a Git checkout, the directory itself is the untrusted project
# boundary.
cmux_codex_untrusted_project_root() {
    local directory="$1"
    local root
    root="$(cd -P "$directory" 2>/dev/null && pwd -P)" || return 1
    local cursor="$root"
    while :; do
        if [[ -e "$cursor/.git" || -L "$cursor/.git" ]]; then
            printf '%s' "$cursor"
            return 0
        fi
        [[ "$cursor" == "/" ]] && break
        cursor="${cursor%/*}"
        [[ -n "$cursor" ]] || cursor="/"
    done
    printf '%s' "$root"
}

cmux_codex_candidate_is_project_controlled() {
    local candidate="$1"
    shift
    local project_root
    for project_root in "$@"; do
        [[ -n "$project_root" ]] || return 0
        [[ "$project_root" == "/" ]] && return 0
        if [[ "$candidate" == "$project_root"
              || "$candidate" == "$project_root/"* ]]; then
            return 0
        fi
    done
    return 1
}

# Print a physical, executable candidate only when it is outside the untrusted
# project boundary. This lets custom npm/pnpm/user-bin installs work without
# allowing a repository-local `codex` to run before Codex asks for trust.
cmux_codex_validated_session_candidate() {
    local candidate="$1"
    shift
    local logical_candidate
    local physical_candidate
    logical_candidate="$(cmux_codex_logical_candidate "$candidate")" || return 1
    physical_candidate="$(
        cmux_codex_physical_candidate "$logical_candidate"
    )" || return 1
    cmux_codex_candidate_is_real "$logical_candidate" || return 1
    cmux_codex_candidate_is_real "$physical_candidate" || return 1
    cmux_codex_candidate_is_project_controlled \
        "$logical_candidate" \
        "$@" && return 1
    cmux_codex_candidate_is_project_controlled \
        "$physical_candidate" \
        "$@" && return 1
    printf '%s' "$logical_candidate"
}

# Find the real Codex binary. An explicit absolute captured path is checked
# first. Normal PATH lookup remains available for custom installation roots,
# with repository-local candidates rejected for session entrypoints.
find_real_codex() {
    local session_requires_project_validation=false
    local project_roots=()
    if [[ "${cmux_codex_inject_hooks:-0}" == "1" ]]; then
        session_requires_project_validation=true
        local project_root
        project_root="$(cmux_codex_untrusted_project_root ".")" || return 1
        project_roots+=("$project_root")

        # Codex applies -C/--cd from the inherited cwd, and accepts it in both
        # global and resume scopes. Validate against every requested project
        # boundary so a PATH candidate from the effective project cannot run
        # before that project receives a trust decision.
        local args=("$@")
        local index=0 argument directory
        while (( index < ${#args[@]} )); do
            argument="${args[$index]}"
            case "$argument" in
                --)
                    break
                    ;;
                -C|--cd)
                    (( index + 1 < ${#args[@]} )) || return 1
                    directory="${args[$(( index + 1 ))]}"
                    if project_root="$(
                        cmux_codex_untrusted_project_root "$directory"
                    )"; then
                        project_roots+=("$project_root")
                    fi
                    (( index += 2 ))
                    continue
                    ;;
                -C?*)
                    directory="${argument#-C}"
                    if project_root="$(
                        cmux_codex_untrusted_project_root "$directory"
                    )"; then
                        project_roots+=("$project_root")
                    fi
                    ;;
                --cd=*)
                    directory="${argument#--cd=}"
                    if project_root="$(
                        cmux_codex_untrusted_project_root "$directory"
                    )"; then
                        project_roots+=("$project_root")
                    fi
                    ;;
            esac
            if codex_option_consumes_value "$argument"; then
                (( index + 1 < ${#args[@]} )) || return 1
                (( index += 2 ))
            else
                (( index += 1 ))
            fi
        done
    fi

    local custom="${CMUX_CUSTOM_CODEX_PATH:-}"
    custom="${custom#"${custom%%[![:space:]]*}"}"  # trim leading whitespace
    custom="${custom%"${custom##*[![:space:]]}"}"  # trim trailing whitespace
    if [[ "$custom" == /* ]]; then
        if [[ "$session_requires_project_validation" == true ]]; then
            cmux_codex_validated_session_candidate \
                "$custom" \
                "${project_roots[@]}" && return 0
        elif cmux_codex_candidate_is_real "$custom"; then
            printf '%s' "$custom"
            return 0
        fi
    fi

    local self_dir
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    local IFS=:
    local d candidate
    for d in $cmux_codex_lookup_path; do
        [[ -n "$d" ]] || d="."
        [[ "$d" == "$self_dir" ]] && continue
        candidate="$d/codex"
        if [[ "$session_requires_project_validation" == true ]]; then
            cmux_codex_validated_session_candidate \
                "$candidate" \
                "${project_roots[@]}" && return 0
        elif cmux_codex_candidate_is_real "$candidate"; then
            printf '%s' "$candidate"
            return 0
        fi
    done

    local candidates=()
    if [[ "${HOME:-}" == /* ]]; then
        candidates+=(
            "$HOME/.local/bin/codex"
            "$HOME/.bun/bin/codex"
            "$HOME/.nvm/current/bin/codex"
            "$HOME/.volta/bin/codex"
            "$HOME/.fnm/current/bin/codex"
            "$HOME/.local/share/mise/shims/codex"
            "$HOME/.asdf/shims/codex"
            "$HOME/bin/codex"
        )
        local versioned_candidate
        for versioned_candidate in \
            "$HOME"/.nvm/versions/node/*/bin/codex \
            "$HOME"/Library/Application\ Support/fnm/node-versions/*/installation/bin/codex \
            "$HOME"/.local/share/fnm/node-versions/*/installation/bin/codex; do
            candidates+=("$versioned_candidate")
        done
    fi
    candidates+=(
        "/opt/homebrew/bin/codex"
        "/usr/local/bin/codex"
        "/usr/bin/codex"
        "/bin/codex"
    )
    local candidate
    for candidate in "${candidates[@]}"; do
        if [[ "$session_requires_project_validation" == true ]]; then
            cmux_codex_validated_session_candidate \
                "$candidate" \
                "${project_roots[@]}" && return 0
        elif cmux_codex_candidate_is_real "$candidate"; then
            printf '%s' "$candidate"
            return 0
        fi
    done
    return 1
}

# Return 0 only when CMUX_SOCKET_PATH points to a live cmux socket.
cmux_socket_available() {
    local socket="${CMUX_SOCKET_PATH:-}"
    [[ -n "$socket" && -S "$socket" ]] || return 1

    local cmux_bin
    cmux_bin="$(resolve_hook_cmux_bin)"
    [[ -n "$cmux_bin" ]] || return 1

    CMUXTERM_CLI_RESPONSE_TIMEOUT_SEC=0.75 \
        "$cmux_bin" --socket "$socket" ping >/dev/null 2>&1
}

resolve_hook_cmux_bin() {
    local self_dir bundled_cli
    bundled_cli="${CMUX_BUNDLED_CLI_PATH:-}"
    if [[ -n "$bundled_cli" && -x "$bundled_cli" ]]; then
        printf '%s' "$bundled_cli"
        return 0
    fi

    self_dir="$(cd "$(dirname "$0")" && pwd)"
    bundled_cli="$self_dir/cmux"
    if [[ -x "$bundled_cli" ]]; then
        printf '%s' "$bundled_cli"
        return 0
    fi

    bundled_cli="$(command -v cmux 2>/dev/null || true)"
    if [[ -n "$bundled_cli" ]]; then
        printf '%s' "$bundled_cli"
        return 0
    fi

    printf '%s' "cmux"
}

# The interactive session, `exec`/`e`, `resume`, and `fork` entrypoints all
# START a Codex session, so they must receive cmux's hook injection; everything
# else (review, login, mcp, doctor, --help, --version, ...) passes through
# untouched. `resume` is critical: cmux auto-resumes a session as `codex resume
# <id>` after a Mac relaunch, and without hooks the resumed process fires no
# SessionStart, so the registry keeps only the stale pre-relaunch record (its
# old pid is dead -> seeded `.ended`) and the iOS GUI shows it read-only with no
# input bar. Injecting hooks on resume lets the live resumed session re-bind and
# flip back to idle/editable. codex accepts the global `--enable hooks` /
# `--dangerously-bypass-hook-trust` / `-c hooks.X=...` flags before the `resume`
# subcommand, so prepending them is safe. Mirrors should_inject_claude_hooks: a
# leading non-option token that is a known Codex subcommand means "not a session"
# unless it is exec, resume, or fork.
codex_subcommand_starts_session() {
    case "$1" in
        exec|e|resume|fork) return 0 ;;
        *) return 1 ;;
    esac
}

codex_known_subcommand() {
    case "$1" in
        exec|e|review|login|logout|mcp|plugin|mcp-server|app-server|\
        remote-control|app|completion|update|doctor|sandbox|debug|apply|a|\
        resume|archive|delete|unarchive|fork|cloud|exec-server|features|help)
            return 0
            ;;
    esac
    return 1
}

# Options that take a value, so a following non-option token is the value and
# not the subcommand. Conservative: unknown `--flag value` is handled by the
# "first bare token decides" rule below, which is safe because Codex session
# launches take an optional prompt, not a subcommand.
codex_option_consumes_value() {
    case "$1" in
        -c|--config|--enable|--disable|-i|--image|-m|--model|--remote|\
        --remote-auth-token-env|--local-provider|-p|--profile|-s|--sandbox|\
        -C|--cd|--add-dir|-a|--ask-for-approval)
            return 0
            ;;
    esac
    return 1
}

codex_passthrough_option_flag() {
    case "$1" in
        --help|-h|-V|--version)
            return 0
            ;;
    esac
    return 1
}

codex_resume_parser_flag() {
    case "$1" in
        --strict-config|--oss|--dangerously-bypass-approvals-and-sandbox|\
        --dangerously-bypass-hook-trust|--yolo|--search|--no-alt-screen|-h|--help|\
        -V|--version)
            return 0
            ;;
    esac
    return 1
}

codex_recognized_inline_option() {
    case "$1" in
        -c?*|-i?*|-m?*|-p?*|-s?*|-C?*|-a?*|--config=*|--enable=*|\
        --disable=*|--image=*|--model=*|--remote=*|\
        --remote-auth-token-env=*|--local-provider=*|--profile=*|\
        --sandbox=*|--cd=*|--add-dir=*|--ask-for-approval=*)
            return 0
            ;;
    esac
    return 1
}

# Print the zero-based index of the actual `resume` subcommand. This parser is
# deliberately conservative: options with ambiguous or unknown value grammar
# fail closed so an option value named `resume` cannot authorize a PID rebind.
cmux_codex_resume_subcommand_index() {
    local args=("$@")
    local index=0 arg
    while (( index < ${#args[@]} )); do
        arg="${args[$index]}"
        case "$arg" in
            resume)
                printf '%s' "$index"
                return 0
                ;;
            --)
                return 1
                ;;
            -i|--image|-i?*|--image=*)
                return 1
                ;;
        esac
        if codex_option_consumes_value "$arg"; then
            (( index + 1 < ${#args[@]} )) || return 1
            (( index += 2 ))
            continue
        fi
        if codex_resume_parser_flag "$arg" || codex_recognized_inline_option "$arg"; then
            (( index += 1 ))
            continue
        fi
        return 1
    done
    return 1
}

# Print the zero-based index of the actual end-of-options marker in a resume
# invocation. A marker-shaped token consumed by a known option is data, so skip
# value slots with the same arity table used by the resume parser.
cmux_codex_resume_terminator_index() {
    local resume_index="$1"
    shift
    local args=("$@")
    local index=$(( resume_index + 1 )) arg
    while (( index < ${#args[@]} )); do
        arg="${args[$index]}"
        if codex_option_consumes_value "$arg"; then
            (( index + 1 < ${#args[@]} )) || return 1
            (( index += 2 ))
            continue
        fi
        if [[ "$arg" == "--" ]]; then
            printf '%s' "$index"
            return 0
        fi
        (( index += 1 ))
    done
    return 1
}

# Decide whether this invocation is a Codex SESSION entrypoint we should inject
# hooks into. Bare `codex` (no args) and `codex [prompt]` are interactive
# sessions; `codex exec ...` is a non-interactive session; `codex resume ...`
# (picker, <id>, --last, --all <id>) resumes a session; `codex fork ...` starts
# a new session from an existing transcript; any other leading subcommand is
# not.
should_inject_codex_hooks() {
    (( $# == 0 )) && return 0

    local arg
    local skip_next=false
    for arg in "$@"; do
        if [[ "$skip_next" == true ]]; then
            skip_next=false
            continue
        fi
        case "$arg" in
            --)
                return 0
                ;;
            -*)
                if codex_passthrough_option_flag "$arg"; then
                    return 1
                fi
                if [[ "$arg" != *=* ]] && codex_option_consumes_value "$arg"; then
                    skip_next=true
                fi
                continue
                ;;
            *)
                if codex_known_subcommand "$arg"; then
                    codex_subcommand_starts_session "$arg" && return 0
                    return 1
                fi
                # First bare token is a prompt -> interactive session.
                return 0
                ;;
        esac
    done

    return 0
}

# Extract the resumed session id from a `codex resume ...` argv. codex does NOT
# fire its own SessionStart hook when resuming a session, so without this the GUI
# never learns the resumed session's new live pid: it keeps the stale
# pre-relaunch record whose pid is already dead, the exit watcher flips it to
# `.ended`, and the iOS chat shows it read-only with no input bar. The wrapper,
# unlike codex, knows the resumed id (it is in argv) and the new live pid ($$),
# so it fires the session-start itself (below). The id is the first UUID-shaped
# token after the `resume` subcommand; flags (`--all`, `-c k=v`, `--last`, ...)
# are skipped because they are not UUID-shaped. `codex resume` with no id (the
# interactive picker) and `--last` carry no id at launch, so this returns
# non-zero and those are left to codex.
cmux_codex_resume_session_id() {
    local args=("$@")
    local resume_index index arg
    resume_index="$(cmux_codex_resume_subcommand_index "$@")" || return 1
    index=$(( resume_index + 1 ))
    while (( index < ${#args[@]} )); do
        arg="${args[$index]}"
        if [[ "$arg" == "--" ]]; then
            (( index += 1 ))
            break
        fi
        if [[ "$arg" == "--last" ]]; then
            return 1
        fi
        if [[ "$arg" == "-i" || "$arg" == "--image" ]]; then
            return 1
        fi
        if codex_option_consumes_value "$arg"; then
            (( index + 1 < ${#args[@]} )) || return 1
            (( index += 2 ))
            continue
        fi
        if codex_recognized_inline_option "$arg" \
            || codex_resume_parser_flag "$arg" \
            || [[ "$arg" == "--all" || "$arg" == "--include-non-interactive" ]]; then
            (( index += 1 ))
            continue
        fi
        [[ "$arg" == -* ]] && return 1
        if [[ "$arg" =~ ^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$ ]]; then
            printf '%s' "$arg"
            return 0
        fi
        return 1
    done
    if (( index < ${#args[@]} )); then
        arg="${args[$index]}"
        if [[ "$arg" =~ ^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$ ]]; then
            printf '%s' "$arg"
            return 0
        fi
    fi
    return 1
}

# Whether the invocation uses the non-interactive `exec`/`e` subcommand, which
# requires --skip-git-repo-check tolerance differently; we never add flags codex
# would reject, so this only gates the best-effort wrapper-fired session-start
# transcript hint. (Currently informational; kept for clarity/extension.)

IN_CMUX=0
if [[ -n "${CMUX_SURFACE_ID:-}" ]]; then
    IN_CMUX=1
fi

cmux_codex_inject_hooks=0
if [[ "$IN_CMUX" == "1"
      && "${CMUX_CODEX_HOOKS_DISABLED:-}" != "1" ]] \
    && should_inject_codex_hooks "$@" \
    && cmux_socket_available; then
    cmux_codex_inject_hooks=1
fi

# Resolve real codex up front; if it cannot be found we error like a missing
# binary would (same as the claude wrapper) rather than silently succeeding.
REAL_CODEX="$(find_real_codex "$@")" || {
    echo "Error: codex not found in a trusted install location; set CMUX_CUSTOM_CODEX_PATH to its absolute path" >&2
    exit 127
}

exec_real_codex() {
    PATH="$cmux_codex_lookup_path"
    export PATH
    exec "$REAL_CODEX" "$@"
}

exec_real_codex_passthrough() {
    if [[ "$IN_CMUX" == "1" ]]; then
        local cmux_key
        for cmux_key in "${!CMUX_@}"; do
            unset "$cmux_key"
        done
        unset TERMINFO
    fi
    exec_real_codex "$@"
}

# Opt-out, outside cmux, stale/dead socket, and non-session commands pass
# through without project-location filtering or hook injection.
if [[ "$cmux_codex_inject_hooks" != "1" ]]; then
    exec_real_codex_passthrough "$@"
fi

# Export launch identity so the hook subprocesses and cmux's agent-pid /
# ended-detection can bind this Codex to its surface and pid. Because we exec
# codex below, $$ becomes the real codex pid.
export CMUX_CODEX_PID=$$
unset CMUX_CODEX_PROCESS_LEASE_ID
cmux_codex_process_lease_id="$(/usr/bin/uuidgen 2>/dev/null || true)"
if [[ -n "$cmux_codex_process_lease_id" ]]; then
    export CMUX_CODEX_PROCESS_LEASE_ID="$cmux_codex_process_lease_id"
fi
export CMUX_CODEX_HOOK_CMUX_BIN="$(resolve_hook_cmux_bin)"
export CMUX_AGENT_LAUNCH_KIND="codex"
export CMUX_AGENT_LAUNCH_EXECUTABLE="$REAL_CODEX"
export CMUX_AGENT_LAUNCH_CWD="$PWD"
{
    cmux_codex_argv_b64="$(
        {
            printf '%s\0' "$REAL_CODEX"
            if (( $# > 0 )); then
                printf '%s\0' "$@"
            fi
        } | base64 | tr -d '\n'
    )"
    [[ -n "$cmux_codex_argv_b64" ]] && export CMUX_AGENT_LAUNCH_ARGV_B64="$cmux_codex_argv_b64"
}

# On a FRESH launch, no wrapper-fired session-start: codex's own injected
# SessionStart hook (below) fires within ~1s carrying codex's REAL session_id, so
# it is the single authoritative signal. A pre-exec wrapper-fired session-start
# there had no session id and minted a junk `fallback-*` record (a phantom in the
# GUI), so it stays omitted for fresh launches.
#
# RESUME is different: codex does NOT fire SessionStart when resuming, so the
# injected hooks alone would never re-bind the session (its only pid-refreshing
# event never arrives), leaving it stuck on the dead pre-relaunch pid -> `.ended`
# -> read-only with no input bar, with no way out (you cannot submit a prompt
# from a GUI that has no composer). The wrapper has the resumed id (from argv) and
# the new live pid ($$, exported as CMUX_CODEX_PID above), so it fires the
# session-start ITSELF. The handler binds surface/workspace/cwd from the cmux env
# and pid from CMUX_CODEX_PID, re-binding the resumed session to its live pid and
# flipping it back to idle/editable. Fire-and-forget (backgrounded + disowned) so
# it never blocks the launch; best-effort so a failure can never break `codex`.
cmux_codex_resume_sid="$(cmux_codex_resume_session_id "$@")"
if [[ -n "$cmux_codex_resume_sid" \
      && -n "$CMUX_CODEX_HOOK_CMUX_BIN" && -x "$CMUX_CODEX_HOOK_CMUX_BIN" ]]; then
    cmux_codex_resume_payload="{\"session_id\":\"$cmux_codex_resume_sid\",\"cwd\":\"$PWD\",\"cmux_resume_rebind\":true}"
    if [[ -n "${CMUX_SOCKET_PATH:-}" ]]; then
        ( printf '%s' "$cmux_codex_resume_payload" \
            | nohup "$CMUX_CODEX_HOOK_CMUX_BIN" --socket "$CMUX_SOCKET_PATH" hooks codex session-start >/dev/null 2>&1 ) &
    else
        ( printf '%s' "$cmux_codex_resume_payload" \
            | nohup "$CMUX_CODEX_HOOK_CMUX_BIN" hooks codex session-start >/dev/null 2>&1 ) &
    fi
    disown 2>/dev/null || true
fi

# Build the per-invocation [hooks] injection. The cmux CLI emits the exact
# prefix arg list (NUL-separated) that enables hooks and injects cmux's
# FIRE-AND-FORGET hook command for each event. Fire-and-forget is critical:
# codex runs hooks
# synchronously and BLOCKS until they return, so a synchronous `cmux hooks codex
# <sub>` made every launch hang ~35s on "Running SessionStart hook". The emitted
# command captures codex's stdin payload to a temp file, nohup-backgrounds the
# real cmux call with a 30s watchdog, and `echo '{}'` returns to codex instantly,
# so detection still binds the real session id while codex never blocks.
#
# Resolving the args via the CLI (instead of re-deriving fragile shell here)
# avoids quoting bugs in the fire-and-forget command (it contains single quotes
# like `echo '{}'` and `sh -c '...'`). If the emit fails or yields nothing, we
# fall back to plain passthrough so installing the wrapper can never break codex.
CMUX_INJECT_CLI="$CMUX_CODEX_HOOK_CMUX_BIN"
cmux_codex_injected_args=()
cmux_codex_resume_args=()
cmux_codex_read_inject_args() {
    [[ -n "$CMUX_INJECT_CLI" && -x "$CMUX_INJECT_CLI" ]] || return 1
    local arg
    # Read the NUL-TERMINATED arg stream DIRECTLY via process substitution. A
    # `raw="$(... )"` command substitution must NOT be used: bash discards every
    # NUL byte from command-substitution output (with a warning), which would
    # collapse the whole stream into one token and silently drop the injection.
    if [[ -n "${CMUX_SOCKET_PATH:-}" ]]; then
        while IFS= read -r -d '' arg; do
            cmux_codex_injected_args+=("$arg")
        done < <("$CMUX_INJECT_CLI" --socket "$CMUX_SOCKET_PATH" hooks codex inject-args 2>/dev/null)
    else
        while IFS= read -r -d '' arg; do
            cmux_codex_injected_args+=("$arg")
        done < <("$CMUX_INJECT_CLI" hooks codex inject-args 2>/dev/null)
    fi
    (( ${#cmux_codex_injected_args[@]} > 0 )) || return 1
    return 0
}

# Codex parses project trust in the `resume` subcommand's argument scope. The
# same `-c projects=...` override is ignored if it is prepended with the global
# hook configuration, so fetch it separately and place it in the captured
# resume argv, immediately before a resume-scoped `--` when present. An explicit
# persisted or command-line trust decision emits nothing and remains
# authoritative. Any helper failure likewise leaves the suffix empty, allowing
# Codex's own trust picker to fail closed.
cmux_codex_read_resume_args() {
    [[ -n "$CMUX_INJECT_CLI" && -x "$CMUX_INJECT_CLI" ]] || return 1
    local arg=""
    local output_file
    local parsed_args=()
    output_file="$(
        mktemp "${TMPDIR:-/tmp}/cmux-codex-resume-args.XXXXXX"
    )" || return 1
    if [[ -n "${CMUX_SOCKET_PATH:-}" ]]; then
        if ! "$CMUX_INJECT_CLI" --socket "$CMUX_SOCKET_PATH" \
            hooks codex inject-resume-args >"$output_file" 2>/dev/null; then
            rm -f "$output_file"
            return 1
        fi
    else
        if ! "$CMUX_INJECT_CLI" hooks codex inject-resume-args \
            >"$output_file" 2>/dev/null; then
            rm -f "$output_file"
            return 1
        fi
    fi
    while IFS= read -r -d '' arg; do
        parsed_args+=("$arg")
        arg=""
    done < "$output_file"
    rm -f "$output_file"
    # The helper contract is either no output or one complete `-c value` pair.
    # Reject a truncated final token or any partial/unknown shape so a killed
    # helper can never turn the unattended resume into a malformed Codex argv.
    if [[ -n "$arg" ]] \
        || (( ${#parsed_args[@]} != 2 )) \
        || [[ "${parsed_args[0]:-}" != "-c" ]] \
        || [[ -z "${parsed_args[1]:-}" ]]; then
        return 1
    fi
    cmux_codex_resume_args=("${parsed_args[@]}")
    return 0
}

if cmux_codex_read_inject_args; then
    # Only resumes need an effective-config query. Keep fresh launches on the
    # single hook-injection CLI call, while still covering `resume --last` and
    # named-session resumes that do not expose a UUID for the rebind above.
    cmux_codex_resume_index="$(
        cmux_codex_resume_subcommand_index "$@"
    )" || cmux_codex_resume_index=""
    if [[ -n "$cmux_codex_resume_index" ]]; then
        cmux_codex_read_resume_args || cmux_codex_resume_args=()
        if (( ${#cmux_codex_resume_args[@]} > 0 )); then
            cmux_codex_user_args=("$@")
            cmux_codex_resume_terminator="$(
                cmux_codex_resume_terminator_index \
                    "$cmux_codex_resume_index" \
                    "${cmux_codex_user_args[@]}"
            )" || cmux_codex_resume_terminator=-1
            if (( cmux_codex_resume_terminator >= 0 )); then
                exec_real_codex \
                    "${cmux_codex_injected_args[@]}" \
                    "${cmux_codex_user_args[@]:0:$cmux_codex_resume_terminator}" \
                    "${cmux_codex_resume_args[@]}" \
                    "${cmux_codex_user_args[@]:$cmux_codex_resume_terminator}"
            fi
            exec_real_codex \
                "${cmux_codex_injected_args[@]}" \
                "$@" \
                "${cmux_codex_resume_args[@]}"
        fi
    fi
    exec_real_codex "${cmux_codex_injected_args[@]}" "$@"
fi

# Emit failed or returned nothing: never break codex, just pass through.
exec_real_codex_passthrough "$@"

#!/usr/bin/env bash
# cmux claude wrapper - injects hooks and session tracking
#
# When running inside a cmux terminal (CMUX_SURFACE_ID is set), this wrapper
# intercepts `claude` invocations to inject --session-id and --settings flags
# so that Claude Code hooks fire back into cmux for notifications/status.
# Outside cmux, it passes through to the real claude binary unchanged.

# Find the real claude binary, skipping our own directory.
find_real_claude() {
    # Honor custom path from Settings > Automation > Claude Code > Claude Binary Path.
    # Guard against self-reference (user pointing back to this wrapper).
    local custom="${CMUX_CUSTOM_CLAUDE_PATH:-}"
    custom="${custom#"${custom%%[![:space:]]*}"}"  # trim leading whitespace
    custom="${custom%"${custom##*[![:space:]]}"}"  # trim trailing whitespace
    if [[ -n "$custom" && -f "$custom" && -x "$custom" ]]; then
        # Use -ef to detect same underlying file even through symlinks
        if [[ ! "$custom" -ef "$0" ]]; then
            printf '%s' "$custom"
            return 0
        fi
    fi
    local self_dir
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    local IFS=:
    for d in $PATH; do
        [[ "$d" == "$self_dir" ]] && continue
        [[ -x "$d/claude" ]] && printf '%s' "$d/claude" && return 0
    done
    return 1
}

# Return 0 only when CMUX_SOCKET_PATH points to a live cmux socket.
cmux_socket_available() {
    local socket="${CMUX_SOCKET_PATH:-}"
    [[ -n "$socket" && -S "$socket" ]] || return 1

    local self_dir cmux_bin
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    cmux_bin="$self_dir/cmux"
    [[ -x "$cmux_bin" ]] || cmux_bin="$(command -v cmux || true)"
    [[ -n "$cmux_bin" ]] || return 1

    # Keep stale/hung socket checks bounded so claude startup does not block
    # behind the CLI default timeout (15s).
    CMUXTERM_CLI_RESPONSE_TIMEOUT_SEC=0.75 \
        "$cmux_bin" --socket "$socket" ping >/dev/null 2>&1
}

resolve_hook_cmux_bin() {
    local self_dir bundled_cli
    bundled_cli="${CMUX_BUNDLED_CLI_PATH:-}"
    if [[ -n "$bundled_cli" && -x "$bundled_cli" ]]; then
        printf '%s' "$bundled_cli"
        return 0
    fi

    self_dir="$(cd "$(dirname "$0")" && pwd)"
    bundled_cli="$self_dir/cmux"
    if [[ -x "$bundled_cli" ]]; then
        printf '%s' "$bundled_cli"
        return 0
    fi

    bundled_cli="$(command -v cmux || true)"
    if [[ -n "$bundled_cli" ]]; then
        printf '%s' "$bundled_cli"
        return 0
    fi

    printf '%s' "cmux"
}

CLAUDE_AUTH_SELECTION_ENV_KEYS=(
    ANTHROPIC_API_KEY
    ANTHROPIC_MODEL
    ANTHROPIC_SMALL_FAST_MODEL
    CLAUDE_CODE_USE_BEDROCK
    CLAUDE_CODE_USE_VERTEX
)

PRESERVE_CLAUDE_AUTH_SELECTION_ENV=false
case "${CMUX_PRESERVE_CLAUDE_AUTH_SELECTION_ENV:-}" in
    1|true|TRUE|yes|YES) PRESERVE_CLAUDE_AUTH_SELECTION_ENV=true ;;
esac

should_preserve_claude_auth_selection_key() {
    if [[ "$PRESERVE_CLAUDE_AUTH_SELECTION_ENV" == true ]]; then
        local configured_keys="${CMUX_PRESERVE_CLAUDE_AUTH_SELECTION_ENV_KEYS:-}"
        if [[ -z "$configured_keys" ]]; then
            return 0
        fi
        configured_keys="${configured_keys//,/ }"
        local configured_key
        for configured_key in $configured_keys; do
            [[ "$configured_key" == "$1" ]] && return 0
        done
        # Key not in the explicit list: do NOT early-return — fall through to
        # the Vertex/Bedrock auto-preserve below. CMUX_PRESERVE_CLAUDE_AUTH_SELECTION_ENV_KEYS
        # is an additive allow-list, not an exclusion list, so an operator
        # who opts in with a narrower key list still gets Vertex/Bedrock
        # selection signals preserved when those backends are active.
    fi

    # Auto-preserve Vertex/Bedrock auth selection so users with valid
    # CLAUDE_CODE_USE_VERTEX=1 / CLAUDE_CODE_USE_BEDROCK=1 setups in their
    # shell rc authenticate inside cmux the same way they do in plain
    # Terminal. Without this, the wrapper silently drops the selection
    # signal and claude reports "not logged in".
    # Refs: https://github.com/manaflow-ai/cmux/issues/3641 (Vertex)
    #       https://github.com/manaflow-ai/cmux/issues/3638 (Bedrock)
    local vertex_on=false bedrock_on=false
    case "${CLAUDE_CODE_USE_VERTEX:-}" in
        1|true|TRUE|yes|YES) vertex_on=true ;;
    esac
    case "${CLAUDE_CODE_USE_BEDROCK:-}" in
        1|true|TRUE|yes|YES) bedrock_on=true ;;
    esac

    case "$1" in
        CLAUDE_CODE_USE_VERTEX)
            [[ "$vertex_on" == true ]] && return 0
            ;;
        CLAUDE_CODE_USE_BEDROCK)
            [[ "$bedrock_on" == true ]] && return 0
            ;;
        ANTHROPIC_MODEL|ANTHROPIC_SMALL_FAST_MODEL)
            # Vertex and Bedrock require backend-specific full model ids
            # (e.g. "claude-sonnet-4-5@20250929" for Vertex,
            # "us.anthropic.claude-sonnet-4-5-20250929-v1:0" for Bedrock).
            # Preserve the user's selection only when one of those
            # backends is active; otherwise stale ids would leak into the
            # default Anthropic API path.
            if [[ "$vertex_on" == true || "$bedrock_on" == true ]]; then
                return 0
            fi
            ;;
    esac

    return 1
}

normalize_claude_config_dir() {
    [[ -n "${CLAUDE_CONFIG_DIR:-}" ]] || return 0
    [[ -n "${HOME:-}" ]] || return 0

    local value="$CLAUDE_CONFIG_DIR"
    local legacy_root="$HOME/.subrouter/codex/claude"
    local account_root="$HOME/.codex-accounts/claude"
    if [[ "$value" == "~/"* ]]; then
        value="$HOME/${value#~/}"
    fi

    case "$value" in
        "$legacy_root"|"$legacy_root"/*)
            local suffix="${value#$legacy_root}"
            local candidate="$account_root$suffix"
            if [[ -e "$candidate" || -L "$candidate" ]]; then
                export CLAUDE_CONFIG_DIR="$candidate"
            fi
            ;;
    esac
}

clear_inherited_claude_auth_selection_env() {
    if [[ "${IN_CMUX:-0}" == "1" ]]; then
        local key
        for key in "${CLAUDE_AUTH_SELECTION_ENV_KEYS[@]}"; do
            should_preserve_claude_auth_selection_key "$key" && continue
            unset "$key"
        done
    fi
    # Safe outside cmux: this only rewrites an existing subrouter path when the account alias exists.
    normalize_claude_config_dir
}

# Pass through if not in a cmux terminal, hooks are disabled, or the cmux
# socket is unavailable (stale env / app not running).
IN_CMUX=0
if [[ -n "$CMUX_SURFACE_ID" ]]; then
    IN_CMUX=1
fi

if [[ "$IN_CMUX" == "0" || "$CMUX_CLAUDE_HOOKS_DISABLED" == "1" ]] || ! cmux_socket_available; then
    # In cmux-launched shells, preserve old behavior and always clear nested
    # Claude session markers, even when we must pass through due to stale socket.
    if [[ "$IN_CMUX" == "1" ]]; then
        unset CLAUDECODE
    fi
    clear_inherited_claude_auth_selection_env
    REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }
    exec "$REAL_CLAUDE" "$@"
fi

# Find real claude.
REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }

ensure_node_options_restore_module() {
    local guard_dir="${TMPDIR:-/tmp}"
    guard_dir="${guard_dir%/}/cmux-claude-node-options"
    local guard_path="$guard_dir/restore-node-options.cjs"
    mkdir -p "$guard_dir" || return 1
    local temp_path
    temp_path="$(mktemp "$guard_dir/restore-node-options.cjs.XXXXXX")" || return 1
    cat >"$temp_path" <<'EOF'
const hadOriginalNodeOptions = process.env.CMUX_ORIGINAL_NODE_OPTIONS_PRESENT === "1";
const originalNodeOptions = hadOriginalNodeOptions ? (process.env.CMUX_ORIGINAL_NODE_OPTIONS ?? "") : undefined;
const preloadPath = __filename;

if (hadOriginalNodeOptions) {
  process.env.NODE_OPTIONS = originalNodeOptions;
} else {
  delete process.env.NODE_OPTIONS;
}
delete process.env.CMUX_ORIGINAL_NODE_OPTIONS;
delete process.env.CMUX_ORIGINAL_NODE_OPTIONS_PRESENT;

function splitNodeOptions(value) {
  return String(value || "").split(/\s+/).filter(Boolean);
}

function nodeOptionsWithCmuxPreload(existing) {
  const tokens = splitNodeOptions(existing);
  const filtered = [];
  for (let index = 0; index < tokens.length; index += 1) {
    const token = tokens[index];
    if (token === "--require" || token === "-r") {
      const value = tokens[index + 1] || "";
      if (value === preloadPath) {
        index += 1;
        continue;
      }
      filtered.push(token);
      if (index + 1 < tokens.length) {
        filtered.push(tokens[index + 1]);
        index += 1;
      }
      continue;
    }
    if (token === "--max-old-space-size") {
      index += 1;
      continue;
    }
    if (token === `--require=${preloadPath}` || token === `-r=${preloadPath}`) {
      continue;
    }
    if (token.startsWith("--max-old-space-size=")) {
      continue;
    }
    filtered.push(token);
  }
  return [`--require=${preloadPath}`, "--max-old-space-size=4096", ...filtered].join(" ");
}

function normalizeNodeOptionsForRestore(existing) {
  const tokens = splitNodeOptions(existing);
  const normalized = [];
  for (let index = 0; index < tokens.length; index += 1) {
    const token = tokens[index];
    if (token === "--require" || token === "-r") {
      const value = tokens[index + 1] || "";
      if (value === preloadPath) {
        index += 1;
        continue;
      }
      normalized.push(token);
      if (index + 1 < tokens.length) {
        normalized.push(tokens[index + 1]);
        index += 1;
      }
      continue;
    }
    if (token === `--require=${preloadPath}` || token === `-r=${preloadPath}`) {
      continue;
    }
    if (token === "--max-old-space-size" && index + 1 < tokens.length) {
      normalized.push(`--max-old-space-size=${tokens[index + 1]}`);
      index += 1;
      continue;
    }
    normalized.push(token);
  }
  return normalized.join(" ");
}

function installClaudeChildHookPropagation() {
  const hookSettingsBase64 = process.env.CMUX_CLAUDE_HOOKS_JSON_B64 || "";
  if (!hookSettingsBase64) {
    return;
  }

  process.env.CMUX_CLAUDE_PID = String(process.pid);

  const childProcess = require("node:child_process");
  const path = require("node:path");
  const hookSettingsJson = Buffer.from(hookSettingsBase64, "base64").toString("utf8");
  const entrypoint = process.env.CMUX_CLAUDE_ENTRYPOINT || process.argv[1] || "";
  process.env.CMUX_CLAUDE_ENTRYPOINT = entrypoint;

  const passthroughSubcommands = new Set([
    "api-key",
    "auth",
    "config",
    "doctor",
    "install",
    "mcp",
    "project",
    "rc",
    "remote-control",
    "setup-token",
    "update",
    "upgrade",
  ]);
  const envOnlySubcommands = new Set(["agents", "daemon"]);
  const knownSubcommands = new Set([...passthroughSubcommands, ...envOnlySubcommands]);
  const valueOptions = new Set([
    "--add-dir",
    "--agent",
    "--agents",
    "--allowedTools",
    "--allowed-tools",
    "--append-system-prompt",
    "--betas",
    "--dangerously-load-development-channels",
    "--debug-file",
    "--disallowedTools",
    "--disallowed-tools",
    "--effort",
    "--fallback-model",
    "--file",
    "--fork-session",
    "--from-pr",
    "--input-format",
    "--json-schema",
    "--max-budget-usd",
    "--mcp-config",
    "--model",
    "-m",
    "--name",
    "-n",
    "--output-format",
    "--permission-mode",
    "--plugin-dir",
    "--plugin-url",
    "--remote-control-session-name-prefix",
    "--resume",
    "-r",
    "--session-id",
    "--setting-sources",
    "--settings",
    "--system-prompt",
    "--teammate-mode",
    "--tmux",
    "--tools",
    "--worktree",
    "-w",
  ]);
  const optionalValueOptions = new Set(["--debug"]);

  function samePath(lhs, rhs) {
    return Boolean(lhs && rhs && path.resolve(String(lhs)) === path.resolve(String(rhs)));
  }

  function claudeInsertIndex(command, args) {
    const commandName = path.basename(String(command || "")).toLowerCase();
    if (commandName === "claude" || commandName === "claude.exe") {
      return 0;
    }
    if (String(command || "") === process.execPath && args.length > 0 && samePath(args[0], entrypoint)) {
      return 1;
    }
    return null;
  }

  function firstClaudeSubcommand(args, startIndex) {
    let index = startIndex;
    while (index < args.length) {
      const arg = String(args[index]);
      if (arg === "--") {
        return "";
      }
      if (arg.startsWith("--")) {
        const hasInlineValue = arg.includes("=");
        if (!hasInlineValue && valueOptions.has(arg)) {
          index += 2;
          continue;
        }
        if (!hasInlineValue && optionalValueOptions.has(arg)) {
          const next = args[index + 1];
          const nextValue = next === undefined ? "" : String(next);
          index += nextValue && !nextValue.startsWith("-") && !knownSubcommands.has(nextValue) ? 2 : 1;
          continue;
        }
        index += 1;
        continue;
      }
      if (arg.startsWith("-") && arg !== "-") {
        index += valueOptions.has(arg) ? 2 : 1;
        continue;
      }
      return arg;
    }
    return "";
  }

  function isCmuxHookCommand(command) {
    if (typeof command !== "string") {
      return false;
    }
    const trimmed = command.trim();
    return trimmed.startsWith("\"${CMUX_CLAUDE_HOOK_CMUX_BIN:-cmux}\" hooks claude ")
      || trimmed === "\"${CMUX_CLAUDE_HOOK_CMUX_BIN:-cmux}\" hooks feed --source claude"
      || trimmed.startsWith("cmux hooks claude ")
      || trimmed === "cmux hooks feed --source claude";
  }

  function settingsJsonHasCmuxHooks(value) {
    let settings;
    try {
      settings = JSON.parse(value);
    } catch {
      return false;
    }
    const hooks = settings && typeof settings === "object" && !Array.isArray(settings)
      ? settings.hooks
      : undefined;
    if (!hooks || typeof hooks !== "object" || Array.isArray(hooks)) {
      return false;
    }
    for (const groups of Object.values(hooks)) {
      if (!Array.isArray(groups)) {
        continue;
      }
      for (const group of groups) {
        const hookEntries = group && typeof group === "object" && !Array.isArray(group)
          ? group.hooks
          : undefined;
        if (!Array.isArray(hookEntries)) {
          continue;
        }
        for (const hook of hookEntries) {
          if (
            hook
            && typeof hook === "object"
            && !Array.isArray(hook)
            && hook.type === "command"
            && isCmuxHookCommand(hook.command)
          ) {
            return true;
          }
        }
      }
    }
    return false;
  }

  function hasCmuxHookSettings(args, startIndex) {
    for (let index = startIndex; index < args.length; index += 1) {
      const arg = String(args[index]);
      if (arg.startsWith("--settings=")) {
        if (settingsJsonHasCmuxHooks(arg.slice("--settings=".length))) {
          return true;
        }
        continue;
      }
      if (arg === "--settings" && index + 1 < args.length) {
        const value = String(args[index + 1]);
        if (settingsJsonHasCmuxHooks(value)) {
          return true;
        }
        index += 1;
      }
    }
    return false;
  }

  function withCmuxSettings(args, insertIndex) {
    if (hasCmuxHookSettings(args, insertIndex)) {
      return args;
    }
    return [
      ...args.slice(0, insertIndex),
      "--settings",
      hookSettingsJson,
      ...args.slice(insertIndex),
    ];
  }

  function base64NulSeparated(values) {
    return Buffer.from(`${values.map(String).join("\0")}\0`, "utf8").toString("base64");
  }

  function launchExecutableForRecord(command, insertIndex) {
    if (String(command || "") === process.execPath && insertIndex === 1) {
      return process.env.CMUX_CLAUDE_REAL_EXECUTABLE || String(command || "");
    }
    return String(command || "");
  }

  function withCmuxClaudeEnv(options, command, args, insertIndex) {
    const nextOptions = options && typeof options === "object" && !Array.isArray(options)
      ? { ...options }
      : {};
    const env = nextOptions.env ? { ...nextOptions.env } : { ...process.env };
    for (const [key, value] of Object.entries(process.env)) {
      if (key.startsWith("CMUX_") && env[key] === undefined) {
        env[key] = value;
      }
    }
    env.CMUX_CLAUDE_HOOKS_JSON_B64 = hookSettingsBase64;
    env.CMUX_CLAUDE_ENTRYPOINT = entrypoint;
    const childOriginalNodeOptions = env.NODE_OPTIONS;
    if (childOriginalNodeOptions !== undefined) {
      env.CMUX_ORIGINAL_NODE_OPTIONS_PRESENT = "1";
      env.CMUX_ORIGINAL_NODE_OPTIONS = normalizeNodeOptionsForRestore(childOriginalNodeOptions);
    } else {
      env.CMUX_ORIGINAL_NODE_OPTIONS_PRESENT = "0";
      delete env.CMUX_ORIGINAL_NODE_OPTIONS;
    }
    env.NODE_OPTIONS = nodeOptionsWithCmuxPreload(childOriginalNodeOptions);
    const launchExecutable = launchExecutableForRecord(command, insertIndex);
    const launchArguments = args.slice(insertIndex);
    env.CMUX_AGENT_LAUNCH_KIND = "claude";
    env.CMUX_AGENT_LAUNCH_EXECUTABLE = launchExecutable;
    env.CMUX_AGENT_LAUNCH_ARGV_B64 = base64NulSeparated([launchExecutable, ...launchArguments]);
    env.CMUX_AGENT_LAUNCH_CWD = String(nextOptions.cwd || process.cwd());
    nextOptions.env = env;
    return nextOptions;
  }

  function patchClaudeChild(command, args, options) {
    const normalizedArgs = Array.isArray(args) ? args.map(String) : [];
    const insertIndex = claudeInsertIndex(command, normalizedArgs);
    if (insertIndex === null) {
      return { args: normalizedArgs, options, patched: false };
    }

    const subcommand = firstClaudeSubcommand(normalizedArgs, insertIndex);
    if (passthroughSubcommands.has(subcommand)) {
      return { args: normalizedArgs, options, patched: false };
    }

    const nextArgs = envOnlySubcommands.has(subcommand)
      ? normalizedArgs
      : withCmuxSettings(normalizedArgs, insertIndex);
    return {
      args: nextArgs,
      options: withCmuxClaudeEnv(options, command, nextArgs, insertIndex),
      patched: true,
    };
  }

  function normalizeOptionalArgsOptions(args, options, argCount) {
    if (Array.isArray(args)) {
      return { args, options };
    }
    if (argCount >= 3 && (args === undefined || args === null)) {
      return { args: [], options };
    }
    if (args && typeof args === "object") {
      return { args: [], options: args };
    }
    return { args: [], options: undefined };
  }

  function callOriginalArgsOptions(original, thisArg, command, argCount, args, options) {
    if (argCount <= 1) {
      return original.call(thisArg, command);
    }
    if (argCount === 2) {
      return original.call(thisArg, command, args);
    }
    return original.call(thisArg, command, args, options);
  }

  function normalizeExecFileArgs(args, options, callback, argCount) {
    if (Array.isArray(args)) {
      return {
        args,
        options: typeof options === "function" ? undefined : options,
        callback: typeof options === "function" ? options : callback,
      };
    }
    if (typeof args === "function") {
      return { args: [], options: undefined, callback: args };
    }
    if (args && typeof args === "object") {
      return {
        args: [],
        options: args,
        callback: typeof options === "function" ? options : callback,
      };
    }
    return {
      args: [],
      options: argCount >= 3 && typeof options !== "function" ? options : undefined,
      callback: typeof options === "function" ? options : callback,
    };
  }

  function callOriginalExecFile(original, thisArg, file, argCount, args, options, callback) {
    if (argCount <= 1) {
      return original.call(thisArg, file);
    }
    if (argCount === 2) {
      return original.call(thisArg, file, args);
    }
    if (argCount === 3) {
      return original.call(thisArg, file, args, options);
    }
    return original.call(thisArg, file, args, options, callback);
  }

  const originalSpawn = childProcess.spawn;
  childProcess.spawn = function patchedSpawn(command, args, options) {
    const argCount = arguments.length;
    const normalized = normalizeOptionalArgsOptions(args, options, argCount);
    const patched = patchClaudeChild(command, normalized.args, normalized.options);
    if (patched.patched) {
      return originalSpawn.call(this, command, patched.args, patched.options);
    }
    return callOriginalArgsOptions(originalSpawn, this, command, argCount, args, options);
  };

  const originalSpawnSync = childProcess.spawnSync;
  childProcess.spawnSync = function patchedSpawnSync(command, args, options) {
    const argCount = arguments.length;
    const normalized = normalizeOptionalArgsOptions(args, options, argCount);
    const patched = patchClaudeChild(command, normalized.args, normalized.options);
    if (patched.patched) {
      return originalSpawnSync.call(this, command, patched.args, patched.options);
    }
    return callOriginalArgsOptions(originalSpawnSync, this, command, argCount, args, options);
  };

  const originalExecFile = childProcess.execFile;
  childProcess.execFile = function patchedExecFile(file, args, options, callback) {
    const argCount = arguments.length;
    const normalized = normalizeExecFileArgs(args, options, callback, argCount);
    const patched = patchClaudeChild(file, normalized.args, normalized.options);
    if (!patched.patched) {
      return callOriginalExecFile(originalExecFile, this, file, argCount, args, options, callback);
    }
    return originalExecFile.call(this, file, patched.args, patched.options, normalized.callback);
  };

  const originalExecFileSync = childProcess.execFileSync;
  childProcess.execFileSync = function patchedExecFileSync(file, args, options) {
    const argCount = arguments.length;
    const normalized = normalizeOptionalArgsOptions(args, options, argCount);
    const patched = patchClaudeChild(file, normalized.args, normalized.options);
    if (patched.patched) {
      return originalExecFileSync.call(this, file, patched.args, patched.options);
    }
    return callOriginalArgsOptions(originalExecFileSync, this, file, argCount, args, options);
  };

  const originalFork = childProcess.fork;
  childProcess.fork = function patchedFork(modulePath, args, options) {
    const argCount = arguments.length;
    const normalized = normalizeOptionalArgsOptions(args, options, argCount);
    if (!samePath(modulePath, entrypoint)) {
      return callOriginalArgsOptions(originalFork, this, modulePath, argCount, args, options);
    }
    const actualArgs = normalized.args.map(String);
    const subcommand = firstClaudeSubcommand(actualArgs, 0);
    if (passthroughSubcommands.has(subcommand)) {
      return callOriginalArgsOptions(originalFork, this, modulePath, argCount, args, options);
    }
    const nextArgs = envOnlySubcommands.has(subcommand) ? actualArgs : withCmuxSettings(actualArgs, 0);
    return originalFork.call(this, modulePath, nextArgs, withCmuxClaudeEnv(normalized.options, process.execPath, [modulePath, ...nextArgs], 1));
  };
}

try {
  installClaudeChildHookPropagation();
} catch {
  // Hook propagation is best-effort. The foreground wrapper still injects hooks.
}
EOF
    chmod 0644 "$temp_path" || {
        rm -f "$temp_path"
        return 1
    }
    if [[ -f "$guard_path" ]] && cmp -s "$temp_path" "$guard_path"; then
        rm -f "$temp_path" || return 1
    else
        mv -f "$temp_path" "$guard_path" || {
            rm -f "$temp_path"
            return 1
        }
    fi
    printf '%s' "$guard_path"
}

merge_node_options() {
    local guard_path="$1"
    local require_flag="--require=$guard_path"
    local memory_flag="--max-old-space-size=4096"
    local existing="${NODE_OPTIONS:-}"
    local -a filtered=()
    local -a tokens=()
    local token
    local index=0

    if [[ -z "$guard_path" ]]; then
        printf '%s' "$existing"
        return 0
    fi

    read -r -a tokens <<<"$existing"
    while (( index < ${#tokens[@]} )); do
        token="${tokens[$index]}"
        if [[ "$token" == "--require" && $((index + 1)) -lt ${#tokens[@]} && "${tokens[$((index + 1))]}" == "$guard_path" ]]; then
            index=$((index + 2))
            continue
        fi
        if [[ "$token" == "--require=$guard_path" ]]; then
            index=$((index + 1))
            continue
        fi
        if [[ "$token" == "--max-old-space-size" ]]; then
            index=$((index + 2))
            continue
        fi
        if [[ "$token" == --max-old-space-size=* ]]; then
            index=$((index + 1))
            continue
        fi
        filtered+=("$token")
        index=$((index + 1))
    done

    if (( ${#filtered[@]} == 0 )); then
        printf '%s %s' "$require_flag" "$memory_flag"
        return 0
    fi
    printf '%s %s' "$require_flag" "$memory_flag"
    printf ' %s' "${filtered[@]}"
}

node_options_has_cmux_preload() {
    local guard_path="$1"
    local existing="${2:-}"
    local -a tokens=()
    local token
    local index=0

    [[ -n "$guard_path" ]] || return 1

    read -r -a tokens <<<"$existing"
    while (( index < ${#tokens[@]} )); do
        token="${tokens[$index]}"
        if [[ "$token" == "--require" && $((index + 1)) -lt ${#tokens[@]} && "${tokens[$((index + 1))]}" == "$guard_path" ]]; then
            return 0
        fi
        if [[ "$token" == "--require=$guard_path" ]]; then
            return 0
        fi
        index=$((index + 1))
    done
    return 1
}

normalize_node_options_for_restore() {
    local existing="${1:-}"
    local guard_path="${2:-}"
    local -a tokens=()
    local -a normalized=()
    local token
    local index=0
    local strip_cmux_injected=false

    if node_options_has_cmux_preload "$guard_path" "$existing"; then
        strip_cmux_injected=true
    fi

    read -r -a tokens <<<"$existing"
    while (( index < ${#tokens[@]} )); do
        token="${tokens[$index]}"
        if [[ -n "$guard_path" && "$token" == "--require" && $((index + 1)) -lt ${#tokens[@]} && "${tokens[$((index + 1))]}" == "$guard_path" ]]; then
            index=$((index + 2))
            continue
        fi
        if [[ -n "$guard_path" && "$token" == "--require=$guard_path" ]]; then
            index=$((index + 1))
            continue
        fi
        if [[ "$strip_cmux_injected" == true && "$token" == "--max-old-space-size" && $((index + 1)) -lt ${#tokens[@]} && "${tokens[$((index + 1))]}" == "4096" ]]; then
            index=$((index + 2))
            continue
        fi
        if [[ "$strip_cmux_injected" == true && "$token" == "--max-old-space-size=4096" ]]; then
            index=$((index + 1))
            continue
        fi
        if [[ "$token" == "--max-old-space-size" && $((index + 1)) -lt ${#tokens[@]} ]]; then
            normalized+=("--max-old-space-size=${tokens[$((index + 1))]}")
            index=$((index + 2))
            continue
        fi
        normalized+=("$token")
        index=$((index + 1))
    done

    if (( ${#normalized[@]} == 0 )); then
        return 0
    fi
    printf '%s' "${normalized[0]}"
    if (( ${#normalized[@]} > 1 )); then
        printf ' %s' "${normalized[@]:1}"
    fi
}

settings_json_has_cmux_hooks() {
    local value="$1"
    [[ "$value" == "$HOOKS_JSON" ]] && return 0
    command -v python3 >/dev/null 2>&1 || return 1
    printf '%s' "$value" | python3 -c '
import json
import sys

try:
    settings = json.loads(sys.stdin.read())
except Exception:
    sys.exit(1)

if not isinstance(settings, dict):
    sys.exit(1)
hooks = settings.get("hooks")
if not isinstance(hooks, dict):
    sys.exit(1)

def is_cmux_hook_command(command):
    if not isinstance(command, str):
        return False
    trimmed = command.strip()
    return (
        trimmed.startswith("\"${CMUX_CLAUDE_HOOK_CMUX_BIN:-cmux}\" hooks claude ")
        or trimmed == "\"${CMUX_CLAUDE_HOOK_CMUX_BIN:-cmux}\" hooks feed --source claude"
        or trimmed.startswith("cmux hooks claude ")
        or trimmed == "cmux hooks feed --source claude"
    )

for groups in hooks.values():
    if not isinstance(groups, list):
        continue
    for group in groups:
        if not isinstance(group, dict):
            continue
        hook_entries = group.get("hooks")
        if not isinstance(hook_entries, list):
            continue
        for hook in hook_entries:
            if (
                isinstance(hook, dict)
                and hook.get("type") == "command"
                and is_cmux_hook_command(hook.get("command"))
            ):
                sys.exit(0)
sys.exit(1)
'
}

args_have_cmux_hook_settings() {
    local arg
    local skip_next=false
    for arg in "$@"; do
        if [[ "$skip_next" == true ]]; then
            if settings_json_has_cmux_hooks "$arg"; then
                return 0
            fi
            skip_next=false
            continue
        fi
        if [[ "$arg" == --settings=* ]] && settings_json_has_cmux_hooks "${arg#--settings=}"; then
            return 0
        fi
        if [[ "$arg" == "--settings" ]]; then
            skip_next=true
            continue
        fi
    done
    return 1
}

encode_launch_argv() {
    {
        printf '%s\0' "$REAL_CLAUDE"
        if (( $# > 0 )); then
            printf '%s\0' "$@"
        fi
    } | base64 | tr -d '\n'
}

claude_option_consumes_value() {
    case "$1" in
        --add-dir|--agent|--agents|--allowedTools|--allowed-tools|\
        --append-system-prompt|--betas|--dangerously-load-development-channels|\
        --debug-file|--disallowedTools|--disallowed-tools|--effort|--fallback-model|--file|\
        --fork-session|\
        --input-format|--json-schema|--max-budget-usd|--mcp-config|\
        --model|-m|-n|--name|--output-format|--permission-mode|--plugin-dir|\
        --plugin-url|--remote-control-session-name-prefix|--setting-sources|\
        --settings|--system-prompt|--teammate-mode|--tmux|--tools)
            return 0
            ;;
    esac
    return 1
}

claude_option_consumes_optional_value() {
    case "$1" in
        --debug)
            return 0
            ;;
    esac
    return 1
}

claude_known_subcommand() {
    case "$1" in
        api-key|auth|config|doctor|install|mcp|project|rc|remote-control|setup-token|update|upgrade|agents|daemon)
            return 0
            ;;
    esac
    return 1
}

claude_should_consume_optional_value() {
    local next="${1:-}"
    [[ -n "$next" ]] || return 1
    [[ "$next" != -* ]] || return 1
    ! claude_known_subcommand "$next"
}

claude_interactive_entry_flag() {
    case "$1" in
        --print|--print=*|-p|--resume|--resume=*|-r|--continue|-c|\
        --session-id|--session-id=*|--remote-control|--remote-control=*|\
        --from-pr|--from-pr=*|--worktree|--worktree=*|-w|-w=*)
            return 0
            ;;
    esac
    return 1
}

should_inject_claude_hooks() {
    (( $# == 0 )) && return 0

    local -a args=("$@")
    local arg
    local index=0
    while (( index < ${#args[@]} )); do
        arg="${args[$index]}"
        case "$arg" in
            --)
                return 0
                ;;
            -*)
                if claude_interactive_entry_flag "$arg"; then
                    return 0
                fi
                if [[ "$arg" != *=* ]] && claude_option_consumes_value "$arg"; then
                    index=$((index + 2))
                    continue
                fi
                if [[ "$arg" != *=* ]] && claude_option_consumes_optional_value "$arg"; then
                    if (( index + 1 < ${#args[@]} )) && claude_should_consume_optional_value "${args[$((index + 1))]}"; then
                        index=$((index + 2))
                    else
                        index=$((index + 1))
                    fi
                    continue
                fi
                index=$((index + 1))
                continue
                ;;
            *)
                return 1
                ;;
        esac
    done

    return 0
}

claude_first_subcommand() {
    local -a args=("$@")
    local arg
    local index=0
    while (( index < ${#args[@]} )); do
        arg="${args[$index]}"
        case "$arg" in
            --)
                return 1
                ;;
            -*)
                if [[ "$arg" != *=* ]] && claude_option_consumes_value "$arg"; then
                    index=$((index + 2))
                    continue
                fi
                if [[ "$arg" != *=* ]] && claude_option_consumes_optional_value "$arg"; then
                    if (( index + 1 < ${#args[@]} )) && claude_should_consume_optional_value "${args[$((index + 1))]}"; then
                        index=$((index + 2))
                    else
                        index=$((index + 1))
                    fi
                    continue
                fi
                index=$((index + 1))
                continue
                ;;
            *)
                printf '%s' "$arg"
                return 0
                ;;
        esac
    done
    return 1
}

# Build Claude settings JSON.
# Claude Code merges --settings additively with the user's own settings.json.
# - preferredNotifChannel: disables Claude Code's OSC/terminal notification
#   channel inside cmux so hooks are the only notification source.
# - SessionStart/Stop/Notification: existing lifecycle hooks
# - SessionEnd: cleanup when Claude exits (covers Ctrl+C where Stop doesn't fire)
# - UserPromptSubmit: clears "Needs input" and sets "Running" on new prompt
# - PreToolUse: rejects unsupported durable cron requests synchronously, then
#   clears "Needs input" and captures AskUserQuestion text for notifications
#   (async status only)
# - PermissionRequest: cmux hooks feed. SYNC with a 125s timeout.
#   This is Claude Code's native blocking decision hook. It covers
#   permissions, ExitPlanMode, and AskUserQuestion without using
#   PreToolUse denial as a side channel.
HOOKS_JSON='{"preferredNotifChannel":"notifications_disabled","hooks":{"SessionStart":[{"matcher":"","hooks":[{"type":"command","command":"\"${CMUX_CLAUDE_HOOK_CMUX_BIN:-cmux}\" hooks claude session-start","timeout":10}]}],"Stop":[{"matcher":"","hooks":[{"type":"command","command":"\"${CMUX_CLAUDE_HOOK_CMUX_BIN:-cmux}\" hooks claude stop","timeout":10}]},{"matcher":"","hooks":[{"type":"command","command":"\"${CMUX_CLAUDE_HOOK_CMUX_BIN:-cmux}\" hooks feed --source claude","timeout":10,"async":true}]}],"SessionEnd":[{"matcher":"","hooks":[{"type":"command","command":"\"${CMUX_CLAUDE_HOOK_CMUX_BIN:-cmux}\" hooks claude session-end","timeout":1}]}],"Notification":[{"matcher":"","hooks":[{"type":"command","command":"\"${CMUX_CLAUDE_HOOK_CMUX_BIN:-cmux}\" hooks claude notification","timeout":10}]}],"UserPromptSubmit":[{"matcher":"","hooks":[{"type":"command","command":"\"${CMUX_CLAUDE_HOOK_CMUX_BIN:-cmux}\" hooks claude prompt-submit","timeout":10}]}],"PreToolUse":[{"matcher":"CronCreate","hooks":[{"type":"command","command":"\"${CMUX_CLAUDE_HOOK_CMUX_BIN:-cmux}\" hooks claude cron-create-guard","timeout":5}]},{"matcher":"","hooks":[{"type":"command","command":"\"${CMUX_CLAUDE_HOOK_CMUX_BIN:-cmux}\" hooks claude pre-tool-use","timeout":5,"async":true}]}],"PermissionRequest":[{"matcher":"","hooks":[{"type":"command","command":"\"${CMUX_CLAUDE_HOOK_CMUX_BIN:-cmux}\" hooks feed --source claude","timeout":125}]}]}}'

configure_claude_hook_environment() {
    # Export the wrapper's PID. Because we exec claude below, this PID becomes
    # the actual claude process PID, which hooks use for stale-session detection.
    export CMUX_CLAUDE_PID=$$
    export CMUX_CLAUDE_HOOK_CMUX_BIN="$(resolve_hook_cmux_bin)"
    export CMUX_CLAUDE_HOOKS_JSON_B64="$(printf '%s' "$HOOKS_JSON" | base64 | tr -d '\n')"
    export CMUX_CLAUDE_REAL_EXECUTABLE="$REAL_CLAUDE"
    export CMUX_AGENT_LAUNCH_KIND="claude"
    export CMUX_AGENT_LAUNCH_EXECUTABLE="$REAL_CLAUDE"
    export CMUX_AGENT_LAUNCH_ARGV_B64="$(encode_launch_argv "$@")"
    export CMUX_AGENT_LAUNCH_CWD="$PWD"
    if GUARD_PATH="$(ensure_node_options_restore_module)"; then
        if [[ ${NODE_OPTIONS+x} ]] && node_options_has_cmux_preload "$GUARD_PATH" "$NODE_OPTIONS" && [[ ${CMUX_ORIGINAL_NODE_OPTIONS_PRESENT+x} ]]; then
            :
        elif [[ ${NODE_OPTIONS+x} ]]; then
            local normalized_node_options
            normalized_node_options="$(normalize_node_options_for_restore "$NODE_OPTIONS" "$GUARD_PATH")"
            if [[ -n "$normalized_node_options" ]]; then
                export CMUX_ORIGINAL_NODE_OPTIONS_PRESENT=1
                export CMUX_ORIGINAL_NODE_OPTIONS="$normalized_node_options"
            else
                export CMUX_ORIGINAL_NODE_OPTIONS_PRESENT=0
                unset CMUX_ORIGINAL_NODE_OPTIONS
            fi
        else
            export CMUX_ORIGINAL_NODE_OPTIONS_PRESENT=0
            unset CMUX_ORIGINAL_NODE_OPTIONS
        fi
        export NODE_OPTIONS="$(merge_node_options "$GUARD_PATH")"
    fi
}

# Only inject hooks for Claude session entrypoints. Other command-like
# invocations pass through so new Claude subcommands do not need cmux changes.
if ! should_inject_claude_hooks "$@"; then
    case "$(claude_first_subcommand "$@")" in
        agents|daemon)
            unset CLAUDECODE
            clear_inherited_claude_auth_selection_env
            configure_claude_hook_environment "$@"
            exec "$REAL_CLAUDE" "$@"
            ;;
    esac
    clear_inherited_claude_auth_selection_env
    exec "$REAL_CLAUDE" "$@"
fi

# Unset CLAUDECODE to avoid "nested session" detection — cmux terminals are
# independent sessions even when the parent shell was launched from Claude Code.
unset CLAUDECODE
clear_inherited_claude_auth_selection_env

# Check if the user already specified a session/resume flag.
# If so, don't inject our own --session-id (it would conflict).
SKIP_SESSION_ID=false
for arg in "$@"; do
    case "$arg" in
        --resume|--resume=*|-r|--session-id|--session-id=*|--continue|-c)
            SKIP_SESSION_ID=true
            break
            ;;
    esac
done

configure_claude_hook_environment "$@"

if [[ "$SKIP_SESSION_ID" == true ]]; then
    if args_have_cmux_hook_settings "$@"; then
        exec "$REAL_CLAUDE" "$@"
    fi
    exec "$REAL_CLAUDE" --settings "$HOOKS_JSON" "$@"
else
    SESSION_ID="$(uuidgen | tr '[:upper:]' '[:lower:]')"
    if args_have_cmux_hook_settings "$@"; then
        exec "$REAL_CLAUDE" --session-id "$SESSION_ID" "$@"
    fi
    exec "$REAL_CLAUDE" --session-id "$SESSION_ID" --settings "$HOOKS_JSON" "$@"
fi

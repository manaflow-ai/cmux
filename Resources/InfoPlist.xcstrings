    "NSBluetoothAlwaysUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A program running within cmux would like to use Bluetooth to discover passkeys and security keys."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux 内で実行中のプログラムが、パスキーとセキュリティキーを検出するために Bluetooth の使用を求めています。"
          }
        }
      }
    },
    "NSCalendarsUsageDescription": {

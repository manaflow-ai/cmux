        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アップデートの準備ができました。インストールを完了するにはアプリケーションを再起動してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "업데이트가 준비되었습니다. 설치를 완료하려면 앱을 재시작하세요."
          }
        },
        "nb": {
          "stringUnit": {

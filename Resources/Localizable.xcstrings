        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo cargar ninguna ruta de carpeta desde el portapapeles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de charger un chemin de dossier depuis le presse-papiers."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile caricare un percorso cartella dagli appunti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クリップボードからフォルダパスを読み込めませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "클립보드에서 폴더 경로를 불러올 수 없습니다."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Kunne ikke laste inn noen mappesti fra utklippstavlen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie udało się wczytać ścieżki folderu ze schowka."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível carregar nenhum caminho de pasta da área de transferência."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось загрузить путь к папке из буфера обмена."

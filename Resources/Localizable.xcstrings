    "socketControl.cmuxOnly.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فقط العمليات التي بدأت داخل طرفيات cmux يمكنها إرسال الأوامر."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Samo procesi pokrenuti unutar cmux terminala mogu slati naredbe."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kun processer startet i cmux-terminaler kan sende kommandoer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur Prozesse, die in cmux-Terminals gestartet wurden, können Befehle senden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only processes started inside cmux terminals can send commands."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo los procesos iniciados dentro de terminales de cmux pueden enviar comandos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seuls les processus lancés dans les terminaux cmux peuvent envoyer des commandes."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo i processi avviati nei terminali cmux possono inviare comandi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux ターミナル内で起動したプロセスのみがコマンドを送信できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux 터미널 내에서 시작된 프로세스만 명령을 보낼 수 있습니다."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Bare prosesser startet innenfor cmux-terminaler kan sende kommandoer."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tylko procesy uruchomione wewnątrz terminali cmux mogą wysyłać polecenia."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Apenas processos iniciados dentro de terminais do cmux podem enviar comandos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Только процессы, запущенные в терминалах cmux, могут отправлять команды."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เฉพาะกระบวนการที่เริ่มต้นภายในเทอร์มินัล cmux เท่านั้นที่สามารถส่งคำสั่งได้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yalnızca cmux terminalleri içinden başlatılan işlemler komut gönderebilir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Тільки процеси, запущені в терміналах cmux, можуть надсилати команди."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅允许在 cmux 终端内启动的进程发送命令。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅在 cmux 終端機內啟動的程序可以傳送指令。"
          }
        }
      }
    },
    "socketControl.cmuxOnly.name": {
      "extractionState": "manual",
      "localizations": {
        "ar": {

    "dialog.quitCmux.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيؤدي هذا إلى إغلاق جميع النوافذ ومساحات العمل."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Ovo će zatvoriti sve prozore i radne prostore."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette lukker alle vinduer og arbejdsområder."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch werden alle Fenster und Arbeitsbereiche geschlossen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will close all windows and workspaces."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto cerrará todas las ventanas y espacios de trabajo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela fermera toutes les fenêtres et tous les espaces de travail."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa operazione chiuderà tutte le finestre e le aree di lavoro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべてのウインドウとワークスペースを閉じます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 윈도우와 작업 공간을 닫습니다."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette vil lukke alle vinduer og arbeidsområder."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spowoduje to zamknięcie wszystkich okien i przestrzeni roboczych."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isto fechará todas as janelas e áreas de trabalho."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все окна и рабочие пространства будут закрыты."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การดำเนินการนี้จะปิดหน้าต่างและเวิร์กสเปซทั้งหมด"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu, tüm pencereleri ve çalışma alanlarını kapatacak."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Це закриє всі вікна та робочі області."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将关闭所有窗口和工作区。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這將關閉所有視窗和工作區。"
          }
        }
      }
    },

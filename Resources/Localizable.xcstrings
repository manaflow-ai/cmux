          "stringUnit": {
            "state": "translated",
            "value": "Cmd+P matches workspace rows only."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Cmd+Pはワークスペース行だけを対象にします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Cmd+P가 워크스페이스 행만 검색합니다."
          }
        },
        "uk": {

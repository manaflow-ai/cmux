        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux nie mógł przenieść tej karty do wybranego miejsca docelowego."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O cmux não conseguiu mover esta aba para o destino selecionado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",

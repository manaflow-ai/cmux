    "error.clipboardFolderPath": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذر تحميل أي مسار مجلد من الحافظة."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nije moguće učitati putanju foldera iz međuspremnika."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kunne ikke indlæse nogen mappesti fra udklipsholderen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es konnte kein Ordnerpfad aus der Zwischenablage geladen werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not load any folder path from the clipboard."

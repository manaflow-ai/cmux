          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontroller din netværksforbindelse, og prøv igen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Überprüfen Sie Ihre Netzwerkverbindung und versuchen Sie es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Check your network connection and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comprueba tu conexión de red e inténtalo de nuevo."

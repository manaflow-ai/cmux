    "update.error.feedDownload.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذر على cmux تنزيل موجز التحديثات. تحقق من اتصالك وحاول مجددًا."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux nije mogao preuzeti feed ažuriranja. Provjerite vezu i pokušajte ponovo."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux kunne ikke downloade opdateringsfeedet. Kontroller din forbindelse, og prøv igen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux konnte den Update-Feed nicht herunterladen. Überprüfen Sie Ihre Verbindung und versuchen Sie es erneut."
          }
        },

    "browser.error.cantReach.messageSite": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "رفض الموقع الاتصال. تأكد من تشغيل خادم على هذا العنوان."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Stranica je odbila vezu. Provjerite da li je server pokrenut na ovoj adresi."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Siden nægtede forbindelsen. Kontroller at en server kører på denne adresse."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Website hat die Verbindung verweigert. Überprüfen Sie, ob ein Server unter dieser Adresse läuft."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The site refused to connect. Check that a server is running on this address."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El sitio rechazó la conexión. Comprueba que haya un servidor en ejecución en esta dirección."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le site a refusé la connexion. Vérifiez qu'un serveur est bien en cours d'exécution à cette adresse."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il sito ha rifiutato la connessione. Verifica che un server sia in esecuzione su questo indirizzo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サイトに接続できませんでした。このアドレスでサーバーが実行されていることを確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사이트에서 연결을 거부했습니다. 이 주소에서 서버가 실행 중인지 확인하세요."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Nettstedet nektet tilkobling. Kontroller at en server kjører på denne adressen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Serwer odmówił połączenia. Sprawdź, czy pod tym adresem działa serwer."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O site recusou a conexão. Verifique se há um servidor em execução neste endereço."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сайт отклонил подключение. Убедитесь, что сервер запущен по этому адресу."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เว็บไซต์ปฏิเสธการเชื่อมต่อ ตรวจสอบว่ามีเซิร์ฟเวอร์ทำงานบนที่อยู่นี้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Site bağlantıyı reddetti. Bu adreste bir sunucunun çalışıp çalışmadığını kontrol edin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Сайт відмовив у з'єднанні. Перевірте, чи працює сервер за цією адресою."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "网站拒绝了连接。请检查此地址上是否有服务器正在运行。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "網站拒絕連線。請確認此位址上有伺服器正在運行。"
          }
        }
      }
    },

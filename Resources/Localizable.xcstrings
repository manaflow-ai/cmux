    "alert.moveTab.failed.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يتمكن cmux من نقل علامة التبويب هذه إلى الوجهة المحددة."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux nije mogao premjestiti ovu karticu na odabrano odredište."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux kunne ikke flytte dette faneblad til den valgte destination."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux konnte diesen Tab nicht zum ausgewählten Ziel verschieben."
          }

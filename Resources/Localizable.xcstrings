    "settings.app.menuBarOnly.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يخفي أيقونة Dock وإدخال Cmd+Tab. استخدم عنصر شريط القائمة لإظهار cmux."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Sakriva Dock ikonu i Cmd+Tab stavku. Koristi stavku trake menija za prikaz cmux-a."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Skjul Dock-symbolet og Cmd+Tab-posten. Brug menulinjeelementet til at vise cmux."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Blendet das Dock-Symbol und den Cmd+Tab-Eintrag aus. Verwende den Menüleisteneintrag, um cmux anzuzeigen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hide the Dock icon and Cmd+Tab entry. Use the menu bar item to show cmux."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Oculta el ícono del Dock y la entrada de Cmd+Tab. Usa el elemento de la barra de menús para mostrar cmux."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Masque l’icône du Dock et l’entrée Cmd+Tab. Utilisez l’élément de barre des menus pour afficher cmux."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nasconde l'icona del Dock e la voce Cmd+Tab. Usa l'elemento nella barra dei menu per mostrare cmux."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "DockアイコンとCmd+Tabの項目を非表示にします。cmuxを表示するにはメニューバー項目を使います。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Dock 아이콘과 Cmd+Tab 항목을 숨깁니다. 메뉴 막대 항목으로 cmux를 표시합니다."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Skjuler Dock-symbolet og Cmd+Tab-oppføringen. Bruk menylinjeelementet for å vise cmux."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ukrywa ikonę Docka i pozycję Cmd+Tab. Użyj elementu na pasku menu, aby pokazać cmux."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Oculta o ícone no Dock e a entrada Cmd+Tab. Use o item da barra de menus para mostrar o cmux."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Скрывает значок Dock и пункт Cmd+Tab. Используйте пункт строки меню, чтобы показать cmux."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ซ่อนไอคอน Dock และรายการ Cmd+Tab ใช้รายการในแถบเมนูเพื่อแสดง cmux"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dock simgesini ve Cmd+Tab girişini gizler. cmux'u göstermek için menü çubuğu öğesini kullan."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Приховує іконку Dock і пункт Cmd+Tab. Використовуйте пункт рядка меню, щоб показати cmux."
          }

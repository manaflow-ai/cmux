    "commandPalette.rename.tabConfirmHint": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضغط Enter لتطبيق اسم اللسان، أو Escape للإلغاء."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pritisnite Enter za primjenu naziva taba, ili Escape za otkazivanje."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryk Enter for at anvende dette fanenavn, eller Escape for at annullere."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Drücken Sie die Eingabetaste, um den Tab-Namen zu übernehmen, oder Escape zum Abbrechen."

    "update.popover.restartRequired.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "التحديث جاهز. يرجى إعادة تشغيل التطبيق لإكمال التثبيت."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Ažuriranje je spremno. Ponovo pokrenite aplikaciju da završite instalaciju."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",

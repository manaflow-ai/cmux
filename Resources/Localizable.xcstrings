          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvor sterkt fargetonen vises over sidefelts materiale."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jak silnie kolor odcienia jest widoczny na materiale paska bocznego."

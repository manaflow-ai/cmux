    "workspace.placement.afterCurrent.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إدراج مساحات العمل الجديدة مباشرة بعد مساحة العمل النشطة."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Umetnite nove radne prostore odmah nakon aktivnog radnog prostora."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Indsæt nye arbejdsområder direkte efter det aktive arbejdsområde."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Neue Arbeitsbereiche direkt nach dem aktiven Arbeitsbereich einfügen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Insert new workspaces directly after the active workspace."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Insertar nuevos espacios de trabajo justo después del espacio de trabajo activo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Insérer les nouveaux espaces de travail juste après l'espace de travail actif."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inserisci le nuove aree di lavoro subito dopo quella attiva."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクティブなワークスペースの直後に新しいワークスペースを挿入します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "활성 작업 공간 바로 다음에 새 작업 공간을 삽입합니다."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Sett inn nye arbeidsområder rett etter det aktive arbeidsområdet."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wstaw nowe przestrzenie robocze bezpośrednio po aktywnej."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Inserir novas áreas de trabalho diretamente após a área de trabalho ativa."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вставлять новые рабочие пространства сразу после активного."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แทรกเวิร์กสเปซใหม่หลังเวิร์กสเปซที่ใช้งานอยู่โดยตรง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yeni çalışma alanlarını etkin çalışma alanının hemen sonrasına ekle."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вставляти нові робочі області одразу після активної."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在活动工作区之后插入新工作区。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將新工作區插入目前使用中工作區的後方。"
          }
        }
      }
    },

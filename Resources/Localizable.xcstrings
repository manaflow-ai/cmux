    "settings.browser.theme.subtitleForced": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ يفرض نظام الألوان هذا للصفحات المتوافقة."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ nameće tu shemu boja za kompatibilne stranice."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ tvinger det farveskema for kompatible sider."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ erzwingt dieses Farbschema für kompatible Seiten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ forces that color scheme for compatible pages."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ fuerza ese esquema de colores para las páginas compatibles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ impose ce jeu de couleurs aux pages compatibles."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ impone quello schema di colori per le pagine compatibili."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@は対応ページにそのカラースキームを強制します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@은(는) 호환 페이지에 해당 색상 구성표를 강제 적용합니다."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ tvinger det fargeskjemaet for kompatible sider."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ wymusza ten schemat kolorów dla zgodnych stron."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ força esse esquema de cores para páginas compatíveis."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ принудительно применяет эту цветовую схему для совместимых страниц."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ บังคับใช้โทนสีนั้นสำหรับหน้าที่รองรับ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ uyumlu sayfalar için bu renk şemasını zorlar."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ примусово встановлює цю кольорову схему для сумісних сторінок."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 为兼容页面强制使用该配色方案。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 會為相容的頁面強制套用該色彩配置。"
          }
        }
      }
    },

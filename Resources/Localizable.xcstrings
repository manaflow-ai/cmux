          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Відновити вбудовані стандартні значення та очистити всі власні кольори."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",

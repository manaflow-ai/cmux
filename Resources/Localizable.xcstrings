    "update.error.serverUnreachable.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذر على cmux الاتصال بخادم التحديثات. تحقق من اتصالك أو حاول لاحقًا."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux se nije mogao povezati na server za ažuriranje. Provjerite vezu ili pokušajte ponovo kasnije."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux kunne ikke oprette forbindelse til opdateringsserveren. Kontroller din forbindelse, eller prøv igen senere."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux konnte keine Verbindung zum Update-Server herstellen. Überprüfen Sie Ihre Verbindung oder versuchen Sie es später erneut."
          }
        },
        "en": {
          "stringUnit": {

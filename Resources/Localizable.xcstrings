    "update.error.permissionError.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انقل cmux إلى مجلد التطبيقات وأعد التشغيل لتفعيل التحديثات."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Premjestite cmux u Applications i ponovo pokrenite da biste omogućili ažuriranja."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Flyt cmux til Programmer, og genstart for at aktivere opdateringer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verschieben Sie cmux in den Ordner 'Programme' und starten Sie die App neu, um Updates zu aktivieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move cmux into Applications and relaunch to enable updates."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mueve cmux a Aplicaciones y vuelve a iniciarlo para activar las actualizaciones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déplacez cmux dans Applications et relancez pour activer les mises à jour."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sposta cmux nella cartella Applicazioni e riavvia per abilitare gli aggiornamenti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アップデートを有効にするには、cmux を「アプリケーション」に移動して再起動してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux를 응용 프로그램 폴더로 이동하고 재실행하여 업데이트를 활성화하세요."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Flytt cmux til Programmer og start på nytt for å aktivere oppdateringer."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przenieś cmux do folderu Aplikacje i uruchom ponownie, aby włączyć aktualizacje."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mova o cmux para Aplicativos e reinicie para ativar as atualizações."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Переместите cmux в папку «Программы» и перезапустите для включения обновлений."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ย้าย cmux ไปที่โฟลเดอร์ Applications แล้วเปิดใหม่เพื่อเปิดใช้งานการอัปเดต"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Güncellemeleri etkinleştirmek için cmux'u Uygulamalar klasörüne taşıyıp yeniden başlatın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Перемістіть cmux до теки Програми та перезапустіть для увімкнення оновлень."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请将 cmux 移到「应用程序」文件夹中，然后重新启动以启用更新。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請將 cmux 移至「應用程式」資料夾並重新啟動，以啟用更新。"
          }
        }
      }
    },

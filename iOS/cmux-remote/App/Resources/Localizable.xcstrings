        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ の %@:%lld（%@）を信頼しますか?\n\nフィンガープリント:\n%@\n\nMacで次を実行して比較してください:\nssh-keygen -E sha256 -lf /etc/ssh/ssh_host_*.pub\n\nSHA256フィンガープリントが完全に一致する場合のみ続行してください。"
          }
        }
      }
    },

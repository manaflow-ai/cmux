    "detail.livePreview.waiting": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Waiting for live video" } },
        "ja": { "stringUnit": { "state": "translated", "value": "ライブ映像を待機中" } }
      }
    },
    "detail.windowID": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Window ID" } },
        "ja": { "stringUnit": { "state": "translated", "value": "ウィンドウID" } }
      }
    },
    "permission.granted": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Granted" } },
        "ja": { "stringUnit": { "state": "translated", "value": "許可済み" } }
      }
    },
    "permission.missing": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Missing" } },
        "ja": { "stringUnit": { "state": "translated", "value": "未許可" } }
      }
    },
    "permission.restartRequired": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Restart Required" } },
        "ja": { "stringUnit": { "state": "translated", "value": "再起動が必要" } }
      }
    },
    "permissions.accessibility": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Accessibility" } },
        "ja": { "stringUnit": { "state": "translated", "value": "アクセシビリティ" } }
      }
    },
    "permissions.screenCapture": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Screen Recording" } },
        "ja": { "stringUnit": { "state": "translated", "value": "画面収録" } }
      }
    },
    "preview.size": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Preview Size" } },
        "ja": { "stringUnit": { "state": "translated", "value": "プレビューサイズ" } }
      }
    },
    "preview.mode": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Mode" } },
        "ja": { "stringUnit": { "state": "translated", "value": "モード" } }
      }
    },
    "preview.mode.native": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Native Window" } },
        "ja": { "stringUnit": { "state": "translated", "value": "ネイティブウィンドウ" } }
      }
    },
    "preview.mode.video": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Video" } },
        "ja": { "stringUnit": { "state": "translated", "value": "ビデオ" } }
      }
    },
    "section.actions": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Actions" } },
        "ja": { "stringUnit": { "state": "translated", "value": "操作" } }
      }
    },
    "section.details": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Details" } },
        "ja": { "stringUnit": { "state": "translated", "value": "詳細" } }
      }
    },
    "section.permissions": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Permissions" } },
        "ja": { "stringUnit": { "state": "translated", "value": "権限" } }
      }
    },
    "section.livePreview": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Live Preview" } },
        "ja": { "stringUnit": { "state": "translated", "value": "ライブプレビュー" } }
      }
    },
    "sidebar.search": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Search windows" } },
        "ja": { "stringUnit": { "state": "translated", "value": "ウィンドウを検索" } }
      }
    },
    "sidebar.title": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Windows" } },
        "ja": { "stringUnit": { "state": "translated", "value": "ウィンドウ" } }
      }
    },
    "status.accessibilityMissing": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Accessibility permission missing" } },
        "ja": { "stringUnit": { "state": "translated", "value": "アクセシビリティ権限がありません" } }
      }
    },
    "status.accessibilityRequested": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Accessibility request sent. System Settings opened if approval is still needed." } },
        "ja": { "stringUnit": { "state": "translated", "value": "アクセシビリティ要求を送信しました。承認が必要な場合はシステム設定を開きました。" } }
      }
    },
    "status.actionFailed": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Window action failed: %@" } },
        "ja": { "stringUnit": { "state": "translated", "value": "ウィンドウ操作に失敗しました: %@" } }
      }
    },
    "status.actionSucceeded": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Window updated" } },
        "ja": { "stringUnit": { "state": "translated", "value": "ウィンドウを更新しました" } }
      }
    },
    "status.inputAccessibilityMissing": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Accessibility permission is needed before forwarding input" } },
        "ja": { "stringUnit": { "state": "translated", "value": "入力を転送するにはアクセシビリティ権限が必要です" } }
      }
    },
    "status.inputFailed": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Input event could not be created" } },
        "ja": { "stringUnit": { "state": "translated", "value": "入力イベントを作成できませんでした" } }
      }
    },
    "status.liveFailed": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Live capture failed: %@" } },
        "ja": { "stringUnit": { "state": "translated", "value": "ライブキャプチャに失敗しました: %@" } }
      }
    },
    "status.liveStarted": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Live capture started" } },
        "ja": { "stringUnit": { "state": "translated", "value": "ライブキャプチャを開始しました" } }
      }
    },
    "status.relaunchFailed": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Relaunch failed: %@" } },
        "ja": { "stringUnit": { "state": "translated", "value": "再起動に失敗しました: %@" } }
      }
    },
    "status.refreshed": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Window list refreshed" } },
        "ja": { "stringUnit": { "state": "translated", "value": "ウィンドウ一覧を更新しました" } }
      }
    },
    "status.screenRequested": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Screen Recording request sent. System Settings opened if approval is still needed." } },
        "ja": { "stringUnit": { "state": "translated", "value": "画面収録要求を送信しました。承認が必要な場合はシステム設定を開きました。" } }
      }
    },
    "status.windowNotFound": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Window unavailable" } },
        "ja": { "stringUnit": { "state": "translated", "value": "ウィンドウを利用できません" } }
      }
    },
    "window.frame.compact": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "%.0f x %.0f" } },
        "ja": { "stringUnit": { "state": "translated", "value": "%.0f x %.0f" } }
      }
    },
    "window.frame.full": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "x %.0f, y %.0f, %.0f x %.0f" } },
        "ja": { "stringUnit": { "state": "translated", "value": "x %.0f, y %.0f, %.0f x %.0f" } }
      }
    },
    "window.untitled": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Untitled" } },
        "ja": { "stringUnit": { "state": "translated", "value": "無題" } }
      }
    },
    "window.location.currentDesktop": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Current Desktop" } },
        "ja": { "stringUnit": { "state": "translated", "value": "現在のデスクトップ" } }
      }
    },
    "window.location.otherDesktop": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Other Desktop" } },
        "ja": { "stringUnit": { "state": "translated", "value": "別のデスクトップ" } }
      }
    },
    "window.owner.unknown": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Unknown App" } },
        "ja": { "stringUnit": { "state": "translated", "value": "不明なアプリ" } }
      }
    }

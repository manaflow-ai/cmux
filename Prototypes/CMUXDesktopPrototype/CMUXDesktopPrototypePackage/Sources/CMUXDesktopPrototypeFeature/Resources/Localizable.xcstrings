{
  "sourceLanguage": "en",
  "version": "1.0",
  "strings": {
    "app.window.title": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "cmux Desktop Prototype" } },
        "ja": { "stringUnit": { "state": "translated", "value": "cmuxデスクトップ試作" } }
      }
    },
    "button.center": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Center" } },
        "ja": { "stringUnit": { "state": "translated", "value": "中央" } }
      }
    },
    "button.fill": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Fill" } },
        "ja": { "stringUnit": { "state": "translated", "value": "全体" } }
      }
    },
    "button.leftHalf": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Left" } },
        "ja": { "stringUnit": { "state": "translated", "value": "左" } }
      }
    },
    "button.raise": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Raise" } },
        "ja": { "stringUnit": { "state": "translated", "value": "前面" } }
      }
    },
    "button.refresh": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Refresh" } },
        "ja": { "stringUnit": { "state": "translated", "value": "更新" } }
      }
    },
    "button.request": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Request" } },
        "ja": { "stringUnit": { "state": "translated", "value": "要求" } }
      }
    },
    "button.relaunch": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Quit & Reopen" } },
        "ja": { "stringUnit": { "state": "translated", "value": "終了して再度開く" } }
      }
    },
    "button.rightHalf": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Right" } },
        "ja": { "stringUnit": { "state": "translated", "value": "右" } }
      }
    },
    "button.restartStream": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Restart Stream" } },
        "ja": { "stringUnit": { "state": "translated", "value": "ストリーム再起動" } }
      }
    },
    "capture.error.windowUnavailable": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Window is unavailable for live capture" } },
        "ja": { "stringUnit": { "state": "translated", "value": "ウィンドウをライブキャプチャに使用できません" } }
      }
    },
    "capture.error.missingEntitlements": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "ScreenCaptureKit reported missing capture entitlements" } },
        "ja": { "stringUnit": { "state": "translated", "value": "ScreenCaptureKitからキャプチャ権限の不足が報告されました" } }
      }
    },
    "capture.error.screenCaptureMissing": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Screen Recording permission is required for live capture" } },
        "ja": { "stringUnit": { "state": "translated", "value": "ライブキャプチャには画面収録権限が必要です" } }
      }
    },
    "capture.error.screenCaptureRestartRequired": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Screen Recording is enabled, but macOS has not applied it to this running copy yet. Quit and reopen the app." } },
        "ja": { "stringUnit": { "state": "translated", "value": "画面収録は有効ですが、この実行中のアプリにはまだ適用されていません。アプリを終了して再度開いてください。" } }
      }
    },
    "detail.alpha": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Alpha" } },
        "ja": { "stringUnit": { "state": "translated", "value": "透明度" } }
      }
    },
    "detail.empty.title": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Select a window" } },
        "ja": { "stringUnit": { "state": "translated", "value": "ウィンドウを選択" } }
      }
    },
    "detail.frame": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Frame" } },
        "ja": { "stringUnit": { "state": "translated", "value": "フレーム" } }
